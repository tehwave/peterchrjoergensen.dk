{
  "name": "peterchrjoergensen",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "npm run build && concurrently --kill-others --names astro,worker \"npm:dev:astro\" \"wrangler dev\"",
    "dev:astro": "chokidar \"src/**/*\" \"public/**/*\" \"astro.config.ts\" -c \"astro build\" --debounce 500",
    "test": "npm run build && vitest run",
    "check": "astro check && tsc -p tsconfig.worker.json",
    "build": "npm run check && astro build",
    "preview": "npm run build && wrangler dev",
    "deploy": "npm run build && wrangler deploy",
    "format": "prettier --write .",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/mdx": "^7.0.2",
    "@astrojs/sitemap": "^3.7.3",
    "@fontsource/caveat": "^5.2.8",
    "@fontsource/inter": "^5.2.8",
    "@playform/compress": "^0.2.3",
    "@playform/inline": "^0.1.4",
    "astro": "^7.1.3",
    "astro-seo-schema": "^7.0.0",
    "pixi.js": "^8.17.1",
    "simple-icons": "^16.16.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260711.1",
    "chokidar-cli": "^3.0.0",
    "concurrently": "^10.0.3",
    "prettier": "3.7.4",
    "prettier-plugin-astro": "0.14.1",
    "sass": "^1.99.0",
    "vitest": "^4.1.10",
    "wrangler": "^4.110.0"
  }
}
