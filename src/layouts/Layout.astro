---
/**
 * Base layout for all pages.
 *
 * Centralizes SEO meta tags, Open Graph, Twitter Cards, and structured data
 * so individual pages only need to pass title/description. Fonts are loaded
 * via Astro's Fonts API with automatic preload links for optimal
 * Core Web Vitals (eliminates CSS → Font request chain).
 */
import "../styles/global.scss";
import { Font } from "astro:assets";
import { ClientRouter } from "astro:transitions";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Surface from "../components/Surface.astro";
import type { Locale } from "../i18n/locale";
import { localeMetadata } from "../i18n/locale";
import { getMessages } from "../i18n/messages";

interface Props {
  title: string;
  description?: string;
  image?: string;
  type?: "website" | "article";
  locale?: Locale;
  contentLocale?: Locale;
  localized?: boolean;
}

const { title, description, image = "/og-image.png", type = "website", locale = "en", contentLocale = locale, localized = false } = Astro.props;
const copy = getMessages(locale);
const resolvedDescription = description ?? copy.metadata.siteDescription;
const documentLanguage = localeMetadata[locale];
const contentLanguage = localeMetadata[contentLocale];

const publicPath = Astro.url.pathname.replace(/^\/__i18n\/(?:en|da)(?=\/|$)/, "") || "/";
const canonicalURL = new URL(publicPath, Astro.site);
const socialImageURL = new URL(image, Astro.site);
---

<!doctype html>
<html lang={documentLanguage.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="title" content={title} />
    <meta name="description" content={resolvedDescription} />
    <meta name="author" content="Peter Chr. Jørgensen" />
    <meta name="robots" content="index, follow" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Resource Hints -->
    <link rel="preconnect" href="https://cdn.usefathom.com" />
    <link rel="preconnect" href="https://analytics.ahrefs.com" />
    <link rel="modulepreload" href="https://cdn.jsdelivr.net/npm/typed.js@2.1.0/+esm" />

    <!-- Font preload links (generated by Astro Fonts API) -->
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-caveat" preload />

    <!-- Client Router for View Transitions -->
    <ClientRouter />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />

    <meta name="color-scheme" content="light" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content={type} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={socialImageURL} />
    <meta property="og:site_name" content="Peter Chr. Jørgensen" />
    <meta property="og:locale" content={contentLanguage.openGraphLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={socialImageURL} />

    <!-- Sitemap -->
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Structured Data -->
    <script
      is:inline
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@graph": [
          {
            "@type": "WebSite",
            "@id": "https://peterchrjoergensen.dk/#website",
            name: "Peter Chr. Jørgensen",
            url: "https://peterchrjoergensen.dk",
            description: copy.metadata.siteDescription,
            inLanguage: documentLanguage.inLanguage,
            publisher: {
              "@id": "https://peterchrjoergensen.dk/#person",
            },
          },
          {
            "@type": "Person",
            "@id": "https://peterchrjoergensen.dk/#person",
            name: "Peter Chr. Jørgensen",
            url: "https://peterchrjoergensen.dk",
            image: "https://peterchrjoergensen.dk/og-image.png",
            jobTitle: copy.metadata.jobTitle,
            description: copy.metadata.personDescription,
            knowsAbout: ["Laravel", "WordPress", "Unity", "Vue.js", "TypeScript", "PHP", "JavaScript", "C#", "Web Development", "Game Development"],
            sameAs: ["https://www.linkedin.com/in/peterchrjoergensen", "https://github.com/peterchrjoergensen", "https://twitter.com/tehwave"],
            mainEntityOfPage: {
              "@id": "https://peterchrjoergensen.dk/#website",
            },
          },
          {
            "@type": "WebPage",
            "@id": canonicalURL + "#webpage",
            url: canonicalURL,
            name: title,
            description: resolvedDescription,
            isPartOf: {
              "@id": "https://peterchrjoergensen.dk/#website",
            },
            about: {
              "@id": "https://peterchrjoergensen.dk/#person",
            },
            inLanguage: contentLanguage.inLanguage,
          },
        ],
      })}
    />

    <!-- Fathom - beautiful, simple website analytics -->
    <script is:inline src="https://cdn.usefathom.com/script.js" data-site="OXXUABJE" defer></script>
    <!-- / Fathom -->

    <!-- Ahrefs Analytics -->
    <script is:inline src="https://analytics.ahrefs.com/analytics.js" data-key="PQ2PVfAM4xEKb65ihHICUQ" defer></script>
    <!-- / Ahrefs Analytics -->

    <!-- Page-specific head content -->
    <slot name="head" />
  </head>
  <body>
    <!-- 
      Skip Link - WCAG 2.4.1 Bypass Blocks (Level A)
      Allows keyboard users to skip navigation and jump directly to main content.
      Hidden off-screen by default, slides into view when focused via Tab key.
      Links to #main-content in Hero component.
    -->
    <style lang="scss">
      @use "../styles/variables" as *;

      /* Skip link styles - positioned off-screen until focused */
      .skip-link {
        position: absolute;
        top: -100px; /* Hidden above viewport */
        left: 0;
        background: $color-orange;
        color: $color-white;
        padding: 8px 16px;
        text-decoration: none;
        font-weight: 600;
        z-index: 10000;
        border-radius: 0 0 4px 0;
      }

      /* Slide into view when keyboard user presses Tab */
      .skip-link:focus {
        top: 0;
      }
    </style>
    <a href="#main-content" class="skip-link">{copy.navigation.skipToContent}</a>
    <Header locale={locale} />
    <Surface as="main" tone="light" width="full" height="auto" depth="end" id="main-content" class="page-surface">
      <slot />
    </Surface>
    <Footer locale={locale} showLocaleSwitch={localized} />
    <script>
      import "../utils/analytics";
    </script>
    <script is:inline type="module">
      const handleExternalLinkClick = (event) => {
        if (event.defaultPrevented) return;

        const anchor = event.target instanceof Element ? event.target.closest("a[target='_blank']") : null;
        if (!(anchor instanceof HTMLAnchorElement) || !anchor.href) return;

        const url = new URL(anchor.href, window.location.href);
        if (url.origin === window.location.origin) return;

        window.trackEvent?.(`External Link: ${url.hostname}`);
      };

      document.body.addEventListener("click", handleExternalLinkClick, { passive: true });
    </script>
  </body>
</html>
