---
import Layout from "../../../layouts/Layout.astro";
import Hero from "../../../components/Hero.astro";
import About from "../../../components/About.astro";
import CurrentWork from "../../../components/CurrentWork.astro";
import Projects from "../../../components/Projects.astro";
import Blog from "../../../components/Blog.astro";
import AI from "../../../components/AI.astro";
import BrickBreaker from "../../../components/BrickBreaker.astro";
import type { Locale } from "../../../i18n/locale";
import { LOCALES } from "../../../i18n/locale";
import { getMessages } from "../../../i18n/messages";

export function getStaticPaths() {
  return LOCALES.map((locale) => ({ params: { internal: "__i18n", locale }, props: { locale } }));
}

interface Props {
  locale: Locale;
}

const { locale } = Astro.props;
const copy = getMessages(locale);
---

<Layout locale={locale} localized title={copy.metadata.homeTitle} description={copy.metadata.homeDescription}>
  <Hero locale={locale} />
  <About locale={locale} />
  <CurrentWork locale={locale} />
  <Projects locale={locale} />
  <BrickBreaker profiles={["tehwave", "peterchrjoergensen"]} locale={locale} />
  <AI locale={locale} />
  <Blog locale={locale} />
</Layout>
