---
import Layout from "../../layouts/Layout.astro";
---

<Layout title="Idle Game Experiment | Peter Chr. Jørgensen" description="A pastel PixiJS idle-game experiment with bouncy animal sprites, day/night cycles, rarity tiers, and local persistence.">
  <!--
    The TypeScript module discovers this root via data attributes instead of
    imports from the Astro template. Keeping the DOM contract explicit here
    makes the Pixi mount resilient to future markup reshuffles.
  -->
  <section class="idle-game" data-idle-game-root>
    <button class="idle-game__back-button" data-idle-game-back type="button" aria-label="Go back"> ← Back </button>

    <div class="idle-game__container">
      <div class="idle-game__card">
        <div class="idle-game__playfield">
          <div class="idle-game__stage" data-idle-game-stage></div>
          <!-- Overlay controls live outside the Pixi canvas so they stay semantic, accessible, and easy to update without rebuilding sprites. -->
          <div class="idle-game__overlay-hud" aria-label="Game status">
            <div class="idle-game__hud-row">
              <span class="idle-game__hud-pill" data-idle-game-population title="Population">🐾 <b>0/0</b></span>
              <span class="idle-game__hud-pill" data-idle-game-food title="Food">🌿 <b>0/0</b></span>
              <span class="idle-game__hud-pill" data-idle-game-coins title="Coins">✨ <b>0</b></span>
            </div>
            <div class="idle-game__hud-row">
              <span class="idle-game__hud-pill" data-idle-game-stardust title="Stardust">🌠 <b>0</b></span>
              <span class="idle-game__hud-pill" data-idle-game-mood title="Mood">💛 <b>0%</b></span>
            </div>
          </div>
          <p class="idle-game__feedback" data-idle-game-feedback aria-live="polite">The meadow wakes up with a gentle bounce.</p>
        </div>

        <div class="idle-game__bottom-bar">
          <div class="idle-game__controls">
            <button class="idle-game__button idle-game__button--feed" data-idle-game-action="feed" type="button">🍎 Feed</button>
            <button class="idle-game__button idle-game__button--populate" data-idle-game-action="populate" type="button">🐣 Hatch</button>
            <button class="idle-game__button idle-game__button--shop" data-idle-game-action="shop" type="button">🏪 Shop</button>
            <button class="idle-game__button idle-game__button--pause" data-idle-game-action="pause" type="button">⏸ Pause</button>
          </div>
        </div>

        <div class="idle-game__shop-drawer" data-idle-game-shop hidden>
          <div class="idle-game__shop-header">
            <h2 class="idle-game__shop-title">🏪 Meadow Shop</h2>
            <button class="idle-game__shop-close" data-idle-game-shop-close type="button" aria-label="Close shop">✕</button>
          </div>
          <div class="idle-game__shop-content">
            <p class="idle-game__shop-hint">Buy animals, expand capacity, and prestige for Stardust.</p>
            <div class="idle-game__shop-list" data-idle-game-shop-list></div>
          </div>
        </div>
      </div>

      <div class="idle-game__credits">
        Pixel art by <a href="https://kenney.nl" target="_blank" rel="noopener noreferrer">Kenney.nl</a> • Built with <a href="https://pixijs.com/" target="_blank" rel="noopener noreferrer">PixiJS</a> •
        Made with love and AI in Denmark. <a href="https://bsky.app/profile/tehwave.bsky.social" target="_blank" rel="noopener noreferrer">@tehwave</a>
      </div>
    </div>
  </section>

  <script>
    import { initIdleGame } from "../../utils/experiments/idle-game";

    // The experiment intentionally behaves like a fullscreen app: the class hides
    // the site chrome and tightens page padding, but is removed before Astro swaps
    // routes so the rest of the site cannot inherit the experiment shell.
    const idleGamePageClass = "idle-game-page";
    const backButtonSelector = "[data-idle-game-back]";

    const applyIdleGamePageClass = () => {
      document.body.classList.add(idleGamePageClass);
    };

    const clearIdleGamePageClass = () => {
      document.body.classList.remove(idleGamePageClass);
    };

    applyIdleGamePageClass();
    document.addEventListener("astro:before-preparation", clearIdleGamePageClass, { once: true });

    const backButton = document.querySelector(backButtonSelector);

    if (backButton instanceof HTMLButtonElement) {
      backButton.addEventListener("click", () => {
        // Prefer browser history when available so deep links return users to the page
        // they came from; fall back to the homepage for direct visits/bookmarks.
        if (window.history.length > 1) {
          window.history.back();
          return;
        }

        window.location.assign("/");
      });
    }

    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", initIdleGame, { once: true });
    } else {
      initIdleGame();
    }

    // Astro view transitions can re-run inline scripts without a full reload.
    // The game module guards against duplicate Pixi mounts, so calling this after
    // every page-load keeps transitions working without leaking canvases/tickers.
    document.addEventListener("astro:page-load", initIdleGame);
  </script>
</Layout>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .idle-game {
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100dvh;
    padding: calc($header-height + $space-md) $space-md $space-md;
    box-sizing: border-box;

    &__container {
      position: relative;
      width: 100%;
      max-width: 420px;
      // The Pixi viewport is tuned around a narrow portrait canvas; flex lets the
      // game fill available height while preserving that phone-like aspect on desktop.
      flex: 1 1 0;
      display: flex;
      flex-direction: column;

      @include respond-to(sm) {
        max-width: 100%;
      }
    }

    &__card {
      position: relative;
      width: 100%;
      flex: 1 1 0;
      display: flex;
      flex-direction: column;
      border-radius: 28px;
      overflow: hidden;
      box-shadow: $shadow-lg;
      border: 1px solid rgba(255, 255, 255, 0.35);
      background: linear-gradient(180deg, rgba(245, 255, 244, 0.96), rgba(224, 247, 217, 0.96));

      @include respond-to(sm) {
        border-radius: 22px;
      }
    }

    &__credits {
      position: absolute;
      top: 0;
      // Offset by the control bar so the vertical credit line centers against the canvas, not the full card.
      bottom: 64px;
      right: -28px;
      display: flex;
      align-items: center;
      writing-mode: vertical-rl;
      transform: rotate(180deg);
      font-size: $font-size-xs;
      color: rgba($color-black, 0.4);
      pointer-events: auto;

      a {
        color: inherit;
        text-decoration: underline;
        text-decoration-color: rgba($color-black, 0.2);
        text-underline-offset: 2px;
        @include transition(all);

        &:hover {
          color: rgba($color-black, 0.8);
          text-decoration-color: rgba($color-black, 0.8);
        }
      }

      @include respond-to(md) {
        right: -16px;
        font-size: 10px;
      }

      @include respond-to(sm) {
        position: static;
        writing-mode: horizontal-tb;
        transform: none;
        text-align: center;
        margin-top: $space-md;
        padding-bottom: $space-sm;
        bottom: auto;
      }
    }

    &__back-button {
      @include focus-ring;
      position: fixed;
      top: calc($space-sm + env(safe-area-inset-top));
      left: $space-sm;
      z-index: 40;
      border: 0;
      border-radius: $radius-full;
      padding: 8px 14px;
      font: inherit;
      font-size: $font-size-sm;
      font-weight: $font-weight-semibold;
      color: $color-text-light;
      background: rgba($color-blue-dark, 0.9);
      backdrop-filter: blur(8px);
      box-shadow: $shadow-sm;
      cursor: pointer;
      transition:
        transform 0.18s cubic-bezier(0.2, 0.7, 0.3, 1),
        background-color 0.18s cubic-bezier(0.2, 0.7, 0.3, 1),
        box-shadow 0.18s cubic-bezier(0.2, 0.7, 0.3, 1);

      &:hover {
        transform: translateY(-1px);
        background: rgba($color-blue-dark, 0.96);
        box-shadow: $shadow-md;
      }

      &:active {
        transform: scale(0.97);
      }
    }

    &__playfield {
      position: relative;
      // `min-height: 0` is the critical flexbox escape hatch: without it the Pixi
      // stage can overflow the card instead of yielding space to the bottom bar.
      flex: 1 1 0;
      min-height: 0;
      overflow: hidden;
    }

    &__stage {
      position: absolute;
      inset: 0;
      overflow: hidden;

      :global(canvas) {
        width: 100% !important;
        height: 100% !important;
        display: block;
        image-rendering: pixelated;
      }
    }

    &__overlay-hud {
      position: absolute;
      top: $space-sm;
      left: $space-sm;
      right: $space-sm;
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 6px;
      z-index: 2;
      // Let taps pass through the HUD wrapper to the canvas; individual pills opt
      // back in so tooltips/copy interactions still work where useful.
      pointer-events: none;
    }

    &__hud-row {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      gap: 6px;
    }

    &__hud-pill {
      display: inline-flex;
      flex: 0 1 auto;
      justify-content: center;
      align-items: center;
      gap: 4px;
      padding: 4px 10px;
      border-radius: $radius-full;
      background: rgba(255, 255, 255, 0.78);
      backdrop-filter: blur(8px);
      font-size: 0.8rem;
      font-variant-numeric: tabular-nums;
      white-space: nowrap;
      color: $color-text-primary;
      box-shadow: 0 1px 4px rgba(0, 0, 0, 0.08);
      line-height: 1.3;
      pointer-events: auto;

      b {
        font-weight: $font-weight-bold;
      }
    }

    &__feedback {
      position: absolute;
      bottom: $space-sm;
      left: $space-sm;
      right: $space-sm;
      margin: 0;
      padding: 6px 12px;
      border-radius: $radius-lg;
      background: rgba(255, 255, 255, 0.72);
      backdrop-filter: blur(8px);
      font-size: $font-size-xs;
      color: $color-text-secondary;
      line-height: $leading-relaxed;
      z-index: 2;
      pointer-events: none;
      text-align: center;
    }

    &__bottom-bar {
      padding: $space-sm $space-md;
      background: rgba(255, 255, 255, 0.82);
      backdrop-filter: blur(12px);
      border-top: 1px solid rgba(0, 0, 0, 0.06);
    }

    &__controls {
      display: grid;
      grid-template-columns: repeat(4, 1fr);
      gap: 6px;
    }

    &__button {
      @include focus-ring;
      border: 0;
      border-radius: $radius-full;
      padding: 10px 6px;
      font: inherit;
      font-size: 0.82rem;
      font-weight: $font-weight-semibold;
      cursor: pointer;
      color: $color-text-primary;
      box-shadow: $shadow-xs;
      transition:
        transform 0.18s cubic-bezier(0.2, 0.7, 0.3, 1),
        background-color 0.18s cubic-bezier(0.2, 0.7, 0.3, 1),
        box-shadow 0.18s cubic-bezier(0.2, 0.7, 0.3, 1);
      white-space: nowrap;

      &:hover:not(:disabled) {
        transform: translateY(-2px);
      }

      &:active:not(:disabled) {
        transform: scale(0.96);
      }

      &:disabled {
        cursor: not-allowed;
        opacity: 0.5;
        transform: none;
      }

      &--feed {
        background: linear-gradient(180deg, #fff1d1, #ffdca3);
      }

      &--populate {
        background: linear-gradient(180deg, #efe3ff, #d8c2ff);
      }

      &--shop {
        background: linear-gradient(180deg, #d1f0ff, #a3d8ff);
      }

      &--pause {
        background: linear-gradient(180deg, #dff6e7, #b6e7c3);
      }
    }

    &__shop-drawer {
      display: flex;
      flex-direction: column;
      position: absolute;
      bottom: 0;
      left: 0;
      right: 0;
      max-height: 60%;
      background: rgba(255, 255, 255, 0.94);
      backdrop-filter: blur(16px);
      border-top: 1px solid rgba(0, 0, 0, 0.08);
      border-radius: 22px 22px 0 0;
      z-index: 10;
      box-shadow: 0 -4px 20px rgba(0, 0, 0, 0.08);
      transition:
        transform 0.2s cubic-bezier(0.2, 0.7, 0.3, 1),
        opacity 0.2s;
      transform-origin: bottom center;

      &[hidden] {
        display: none;
      }
    }

    &__shop-header {
      flex-shrink: 0;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: $space-md $space-md $space-sm;
      cursor: grab;
      touch-action: none;

      &:active {
        cursor: grabbing;
      }
    }

    &__shop-content {
      overflow-y: auto;
      padding: 0 $space-md $space-md;
    }

    &__shop-title {
      margin: 0;
      font-size: $font-size-lg;
      color: $color-text-primary;
    }

    &__shop-close {
      @include focus-ring;
      border: 0;
      background: rgba(0, 0, 0, 0.06);
      border-radius: $radius-full;
      width: 32px;
      height: 32px;
      cursor: pointer;
      font-size: 1rem;
      display: flex;
      align-items: center;
      justify-content: center;
      color: $color-text-secondary;
    }

    &__shop-hint {
      margin: 0 0 $space-sm;
      font-size: $font-size-xs;
      color: $color-text-secondary;
    }

    &__shop-list {
      display: grid;
      gap: 6px;

      // Shop rows are generated imperatively by the Pixi game module. `:global()`
      // keeps Astro's scoped styles attached to this drawer without forcing those
      // DOM nodes to know about the component's generated scope attribute.
      :global(.shop-item) {
        display: flex;
        align-items: center;
        gap: $space-sm;
        padding: 8px 12px;
        border-radius: $radius-lg;
        background: rgba(255, 255, 255, 0.65);
        border: 1px solid rgba(0, 0, 0, 0.06);
      }

      :global(.shop-section) {
        display: grid;
        gap: 6px;
        padding-bottom: $space-sm;
      }

      :global(.shop-section + .shop-section) {
        padding-top: $space-sm;
        border-top: 1px solid rgba(0, 0, 0, 0.08);
      }

      :global(.shop-section__title) {
        margin: 0;
        font-size: $font-size-sm;
        color: $color-text-primary;
      }

      :global(.shop-section__hint) {
        margin: 0;
        font-size: $font-size-xs;
        color: $color-text-secondary;
      }

      :global(.shop-item__icon) {
        width: 36px;
        height: 36px;
        image-rendering: pixelated;
        border-radius: 8px;
      }

      :global(.shop-item__emoji) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        width: 36px;
        height: 36px;
        border-radius: 8px;
        background: rgba(255, 255, 255, 0.72);
        font-size: 1.25rem;
      }

      :global(.shop-item__info) {
        flex: 1;
        min-width: 0;
      }

      :global(.shop-item__name) {
        font-size: $font-size-sm;
        font-weight: $font-weight-semibold;
        color: $color-text-primary;
      }

      :global(.shop-item__rarity) {
        font-size: $font-size-xs;
        text-transform: uppercase;
        letter-spacing: $tracking-wider;
      }

      :global(.shop-item__rarity--common) {
        color: #6b7687;
      }
      :global(.shop-item__rarity--uncommon) {
        color: #2ecc71;
      }
      :global(.shop-item__rarity--rare) {
        color: #3498db;
      }
      :global(.shop-item__rarity--epic) {
        color: #9b59b6;
      }
      :global(.shop-item__rarity--legendary) {
        color: #f39c12;
      }

      :global(.shop-item__stats) {
        font-size: $font-size-xs;
        color: $color-text-secondary;
      }

      :global(.shop-item__buy) {
        @include focus-ring;
        border: 0;
        border-radius: $radius-full;
        padding: 6px 14px;
        font: inherit;
        font-size: $font-size-xs;
        font-weight: $font-weight-semibold;
        cursor: pointer;
        background: linear-gradient(180deg, #fff1d1, #ffdca3);
        color: $color-text-primary;
        white-space: nowrap;
        box-shadow: $shadow-xs;

        &:disabled {
          opacity: 0.45;
          cursor: not-allowed;
        }

        &:hover:not(:disabled) {
          transform: translateY(-1px);
        }
      }
    }

    @media (prefers-reduced-motion: reduce) {
      &__button {
        transition: none;
      }

      &__back-button {
        transition: none;
      }
    }
  }

  :global(body.idle-game-page .header),
  :global(body.idle-game-page .footer) {
    display: none;
  }

  // The body class is applied only while this route is active. This keeps the
  // experiment feeling app-like without making the global layout special-case the route.
  :global(body.idle-game-page) .idle-game {
    min-height: 100dvh;
    padding: $space-sm $space-sm $space-sm;
  }
</style>
