---
import Layout from "../../../layouts/Layout.astro";
---

<Layout
  title="Browser Multiplayer Experiment | Peter Chr. Jørgensen"
  description="A zero-server WebRTC air-hockey experiment with manual handshake, mobile-first controls, and a punchy PixiJS renderer."
>
  <section class="browser-multiplayer" data-browser-multiplayer-root>
    <button class="browser-multiplayer__back" data-browser-multiplayer-back type="button" aria-label="Go back">
      <span aria-hidden="true">&larr;</span>
      <span>Back</span>
    </button>

    <div class="browser-multiplayer__shell">
      <header class="browser-multiplayer__header">
        <p class="browser-multiplayer__eyebrow">Zero-server WebRTC experiment</p>
        <h1 class="browser-multiplayer__title">Puck link</h1>
        <p class="browser-multiplayer__intro">Create a match, send the code, paste the reply, and play. No lobby. No account. No signaling server.</p>
      </header>

      <div class="browser-multiplayer__scoreboard" aria-label="Score">
        <div class="browser-multiplayer__score-card browser-multiplayer__score-card--host">
          <span class="browser-multiplayer__score-label" data-browser-multiplayer-label="host">Host</span>
          <strong class="browser-multiplayer__score-value" data-browser-multiplayer-score="host">0</strong>
        </div>
        <div class="browser-multiplayer__versus" aria-hidden="true">vs</div>
        <div class="browser-multiplayer__score-card browser-multiplayer__score-card--client">
          <span class="browser-multiplayer__score-label" data-browser-multiplayer-label="client">Client</span>
          <strong class="browser-multiplayer__score-value" data-browser-multiplayer-score="client">0</strong>
        </div>
      </div>

      <p class="browser-multiplayer__status" data-browser-multiplayer-status aria-live="polite">Create a game or paste an invite to join.</p>

      <div class="browser-multiplayer__card">
        <div class="browser-multiplayer__stage-wrap">
          <div class="browser-multiplayer__stage" data-browser-multiplayer-stage></div>
          <div class="browser-multiplayer__overlay" data-browser-multiplayer-overlay hidden></div>
          <div class="browser-multiplayer__touch-zone" data-browser-multiplayer-touch aria-label="Drag here to move your paddle" role="application">
            <span>Drag here</span>
          </div>
        </div>
      </div>

      <div class="browser-multiplayer__role" data-browser-multiplayer-role>You will always play from the bottom.</div>

      <!-- Data attributes form the runtime contract consumed by controller.ts. -->
      <section class="browser-multiplayer__panel" data-browser-multiplayer-handshake aria-label="Connection setup">
        <div class="browser-multiplayer__choice">
          <button class="browser-multiplayer__button browser-multiplayer__button--host" data-browser-multiplayer-action="create" type="button">Create game</button>
          <button class="browser-multiplayer__button browser-multiplayer__button--client" data-browser-multiplayer-action="join" type="button">Join game</button>
        </div>

        <div class="browser-multiplayer__flow" data-browser-multiplayer-panel="host" hidden>
          <h2>Create game</h2>
          <p>Send this invite to the other player. When they reply, paste their reply below.</p>
          <label>
            Invite code
            <textarea data-browser-multiplayer-offer-output readonly rows="4" spellcheck="false"></textarea>
          </label>
          <div class="browser-multiplayer__actions">
            <button class="browser-multiplayer__button" data-browser-multiplayer-action="share-offer" type="button">Share invite</button>
            <button class="browser-multiplayer__button browser-multiplayer__button--ghost" data-browser-multiplayer-action="copy-offer" type="button">Copy invite</button>
          </div>
          <label>
            Reply code
            <textarea data-browser-multiplayer-answer-input rows="4" spellcheck="false" placeholder="Paste reply here"></textarea>
          </label>
          <button class="browser-multiplayer__button browser-multiplayer__button--primary" data-browser-multiplayer-action="accept-answer" type="button">Start match</button>
        </div>

        <div class="browser-multiplayer__flow" data-browser-multiplayer-panel="client" hidden>
          <h2>Join game</h2>
          <p>Paste the invite from the host. Send the generated reply back to them.</p>
          <label>
            Invite code
            <textarea data-browser-multiplayer-offer-input rows="4" spellcheck="false" placeholder="Paste invite here"></textarea>
          </label>
          <button class="browser-multiplayer__button browser-multiplayer__button--primary" data-browser-multiplayer-action="create-answer" type="button">Create reply</button>
          <label>
            Reply code
            <textarea data-browser-multiplayer-answer-output readonly rows="4" spellcheck="false"></textarea>
          </label>
          <div class="browser-multiplayer__actions">
            <button class="browser-multiplayer__button" data-browser-multiplayer-action="share-answer" type="button">Share reply</button>
            <button class="browser-multiplayer__button browser-multiplayer__button--ghost" data-browser-multiplayer-action="copy-answer" type="button">Copy reply</button>
          </div>
        </div>
      </section>

      <section class="browser-multiplayer__panel browser-multiplayer__panel--connected" data-browser-multiplayer-panel="connected" hidden>
        <p>Connection is live. Missing the puck gives the point away. Leaving the page forfeits the match.</p>
        <div class="browser-multiplayer__actions">
          <button class="browser-multiplayer__button browser-multiplayer__button--primary" data-browser-multiplayer-action="rematch" type="button" hidden>Rematch</button>
          <button class="browser-multiplayer__button browser-multiplayer__button--ghost" data-browser-multiplayer-action="reset" type="button">New connection</button>
        </div>
      </section>
    </div>
  </section>

  <script>
    import { initBrowserMultiplayer } from "../../../utils/experiments/browser-multiplayer/controller";

    const pageClass = "browser-multiplayer-page";
    document.body.classList.add(pageClass);
    document.addEventListener(
      "astro:before-preparation",
      () => {
        // Keep the page-specific body class scoped to this route across Astro view transitions.
        document.body.classList.remove(pageClass);
      },
      { once: true },
    );

    initBrowserMultiplayer();
  </script>
</Layout>

<style lang="scss">
  @use "../../../styles/variables" as *;
  @use "../../../styles/mixins" as *;

  .browser-multiplayer {
    position: relative;
    min-height: 100dvh;
    overflow: hidden;
    padding: calc($header-height + env(safe-area-inset-top) + $space-md) $space-md calc($space-xl + env(safe-area-inset-bottom));
    background:
      radial-gradient(circle at 12% 12%, rgba($color-orange, 0.16), transparent 26rem), radial-gradient(circle at 88% 18%, rgba($color-blue, 0.14), transparent 22rem),
      linear-gradient(180deg, #f7f1e8 0%, #e6ded4 100%);
    color: $color-text-dark;

    &__back {
      @include focus-ring;
      position: fixed;
      z-index: 50;
      top: calc($space-sm + env(safe-area-inset-top));
      left: $space-sm;
      display: inline-flex;
      align-items: center;
      gap: $space-xs;
      border: 2px solid rgba($color-black, 0.12);
      border-radius: $radius-full;
      padding: 0.55rem 0.9rem;
      background: rgba($color-white, 0.82);
      color: $color-text-dark;
      font: inherit;
      font-weight: $font-weight-bold;
      box-shadow: $shadow-sm;
      backdrop-filter: blur(12px);
      cursor: pointer;
    }

    &__shell {
      width: min(100%, 450px);
      margin-inline: auto;
      display: flex;
      flex-direction: column;
      gap: $space-md;
    }

    &__header {
      text-align: center;
    }

    &__eyebrow {
      margin: 0 0 $space-xs;
      color: rgba($color-text-dark, 0.62);
      font-size: $font-size-xs;
      font-weight: $font-weight-bold;
      letter-spacing: $tracking-widest;
      text-transform: uppercase;
    }

    &__title {
      margin: 0;
      color: #111;
      font-size: clamp(2.25rem, 12vw, 4.5rem);
      line-height: $leading-none;
      letter-spacing: $tracking-tight;
      text-transform: uppercase;
    }

    &__intro {
      max-width: 35ch;
      margin: $space-sm auto 0;
      color: rgba($color-text-dark, 0.72);
      font-size: $font-size-sm;
      line-height: $leading-relaxed;
    }

    &__scoreboard {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: $space-sm;
    }

    &__score-card {
      border: 2px solid #111;
      border-radius: $radius-xl;
      padding: $space-sm $space-md;
      background: rgba($color-white, 0.78);
      box-shadow: $shadow-sm;

      &--host {
        border-color: #e94545;
      }

      &--client {
        border-color: #2b65e8;
      }
    }

    &__score-label {
      display: block;
      font-size: $font-size-xs;
      font-weight: $font-weight-bold;
      letter-spacing: $tracking-wider;
      text-transform: uppercase;
    }

    &__score-value {
      display: block;
      font-size: clamp(2rem, 12vw, 4rem);
      line-height: $leading-none;
    }

    &__versus {
      color: rgba($color-text-dark, 0.46);
      font-size: $font-size-xs;
      font-weight: $font-weight-black;
      letter-spacing: $tracking-widest;
      text-transform: uppercase;
    }

    &__status,
    &__role {
      margin: 0;
      border: 1px solid rgba($color-black, 0.1);
      border-radius: $radius-full;
      padding: $space-sm $space-md;
      background: rgba($color-white, 0.72);
      color: rgba($color-text-dark, 0.74);
      text-align: center;
      font-size: $font-size-sm;
      font-weight: $font-weight-semibold;
      box-shadow: $shadow-xs;
    }

    &__card {
      position: relative;
      border: 4px solid #111;
      border-radius: 34px;
      padding: 10px;
      background: #111;
      box-shadow: 0 28px 60px rgba($color-black, 0.22);
    }

    &__stage-wrap {
      position: relative;
      aspect-ratio: 10 / 18;
      overflow: hidden;
      border-radius: 24px;
      background: #fffbf3;
      isolation: isolate;
    }

    &__stage {
      position: absolute;
      inset: 0;

      :global(canvas) {
        display: block;
        width: 100% !important;
        height: 100% !important;
      }
    }

    &__overlay {
      position: absolute;
      inset: 0;
      z-index: 4;
      display: grid;
      place-items: center;
      color: #111;
      font-size: clamp(3rem, 20vw, 7rem);
      font-weight: $font-weight-black;
      letter-spacing: $tracking-tight;
      text-align: center;
      text-transform: uppercase;
      text-shadow: 0 4px 0 rgba($color-white, 0.72);
      pointer-events: none;

      &[hidden] {
        display: none;
      }
    }

    &__touch-zone {
      position: absolute;
      inset-inline: 0;
      bottom: 0;
      z-index: 5;
      height: 25%;
      display: flex;
      align-items: flex-end;
      justify-content: center;
      padding-bottom: $space-md;
      color: rgba($color-text-dark, 0.34);
      font-size: $font-size-xs;
      font-weight: $font-weight-black;
      letter-spacing: $tracking-widest;
      text-transform: uppercase;
      touch-action: none;
      user-select: none;
    }

    &__panel {
      border: 1px solid rgba($color-black, 0.12);
      border-radius: $radius-2xl;
      padding: $space-md;
      background: rgba($color-white, 0.82);
      box-shadow: $shadow-md;
      backdrop-filter: blur(14px);

      &[hidden] {
        display: none;
      }

      &--connected {
        text-align: center;
      }
    }

    &__choice,
    &__actions {
      display: flex;
      flex-wrap: wrap;
      gap: $space-sm;
    }

    &__choice {
      display: grid;
      grid-template-columns: 1fr 1fr;
    }

    &__flow {
      display: grid;
      gap: $space-md;

      &[hidden] {
        display: none;
      }

      h2,
      p {
        margin: 0;
      }

      h2 {
        font-size: $font-size-xl;
      }

      p {
        color: rgba($color-text-dark, 0.68);
        font-size: $font-size-sm;
        line-height: $leading-relaxed;
      }

      label {
        display: grid;
        gap: $space-xs;
        font-size: $font-size-xs;
        font-weight: $font-weight-bold;
        letter-spacing: $tracking-wider;
        text-transform: uppercase;
      }

      textarea {
        @include focus-ring;
        width: 100%;
        min-height: 5.5rem;
        resize: vertical;
        border: 2px solid rgba($color-black, 0.14);
        border-radius: $radius-lg;
        padding: $space-sm;
        background: rgba($color-white, 0.88);
        color: $color-text-dark;
        font-family: $font-mono;
        font-size: $font-size-xs;
        line-height: $leading-relaxed;
      }
    }

    &__button {
      @include focus-ring;
      min-height: 2.8rem;
      flex: 1 1 auto;
      border: 2px solid #111;
      border-radius: $radius-full;
      padding: 0.8rem 1rem;
      background: #fffaf0;
      color: #111;
      font: inherit;
      font-size: $font-size-sm;
      font-weight: $font-weight-black;
      letter-spacing: $tracking-wide;
      text-transform: uppercase;
      box-shadow: 0 4px 0 #111;
      cursor: pointer;
      transition:
        transform 140ms ease,
        box-shadow 140ms ease;

      &:hover:not(:disabled) {
        transform: translateY(-2px);
        box-shadow: 0 6px 0 #111;
      }

      &:active:not(:disabled) {
        transform: translateY(2px);
        box-shadow: 0 2px 0 #111;
      }

      &:disabled {
        opacity: 0.54;
        cursor: wait;
      }

      &--host,
      &--primary {
        background: #e94545;
        color: $color-white;
      }

      &--client {
        background: #2b65e8;
        color: $color-white;
      }

      &--ghost {
        background: rgba($color-white, 0.72);
      }
    }

    @include respond-to(sm) {
      padding-inline: $space-sm;

      &__shell {
        gap: $space-sm;
      }

      &__intro {
        display: none;
      }

      &__panel {
        padding: $space-sm;
      }
    }
  }
</style>
