        document.getElementById("add-task-btn")!.addEventListener("click", () => {
          (document.getElementById("task-title-input") as HTMLInputElement).value = "";
          (document.getElementById("task-type-input") as HTMLSelectElement).value = "short";
          (document.getElementById("task-modal-title") as HTMLElement).textContent = "Add Task";
          (document.getElementById("task-form-submit") as HTMLElement).textContent = "Add Task";
          openModal("task-modal");
        });

        document.getElementById("demo-data-btn")!.addEventListener("click", () => {
          loadDemoTasks();
        });

        document.addEventListener("tracker-board-add-task", (event) => {
          const addEvent = event as CustomEvent<{ type: TaskType }>;
          const type = addEvent.detail?.type;
          if (type !== "short" && type !== "medium" && type !== "long") return;

          (document.getElementById("task-title-input") as HTMLInputElement).value = "";
          (document.getElementById("task-type-input") as HTMLSelectElement).value = type;
          (document.getElementById("task-modal-title") as HTMLElement).textContent = "Add Task";
          (document.getElementById("task-form-submit") as HTMLElement).textContent = "Add Task";
          openModal("task-modal");
        });

        // Modal close buttons
        ["task-modal-close", "task-modal-cancel"].forEach((id) => {
          document.getElementById(id)!.addEventListener("click", () => closeModal("task-modal"));
        });
        ["export-modal-close", "export-modal-close2"].forEach((id) => {
          document.getElementById(id)!.addEventListener("click", () => closeModal("export-modal"));
        });
        ["import-modal-close", "import-modal-cancel"].forEach((id) => {
          document.getElementById(id)!.addEventListener("click", () => closeModal("import-modal"));
        });

        // Close on overlay click
        document.querySelectorAll(".modal-overlay").forEach((overlay) => {
          overlay.addEventListener("click", (e) => {
            if (e.target === overlay) {
              overlay.setAttribute("hidden", "");
            }
          });
        });

        // Close on Escape
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") {
            document.querySelectorAll(".modal-overlay:not([hidden])").forEach((m) => m.setAttribute("hidden", ""));
          }
        });

        // Task form submit
        document.getElementById("task-form")!.addEventListener("submit", (e) => {
          e.preventDefault();
          const title = (document.getElementById("task-title-input") as HTMLInputElement).value;
          const type = (document.getElementById("task-type-input") as HTMLSelectElement).value as TaskType;

          if (!title.trim()) return;

          addTask(title, type);
          showToast({ type: "success", icon: "+", title: "Task added", text: `"${title}" added to your ${type === "short" ? "weekly" : type === "medium" ? "monthly" : "quarterly"} tasks.` });
          closeModal("task-modal");
          renderAll();
        });

        // Export
        document.getElementById("export-btn")!.addEventListener("click", () => {
          const code = encodeState(state);
          (document.getElementById("export-code") as HTMLTextAreaElement).value = code;
          openModal("export-modal");
        });

        document.getElementById("copy-code-btn")!.addEventListener("click", () => {
          const code = (document.getElementById("export-code") as HTMLTextAreaElement).value;
          navigator.clipboard.writeText(code).then(() => {
            showToast({ type: "success", icon: "✓", title: "Copied", text: "Paste this on another device to sync." });
          });
        });

        document.getElementById("copy-url-btn")!.addEventListener("click", () => {
          syncShareUrl(state, false);
          const url = window.location.href;
          navigator.clipboard.writeText(url).then(() => {
            showToast({ type: "success", icon: "✓", title: "URL copied", text: "Open this URL on another device to import." });
          });
        });

        // Import
        document.getElementById("import-btn")!.addEventListener("click", () => {
          (document.getElementById("import-code") as HTMLTextAreaElement).value = "";
          openModal("import-modal");
        });

        document.getElementById("do-import-btn")!.addEventListener("click", () => {
          const code = (document.getElementById("import-code") as HTMLTextAreaElement).value.trim();
          if (!code) return;
          const imported = decodeState(code);
          if (!imported) {
            showToast({ type: "info", icon: "!", title: "Invalid import code", text: "Please check the code and try again." });
            return;
          }
          state = mergeStates(state, imported);
          saveState(state);
          closeModal("import-modal");
          renderAll();
          showToast({ type: "success", icon: "✓", title: "Data imported", text: "Your tasks have been merged." });
        });

        // ===========================================================
        // Tip rotation
        // ===========================================================

        function showRandomTip(): void {
          const tip = TIPS[Math.floor(Math.random() * TIPS.length)];
          document.getElementById("tip-text")!.textContent = tip;
        }

        // ===========================================================
        // Decay re-render (periodic)
        // ===========================================================

        // Re-render tasks every 10 minutes to refresh decay states
        setInterval(() => {
          renderBoard();
        }, 600_000);

        // ===========================================================
        // Init
        // ===========================================================

        showRandomTip();
        syncShareUrl(state, false);
        renderAll();

        if (pendingImportError) {
          showToast({ type: "info", icon: "!", title: "Import warning", text: pendingImportError, duration: 5000 });
        }

        // Show a welcome tip after a brief delay if first visit
        setTimeout(() => {
          const visited = localStorage.getItem("tracker_visited");
          if (!visited) {
            showToast({
              type: "info",
              icon: "i",
              title: "Welcome to your tracker",
              text: "Add your first task to earn XP and start levelling up!",
              duration: 6000,
            });
            localStorage.setItem("tracker_visited", "1");
          }
        }, 500);
      </script>
