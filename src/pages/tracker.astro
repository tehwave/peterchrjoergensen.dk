                archivedAt: null,
                order: 0,
              },
              {
                id: crypto.randomUUID(),
                title: "Complete analytics migration",
                description: "",
                type: "long",
                createdAt: now - 86 * day,
                dueDate: null,
                completedAt: now - 63 * day,
                archivedAt: null,
                order: 0,
              },
              {
                id: crypto.randomUUID(),
                title: "Rework project filtering UX",
                description: "",
                type: "long",
                createdAt: now - 80 * day,
                dueDate: null,
                completedAt: now - 55 * day,
                archivedAt: null,
                order: 0,
              },
              {
                id: crypto.randomUUID(),
                title: "Ship blog structured data update",
                description: "",
                type: "long",
                createdAt: now - 75 * day,
                dueDate: null,
                completedAt: now - 48 * day,
                archivedAt: null,
                order: 0,
              },
              {
                id: crypto.randomUUID(),
                title: "Finish Q1 optimization pass",
                description: "",
                type: "long",
                createdAt: now - 68 * day,
                dueDate: null,
                completedAt: now - 39 * day,
                archivedAt: null,
                order: 0,
              },
            ],
            game: {
              level: 4,
              xp: 120,
              totalXP: 720,
              completedThisMonth: 6,
              completedThisYear: 17,
              streak: 5,
              lastActivityDate: localDateKey(today),
              monthKey,
              yearKey,
            },
            version: 1,
          };

          void saveState(state);
          renderAll();
          showToast({ type: "success", icon: "✓", title: "Demo data loaded", text: "Sample tasks added for testing." });
        }

        /** Completes a task, updates game progress, grants XP, and re-renders. */
        function completeTask(id: string): void {
          const task = state.tasks.find((t) => t.id === id);
          if (!task || task.completedAt) return;
          task.completedAt = Date.now();
          task.archivedAt = null;

          recordActivity();
          state.game.completedThisMonth++;
          state.game.completedThisYear++;

          gainXP(XP_VALUES[task.type]);
          void saveState(state);
          renderAll();
        }

        /** Reopens a completed task and rolls back linked progression rewards. */
        function uncompleteTask(id: string): boolean {
          const task = state.tasks.find((t) => t.id === id);
          if (!task || task.completedAt === null) return false;

          task.completedAt = null;
          task.archivedAt = null;

          state.game.completedThisMonth = Math.max(0, state.game.completedThisMonth - 1);
          state.game.completedThisYear = Math.max(0, state.game.completedThisYear - 1);
          loseXP(XP_VALUES[task.type]);

          normalizeOrders(task.type);
          void saveState(state);
          renderAll();
          return true;
        }

        /** Permanently deletes a task regardless of completion state. */
        function deleteTask(id: string): void {
          state.tasks = state.tasks.filter((t) => t.id !== id);
          void saveState(state);
          renderAll();
        }

        /** Marks a completed task as archived (hidden from default completed view). */
        function archiveCompletedTask(id: string): void {
          const task = state.tasks.find((t) => t.id === id);
          if (!task || task.completedAt === null || task.archivedAt !== null) return;
          task.archivedAt = Date.now();
          void saveState(state);
          renderAll();
        }

        /** Archives all visible completed tasks and returns affected count. */
        function archiveAllCompleted(): number {
          let archivedCount = 0;
          const archivedAt = Date.now();
          state.tasks.forEach((task) => {
            if (task.completedAt !== null && task.archivedAt === null) {
              task.archivedAt = archivedAt;
              archivedCount++;
            }
          });

          if (archivedCount > 0) {
            void saveState(state);
            renderAll();
          }

          return archivedCount;
        }

        /** Restores all archived completed tasks and returns affected count. */
        function restoreAllArchived(): number {
          let restoredCount = 0;
          state.tasks.forEach((task) => {
            if (task.completedAt !== null && task.archivedAt !== null) {
              task.archivedAt = null;
              restoredCount++;
            }
          });

          if (restoredCount > 0) {
            void saveState(state);
            renderAll();
          }

          return restoredCount;
        }

        /** Permanently removes archived-completed tasks from history and returns count. */
        function clearArchivedHistory(): number {
          const previousCount = state.tasks.length;
          state.tasks = state.tasks.filter((task) => !(task.completedAt !== null && task.archivedAt !== null));
          const clearedCount = previousCount - state.tasks.length;

          if (clearedCount > 0) {
            void saveState(state);
            renderAll();
          }

          return clearedCount;
        }

        /** Updates task title inline and persists immediately. */
        function editTask(id: string, title: string): void {
          const task = state.tasks.find((t) => t.id === id);
          if (!task) return;
          task.title = title.trim();
          void saveState(state);
          renderAll();
        }

        // ===========================================================
        // Drag & Drop
        // ===========================================================

        /** Re-normalizes active task order indices within a single board column. */
        function normalizeOrders(type: TaskType): void {
          state.tasks
            .filter((t) => t.type === type && !t.completedAt)
            .sort((a, b) => a.order - b.order)
            .forEach((task, index) => {
              task.order = index;
            });
        }

        /**
         * Canonical drop handler for pointer and keyboard move intents.
         * Supports insert-before/after specific cards or append-to-end placement.
         */
        function handleDrop(targetType: TaskType, dropTaskId: string | null, dropPosition: "before" | "after" | "end" = "end", draggedIdOverride: string | null = null): void {
          const activeDraggedTaskId = draggedIdOverride ?? draggedTaskId;
          if (!activeDraggedTaskId) return;
          const task = state.tasks.find((t) => t.id === activeDraggedTaskId);
          if (!task) return;
          const sourceType = task.type;
          const movedTaskId = task.id;

          if (dropTaskId && dropTaskId !== activeDraggedTaskId) {
            const targetTask = state.tasks.find((t) => t.id === dropTaskId);
            if (targetTask) {
              task.type = targetType;
              // Insert around target task using fractional order, then normalize immediately below.
              task.order = dropPosition === "after" ? targetTask.order + 0.5 : targetTask.order - 0.5;
            }
          } else {
            // Drop at end of section
            task.type = targetType;
            const maxOrder = state.tasks.filter((t) => t.type === targetType && !t.completedAt && t.id !== activeDraggedTaskId).reduce((m, t) => Math.max(m, t.order), -1);
            task.order = maxOrder + 1;
          }

          normalizeOrders(sourceType);
          normalizeOrders(targetType);
          renderBoard();
          setTimeout(() => {
            void saveState(state, false);
          }, 0);
          requestAnimationFrame(() => {
            const movedCard = document.querySelector<HTMLElement>(`.task-card[data-id="${CSS.escape(movedTaskId)}"]`);
            if (!movedCard) return;
            movedCard.classList.remove("task-card--landed");
            void movedCard.offsetWidth;
            movedCard.classList.add("task-card--landed");
            setTimeout(() => movedCard.classList.remove("task-card--landed"), 500);
          });
          showToast({ type: "info", icon: "i", title: "Task moved", text: `Moved to ${targetType === "short" ? "weekly" : targetType === "medium" ? "monthly" : "quarterly"} section.` });
        }

        /** Keyboard-first move helper; translates directional intent into `handleDrop(...)`. */
        function moveTaskByDirection(id: string, direction: "left" | "right" | "up" | "down"): void {
          const task = state.tasks.find((t) => t.id === id && t.completedAt === null);
          if (!task) return;

          const columnOrder: TaskType[] = ["short", "medium", "long"];
          const currentColumnIndex = columnOrder.indexOf(task.type);
          if (currentColumnIndex < 0) return;

          if (direction === "left" || direction === "right") {
            const nextColumnIndex = direction === "left" ? currentColumnIndex - 1 : currentColumnIndex + 1;
            if (nextColumnIndex < 0 || nextColumnIndex >= columnOrder.length) return;

            draggedTaskId = id;
            handleDrop(columnOrder[nextColumnIndex], null, "end");
            draggedTaskId = null;
            return;
          }

          const sameColumn = state.tasks.filter((t) => t.type === task.type && t.completedAt === null).sort((a, b) => a.order - b.order);

          const index = sameColumn.findIndex((t) => t.id === id);
          if (index < 0) return;

          const delta = direction === "up" ? -1 : 1;
          const targetIndex = index + delta;
          if (targetIndex < 0 || targetIndex >= sameColumn.length) return;

          const targetTask = sameColumn[targetIndex];
          draggedTaskId = id;
          handleDrop(task.type, targetTask.id, direction === "up" ? "before" : "after");
          draggedTaskId = null;
        }

        // ===========================================================
        // Modal helpers
        // ===========================================================

        /** Opens a modal overlay and focuses first interactive control. */
        function openModal(id: string): void {
          const modal = document.getElementById(id)!;
          modal.removeAttribute("hidden");
          // Focus first focusable element
          setTimeout(() => {
            const first = modal.querySelector<HTMLElement>("input, select, textarea, button:not(.modal__close)");
            first?.focus();
          }, 50);
        }

        /** Closes a modal overlay by restoring the `hidden` attribute. */
        function closeModal(id: string): void {
          document.getElementById(id)!.setAttribute("hidden", "");
        }

        // ===========================================================
        // Event wiring
        // ===========================================================
        // Notes:
        // - Board/task/completed components emit semantic intent events.
        // - This file remains the canonical mutation + persistence owner.
        // - Event handlers are intentionally explicit to keep contracts discoverable.

        document.addEventListener("tracker-task-dragstart", (event) => {
          const dragEvent = event as CustomEvent<{ id: string }>;
          draggedTaskId = dragEvent.detail?.id ?? null;
        });

        document.addEventListener("tracker-task-dragend", () => {
          draggedTaskId = null;
        });

        document.addEventListener("tracker-board-drop", (event) => {
          const dropEvent = event as CustomEvent<{ targetType: TaskType; dropTaskId: string | null; dropPosition?: "before" | "after" | "end"; draggedTaskId?: string | null }>;
          const targetType = dropEvent.detail?.targetType;

          if (targetType !== "short" && targetType !== "medium" && targetType !== "long") return;
          handleDrop(targetType, dropEvent.detail?.dropTaskId ?? null, dropEvent.detail?.dropPosition ?? "end", dropEvent.detail?.draggedTaskId ?? null);
        });

        document.addEventListener("tracker-task-move", (event) => {
          const moveEvent = event as CustomEvent<{ id: string; direction: "left" | "right" | "up" | "down" }>;
          const id = moveEvent.detail?.id;
          const direction = moveEvent.detail?.direction;
          if (!id || !direction) return;
          moveTaskByDirection(id, direction);
        });

        document.addEventListener("tracker-task-complete", (event) => {
          const completeEvent = event as CustomEvent<{ id: string }>;
          const id = completeEvent.detail?.id;
          if (!id) return;
          completeTask(id);
        });

        document.addEventListener("tracker-task-delete", (event) => {
          const deleteEvent = event as CustomEvent<{ id: string }>;
          const id = deleteEvent.detail?.id;
          if (!id) return;
          if (confirm("Delete this task?")) {
            deleteTask(id);
          }
        });

        document.addEventListener("tracker-task-titlechange", (event) => {
          const renameEvent = event as CustomEvent<{ id: string; title: string }>;
          const id = renameEvent.detail?.id;
          const title = renameEvent.detail?.title;
          if (!id || !title?.trim()) return;
          editTask(id, title);
          showToast({ type: "info", icon: "i", title: "Task renamed", text: "" });
        });

        document.addEventListener("tracker-completed-task-archive", (event) => {
          const archiveEvent = event as CustomEvent<{ id: string }>;
          const id = archiveEvent.detail?.id;
          if (!id) return;
          archiveCompletedTask(id);
          showToast({ type: "info", icon: "i", title: "Archived", text: "Completed task moved to archived history." });
        });

        document.addEventListener("tracker-completed-task-uncomplete", (event) => {
          const uncompleteEvent = event as CustomEvent<{ id: string }>;
          const id = uncompleteEvent.detail?.id;
          if (!id) return;

          const wasUncompleted = uncompleteTask(id);
          if (!wasUncompleted) return;

          showToast({ type: "success", icon: "↺", title: "Task reopened", text: "Task moved back to active and rewards were rolled back." });
        });

        document.addEventListener("tracker-completed-archive-all", () => {
          const archivedCount = archiveAllCompleted();
          if (archivedCount === 0) {
            showToast({ type: "info", icon: "i", title: "Nothing to archive", text: "No visible completed tasks to archive." });
            return;
          }

          showToast({ type: "info", icon: "i", title: "Archived", text: `${archivedCount} completed ${archivedCount === 1 ? "task" : "tasks"} archived.` });
        });

        document.addEventListener("tracker-completed-restore-all", () => {
          const restoredCount = restoreAllArchived();
          if (restoredCount === 0) {
            showToast({ type: "info", icon: "i", title: "Nothing to restore", text: "There are no archived tasks." });
            return;
          }

          showToast({ type: "success", icon: "↺", title: "Restored", text: `${restoredCount} archived ${restoredCount === 1 ? "task" : "tasks"} restored.` });
        });

        document.addEventListener("tracker-completed-clear-history", () => {
          if (!confirm("Clear archived history? This permanently removes archived completed tasks.")) return;

          const clearedCount = clearArchivedHistory();
          if (clearedCount === 0) {
            showToast({ type: "info", icon: "i", title: "Nothing to clear", text: "No archived tasks found in history." });
            return;
          }

          showToast({ type: "info", icon: "i", title: "History cleared", text: `${clearedCount} archived ${clearedCount === 1 ? "task" : "tasks"} removed permanently.` });
        });

        // Header toolbar actions
        document.getElementById("add-task-btn")!.addEventListener("click", () => {
          (document.getElementById("task-title-input") as HTMLInputElement).value = "";
          (document.getElementById("task-type-input") as HTMLSelectElement).value = "short";
          (document.getElementById("task-modal-title") as HTMLElement).textContent = "Add Task";
          (document.getElementById("task-form-submit") as HTMLElement).textContent = "Add Task";
          openModal("task-modal");
        });

        document.getElementById("demo-data-btn")!.addEventListener("click", () => {
          loadDemoTasks();
        });

        document.addEventListener("tracker-board-add-task", (event) => {
          const addEvent = event as CustomEvent<{ type: TaskType }>;
          const type = addEvent.detail?.type;
          if (type !== "short" && type !== "medium" && type !== "long") return;

          (document.getElementById("task-title-input") as HTMLInputElement).value = "";
          (document.getElementById("task-type-input") as HTMLSelectElement).value = type;
          (document.getElementById("task-modal-title") as HTMLElement).textContent = "Add Task";
          (document.getElementById("task-form-submit") as HTMLElement).textContent = "Add Task";
          openModal("task-modal");
        });

        // Modal close controls
        ["task-modal-close", "task-modal-cancel"].forEach((id) => {
          document.getElementById(id)!.addEventListener("click", () => closeModal("task-modal"));
        });
        ["export-modal-close", "export-modal-close2"].forEach((id) => {
          document.getElementById(id)!.addEventListener("click", () => closeModal("export-modal"));
        });
        ["import-modal-close", "import-modal-cancel"].forEach((id) => {
          document.getElementById(id)!.addEventListener("click", () => closeModal("import-modal"));
        });

        // Overlay interaction: close when clicking backdrop (not modal content)
        document.querySelectorAll(".modal-overlay").forEach((overlay) => {
          overlay.addEventListener("click", (e) => {
            if (e.target === overlay) {
              overlay.setAttribute("hidden", "");
            }
          });
        });

        // Escape closes all currently open modal overlays
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") {
            document.querySelectorAll(".modal-overlay:not([hidden])").forEach((m) => m.setAttribute("hidden", ""));
          }
        });

        // Add-task form submission
        document.getElementById("task-form")!.addEventListener("submit", (e) => {
          e.preventDefault();
          const title = (document.getElementById("task-title-input") as HTMLInputElement).value;
          const type = (document.getElementById("task-type-input") as HTMLSelectElement).value as TaskType;

          if (!title.trim()) return;

          addTask(title, type);
          showToast({ type: "success", icon: "+", title: "Task added", text: `"${title}" added to your ${type === "short" ? "weekly" : type === "medium" ? "monthly" : "quarterly"} tasks.` });
          closeModal("task-modal");
          renderAll();
        });

        // Export flows (raw token + full URL)
        document.getElementById("export-btn")!.addEventListener("click", async () => {
          const code = await encodeState(state);
          (document.getElementById("export-code") as HTMLTextAreaElement).value = code;
          openModal("export-modal");
        });

        document.getElementById("copy-code-btn")!.addEventListener("click", () => {
          const code = (document.getElementById("export-code") as HTMLTextAreaElement).value;
          navigator.clipboard.writeText(code).then(() => {
            showToast({ type: "success", icon: "✓", title: "Copied", text: "Paste this on another device to sync." });
          });
        });

        document.getElementById("copy-url-btn")!.addEventListener("click", async () => {
          await syncShareUrl(state, false);
          const url = window.location.href;
          navigator.clipboard.writeText(url).then(() => {
            showToast({ type: "success", icon: "✓", title: "URL copied", text: "Open this URL on another device to import." });
          });
        });

        // Import flow (merge imported payload into local state)
        document.getElementById("import-btn")!.addEventListener("click", () => {
          (document.getElementById("import-code") as HTMLTextAreaElement).value = "";
          openModal("import-modal");
        });

        document.getElementById("do-import-btn")!.addEventListener("click", async () => {
          const code = (document.getElementById("import-code") as HTMLTextAreaElement).value.trim();
          if (!code) return;
          const imported = await decodeState(code);
          if (!imported) {
            showToast({ type: "info", icon: "!", title: "Invalid import code", text: "Please check the code and try again." });
            return;
          }
          state = mergeStates(state, imported);
          await saveState(state);
          closeModal("import-modal");
          renderAll();
          showToast({ type: "success", icon: "✓", title: "Data imported", text: "Your tasks have been merged." });
        });

        // ===========================================================
        // Tip rotation
        // ===========================================================

        /** Chooses a random motivational tip for the subtitle row. */
        function showRandomTip(): void {
          const tip = TIPS[Math.floor(Math.random() * TIPS.length)];
          document.getElementById("tip-text")!.textContent = tip;
        }

        // ===========================================================
        // Decay re-render (periodic)
        // ===========================================================

        // Re-render tasks every 10 minutes to refresh decay states
        setInterval(() => {
          renderBoard();
        }, 600_000);

        // ===========================================================
        // Init
        // ===========================================================

        /** App bootstrap: load state, sync hash, render UI, and surface import warnings. */
        async function bootstrap(): Promise<void> {
          state = await loadState();
          showRandomTip();
          await syncShareUrl(state, false);
          renderAll();

          if (pendingImportError) {
            showToast({ type: "info", icon: "!", title: "Import warning", text: pendingImportError, duration: 5000 });
          }
        }

        void bootstrap();

        // Show a welcome tip after a brief delay if first visit
        setTimeout(() => {
          const visited = localStorage.getItem("tracker_visited");
          if (!visited) {
            showToast({
              type: "info",
              icon: "i",
              title: "Welcome to your tracker",
              text: "Add your first task to earn XP and start levelling up!",
              duration: 6000,
            });
            localStorage.setItem("tracker_visited", "1");
          }
        }, 500);
      </script>
    </main>

    <Toast />
  </body>
