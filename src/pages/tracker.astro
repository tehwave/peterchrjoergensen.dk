---
/**
 * Productivity Tracker & Kanban Board
 *
 * A single-page productivity app with:
 * - Three task sections: Short-term (weekly), Medium-term (monthly), Long-term (quarterly)
 * - LocalStorage persistence + compact-json + gzip + base64url export/import for cross-device sync
 * - Visual decay for overdue tasks with stink particles
 * - Drag-and-drop reordering within and between sections
 * - Statistics and positive reinforcement toasts
 */
import "../styles/global.scss";

import { Font } from "astro:assets";
import { getImage } from "astro:assets";
import CompletedTasks from "../components/tracker/CompletedTasks.astro";
import Board from "../components/tracker/Board.astro";
import Footer from "../components/Footer.astro";
import Statistics from "../components/tracker/Statistics.astro";
import Toast from "../components/tracker/Toast.astro";

// Texture images for the background, generated at build time using Astro's Assets API.
import textureSource from "../assets/black-paper.png";
const textureAVIF = await getImage({ src: textureSource, format: "avif" });
const textureWebP = await getImage({ src: textureSource, format: "webp" });
const textureFallback = await getImage({ src: textureSource, format: "png" });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Productivity Tracker — Peter Chr. Jørgensen</title>
    <meta name="description" content="Personal productivity tracker and kanban board with gamification, visual task decay, and cross-device sync." />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />

    <!-- Resource Hints -->
    <link rel="preconnect" href="https://cdn.usefathom.com" />
    <link rel="preconnect" href="https://analytics.ahrefs.com" />

    <!-- Font preload links (generated by Astro Fonts API) -->
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-caveat" preload />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <!-- Fathom - beautiful, simple website analytics -->
    <script is:inline src="https://cdn.usefathom.com/script.js" data-site="OXXUABJE" defer></script>
    <!-- / Fathom -->

    <!-- Ahrefs Analytics -->
    <script is:inline src="https://analytics.ahrefs.com/analytics.js" data-key="PQ2PVfAM4xEKb65ihHICUQ" defer></script>
    <!-- / Ahrefs Analytics -->
  </head>
  <body
    class="tracker-layout"
    style={{
      "--texture-avif": `url(${textureAVIF.src})`,
      "--texture-webp": `url(${textureWebP.src})`,
      "--texture-fallback": `url(${textureFallback.src})`,
    }}
  >
    <!-- 
      Skip Link - WCAG 2.4.1 Bypass Blocks (Level A)
      Allows keyboard users to skip navigation and jump directly to main content.
      Hidden off-screen by default, slides into view when focused via Tab key.
      Links to #main-content in Hero component.
    -->
    <style lang="scss">
      @use "../styles/variables" as *;

      /* Skip link styles - positioned off-screen until focused */
      .skip-link {
        position: absolute;
        top: -100px; /* Hidden above viewport */
        left: 0;
        background: $color-orange;
        color: $color-white;
        padding: 8px 16px;
        text-decoration: none;
        font-weight: 600;
        z-index: 10000;
        border-radius: 0 0 4px 0;
      }

      /* Slide into view when keyboard user presses Tab */
      .skip-link:focus {
        top: 0;
      }
    </style>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <main>
      <div class="tracker">
        <!-- ====================================================
         ABOVE THE FOLD: Stats + Task Board
         ==================================================== -->

        <!-- Stats Bar -->
        <header class="tracker__header">
          <div class="tracker__title-row">
            <div>
              <h1 class="tracker__title">Your Productivity Tracker</h1>
              <p class="tracker__subtitle" id="tip-text">Loading tip…</p>
            </div>
            <div class="tracker__toolbar">
              <button class="btn btn--primary" id="add-task-btn" aria-label="Add new task">
                <span aria-hidden="true">＋</span> Add Task
              </button>
              <button class="btn btn--secondary" id="demo-data-btn" aria-label="Load demo tasks">Load Demo</button>
              <button class="btn btn--secondary" id="export-btn" aria-label="Export data">Export</button>
              <button class="btn btn--secondary" id="import-btn" aria-label="Import data">Import</button>
            </div>
          </div>

          <div class="stats-bar">
            <!-- Level & XP -->
            <div class="stat-card stat-card--level" id="level-card">
              <div class="level-badge" id="level-badge">
                <span class="level-badge__label">Level</span>
                <span class="level-badge__number" id="level-number">1</span>
              </div>
              <div class="xp-area">
                <div class="xp-bar" role="progressbar" aria-label="XP progress" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                  <div class="xp-bar__fill" id="xp-bar-fill" style="width: 0%"></div>
                  <div class="xp-bar__shimmer"></div>
                </div>
                <div class="xp-text" id="xp-text">0 / 100 XP</div>
              </div>
              <div class="total-xp" id="total-xp">0 XP total</div>
            </div>

            <!-- Monthly stat -->
            <div class="stat-card">
              <span class="stat-card__value" id="stat-month">0</span>
              <span class="stat-card__label">Done this month</span>
              <span class="stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="5" width="18" height="16" rx="2"></rect>
                  <path d="M16 3v4M8 3v4M3 10h18"></path>
                </svg>
              </span>
            </div>

            <!-- Yearly stat -->
            <div class="stat-card">
              <span class="stat-card__value" id="stat-year">0</span>
              <span class="stat-card__label">Done this year</span>
              <span class="stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="8"></circle>
                  <circle cx="12" cy="12" r="4"></circle>
                  <circle cx="12" cy="12" r="1"></circle>
                </svg>
              </span>
            </div>

            <!-- Streak -->
            <div class="stat-card">
              <span class="stat-card__value" id="stat-streak">0</span>
              <span class="stat-card__label">Day streak</span>
              <span class="stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3c.4 2.4-.6 4.1-2.2 5.6C8.2 10 7 11.5 7 13.7 7 17.2 9.7 20 13 20s6-2.8 6-6.3c0-2.4-1.4-4.1-3.4-5.6-.7 2-2.1 3.4-3.6 4.3C12.9 10.6 12.5 7.4 12 3Z"></path>
                </svg>
              </span>
            </div>
          </div>

          <!-- Task Board -->
          <Board />

          <!-- ====================================================
         BELOW THE FOLD: Completed Tasks + Full Stats
         ==================================================== -->

          <div class="below-fold">
            <!-- Completed Tasks -->
            <CompletedTasks />

            <!-- Full Statistics -->
            <Statistics />
          </div>
        </header>
      </div>

      <!-- ====================================================
       MODALS
       ==================================================== -->

      <!-- Add Task Modal -->
      <div class="modal-overlay" id="task-modal" role="dialog" aria-modal="true" aria-labelledby="task-modal-title" hidden>
        <div class="modal">
          <button class="modal__close" id="task-modal-close" aria-label="Close">✕</button>
          <h3 class="modal__title" id="task-modal-title">Add Task</h3>
          <form class="modal__form" id="task-form" novalidate>
            <div class="form-group">
              <label for="task-title-input" class="form-label">Title <span aria-hidden="true">*</span></label>
              <input type="text" id="task-title-input" class="form-input" placeholder="What needs doing?" required maxlength="120" />
            </div>
            <div class="form-group">
              <label for="task-type-input" class="form-label">Timeframe</label>
              <select id="task-type-input" class="form-select">
                <option value="short">This Week (10 XP)</option>
                <option value="medium">This Month (25 XP)</option>
                <option value="long">This Quarter (50 XP)</option>
              </select>
            </div>
            <div class="modal__actions">
              <button type="button" class="btn btn--ghost" id="task-modal-cancel">Cancel</button>
              <button type="submit" class="btn btn--primary" id="task-form-submit">Add Task</button>
            </div>
          </form>
        </div>
      </div>

      <!-- Export Modal -->
      <div class="modal-overlay" id="export-modal" role="dialog" aria-modal="true" aria-labelledby="export-modal-title" hidden>
        <div class="modal">
          <button class="modal__close" id="export-modal-close" aria-label="Close">✕</button>
          <h3 class="modal__title" id="export-modal-title">Export Data</h3>
          <p class="modal__desc">Copy this code to back up or move your data to another device.</p>
          <textarea class="form-textarea form-textarea--code" id="export-code" readonly rows="6" aria-label="Export code"></textarea>
          <div class="modal__actions">
            <button class="btn btn--ghost" id="export-modal-close2">Close</button>
            <button class="btn btn--secondary" id="copy-url-btn">Copy URL</button>
            <button class="btn btn--primary" id="copy-code-btn">Copy code</button>
          </div>
        </div>
      </div>

      <!-- Import Modal -->
      <div class="modal-overlay" id="import-modal" role="dialog" aria-modal="true" aria-labelledby="import-modal-title" hidden>
        <div class="modal">
          <button class="modal__close" id="import-modal-close" aria-label="Close">✕</button>
          <h3 class="modal__title" id="import-modal-title">Import Data</h3>
          <p class="modal__desc">Paste your export code below. <strong>This will merge with your current data.</strong></p>
          <textarea class="form-textarea form-textarea--code" id="import-code" placeholder="Paste export code here…" rows="6" aria-label="Import code"></textarea>
          <div class="modal__actions">
            <button class="btn btn--ghost" id="import-modal-cancel">Cancel</button>
            <button class="btn btn--primary" id="do-import-btn">Import</button>
          </div>
        </div>
      </div>

      <Footer />
      <style lang="scss">
        @use "../styles/variables" as *;
        @use "../styles/mixins" as *;

        // ============================================================
        // Page layout
        // ============================================================

        .tracker-layout {
          --tracker-section-gap: #{$space-xl};
          min-height: 100vh;
          margin: 0;
          background: radial-gradient(circle at 18% -6%, $tracker-bg-gradient-top, transparent 42%), radial-gradient(circle at 100% 100%, $tracker-bg-gradient-bottom, transparent 44%), $color-bg;

          main {
            padding-block: $space-xl 0;

            @include respond-to(md) {
              padding-block: $space-lg 0;
            }
          }
        }

        .tracker {
          padding: 0;
          max-width: 1400px;
          margin: 0 auto;
          background: transparent;
          border: none;
          backdrop-filter: none;
          box-shadow: none;
          display: flex;
          flex-direction: column;
          gap: $space-lg;
          margin-bottom: var(--tracker-section-gap);
          overflow: visible;

          @include respond-to(md) {
            gap: $space-md;
          }

          // ============================================================
          // Header / Stats Bar
          // ============================================================

          &__header {
            margin-bottom: 0;
            background: transparent;
            border: 0;
            border-radius: 0;
            padding: $space-lg $space-xl;
            box-shadow: none;
            animation: panel-enter 0.45s var(--ease-out) both;

            @include respond-to(md) {
              padding: $space-md;
            }
          }

          &__title-row {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: $space-lg;
            margin-bottom: $space-lg;

            @include respond-to(md) {
              flex-direction: column;
            }
          }

          &__title {
            font-size: $font-size-2xl;
            font-weight: $font-weight-bold;
            color: $color-text-primary;
            margin: 0 0 $space-xs;
            letter-spacing: $tracking-tight;
          }

          &__subtitle {
            font-size: $font-size-sm;
            color: $tracker-muted-text;
            margin: 0;
            max-width: 55ch;
            font-style: italic;
          }

          &__toolbar {
            display: flex;
            gap: $space-sm;
            flex-shrink: 0;
            flex-wrap: wrap;

            @include respond-to(md) {
              width: 100%;
            }
          }
        }

        // Stats bar
        .stats-bar {
          margin-bottom: var(--tracker-section-gap);
          display: grid;
          grid-template-columns: 2fr 1fr 1fr 1fr;

          gap: $space-sm;

          @include respond-to(lg) {
            grid-template-columns: 1fr 1fr;
          }

          @media (max-width: 560px) {
            grid-template-columns: 1fr;
          }

          @include respond-to(sm) {
            grid-template-columns: 1fr;
          }
        }

        .stat-card {
          @include elevated-panel($tracker-card-bg, 0, $shadow-xs);
          border-radius: $radius-lg;
          padding: $space-sm $space-lg;
          display: flex;
          align-items: center;
          gap: $space-xs;
          position: relative;
          overflow: hidden;

          &--level {
            background: linear-gradient(135deg, $color-blue-dark 0%, $color-blue 100%);
            border-color: transparent;
            color: $color-text-light;
            box-shadow: $shadow-sm;
          }

          &__value {
            font-size: $font-size-xl;
            font-weight: $font-weight-black;
            color: $color-text-primary;
            line-height: 1;
          }

          &__label {
            font-size: 0.6875rem;
            text-transform: uppercase;
            letter-spacing: $tracking-wider;
            color: $tracker-soft-text;
            font-weight: $font-weight-semibold;
            line-height: 1.2;
            white-space: nowrap;
          }

          &__icon {
            margin-left: auto;
            width: 18px;
            height: 18px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            opacity: 0.44;
            color: $tracker-muted-text;
            filter: drop-shadow(0 1px 2px rgba(0, 0, 0, 0.22));
            flex-shrink: 0;
            @include transition(opacity, 0.2s, ease-out);

            svg {
              width: 18px;
              height: 18px;
              stroke-width: 1.85;
            }
          }

          &:hover {
            .stat-card__icon {
              opacity: 0.72;
            }
          }
        }

        // Level badge
        .level-badge {
          display: flex;
          align-items: center;
          gap: $space-xs;
          margin-bottom: 0;
          white-space: nowrap;
          flex-shrink: 0;

          &__label {
            font-size: 0.625rem;
            text-transform: uppercase;
            letter-spacing: $tracking-wider;
            color: rgba(255, 255, 255, 0.7);
          }

          &__number {
            font-size: $font-size-xl;
            font-weight: $font-weight-black;
            color: $color-text-light;
          }
        }

        .xp-area {
          display: flex;
          align-items: center;
          gap: 6px;
          flex: 1;
          min-width: 0;
        }

        .xp-bar {
          flex: 1;
          min-width: 70px;
          height: 6px;
          background: rgba(255, 255, 255, 0.2);
          border-radius: 4px;
          overflow: hidden;
          position: relative;

          &__fill {
            height: 100%;
            background: linear-gradient(90deg, $color-orange-light, $color-orange);
            border-radius: 4px;
            @include transition(width, 0.5s, ease-out);
          }

          &__shimmer {
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.3) 50%, transparent 100%);
            animation: shimmer 2s infinite;
          }
        }

        @keyframes shimmer {
          0% {
            transform: translateX(-100%);
          }
          100% {
            transform: translateX(200%);
          }
        }

        .xp-text {
          font-size: 0.6875rem;
          color: rgba(255, 255, 255, 0.85);
          white-space: nowrap;
          font-weight: $font-weight-semibold;
          line-height: 1.1;
        }

        .total-xp {
          display: inline;
          font-size: 0.625rem;
          color: rgba(255, 255, 255, 0.7);
          margin-left: $space-xs;
          white-space: nowrap;
          flex-shrink: 0;
        }

        @media (max-width: 560px) {
          .stat-card__value,
          .level-badge__number {
            font-size: $font-size-lg;
          }
        }

        // Buttons
        .btn {
          display: inline-flex;
          align-items: center;
          gap: $space-xs;
          padding: $space-xs $space-md;
          border-radius: $radius-md;
          font-size: $font-size-sm;
          font-weight: $font-weight-semibold;
          cursor: pointer;
          border: 1px solid transparent;
          @include tracker-transition(all);
          text-decoration: none;
          white-space: nowrap;

          @include focus-ring;

          &--primary {
            background: linear-gradient(180deg, $color-blue 0%, $color-blue-dark 100%);
            color: $color-white;
            border-color: $tracker-card-stroke;
            box-shadow: $shadow-xs;

            &:hover {
              filter: brightness(1.04);
              transform: translateY(-1px);
              box-shadow: $shadow-sm;
            }

            &:active {
              transform: translateY(0);
            }
          }

          &--secondary {
            background: $tracker-card-bg;
            color: $color-text-primary;
            border-color: $tracker-card-stroke;

            &:hover {
              border-color: $tracker-card-stroke;
              color: $color-blue;
              background: $color-neutral-100;
            }
          }

          &--ghost {
            background: transparent;
            color: $tracker-muted-text;
            border-color: transparent;

            &:hover {
              background: rgba(31, 39, 51, 0.07);
              color: $color-text-primary;
            }
          }

          &--danger {
            background: $color-danger-bg;
            color: $color-danger-text;
            border-color: transparent;

            &:hover {
              background: $color-danger-bg-hover;
            }
          }

          &--complete {
            background: $color-success-bg;
            color: $color-success-dark;
            border-color: transparent;

            &:hover {
              background: $color-success-bg-hover;
            }
          }

          &--sm {
            min-height: 36px;
            padding: 2px $space-sm;
            font-size: $font-size-xs;
          }

          &--icon-only {
            padding: $space-xs;
            aspect-ratio: 1;
            justify-content: center;
          }
        }

        // ============================================================
        // Below fold
        // ============================================================

        .below-fold {
          margin-top: var(--tracker-section-gap);
          display: flex;
          flex-direction: column;
          gap: var(--tracker-section-gap);
          padding-top: 0;
          border-top: 0;

          @media (min-width: #{$breakpoint-lg}) {
            display: grid;
            grid-template-columns: minmax(0, 1.2fr) minmax(0, 1fr);
            align-items: stretch;
          }
        }

        .tracker-layout :global(.footer) {
          margin-top: 0;
          padding-top: $space-3xl;

          @include respond-to(md) {
            padding-top: $space-2xl;
          }
        }

        // ============================================================
        // Modals
        // ============================================================

        .modal-overlay {
          position: fixed;
          inset: 0;
          background: rgba(0, 0, 0, 0.5);
          backdrop-filter: blur(4px);
          z-index: 1000;
          display: flex;
          align-items: center;
          justify-content: center;
          padding: $space-md;
          animation: fadeIn 0.15s ease-out;

          &[hidden] {
            display: none;
          }
        }

        .modal {
          @include elevated-panel($tracker-card-bg, 0, $shadow-md);
          border-radius: $radius-xl;
          padding: $space-xl;
          width: 100%;
          max-width: 520px;
          position: relative;
          animation: scaleIn 0.15s ease-out;
          max-height: 90vh;
          overflow-y: auto;

          @include respond-to(sm) {
            padding: $space-lg;
          }

          &__close {
            position: absolute;
            top: $space-md;
            right: $space-md;
            background: transparent;
            border: none;
            font-size: 1.2rem;
            cursor: pointer;
            color: $color-text-secondary;
            padding: $space-xs;
            border-radius: $radius-sm;
            @include tracker-transition(all);
            @include focus-ring;

            &:hover {
              background: rgba(0, 0, 0, 0.08);
              color: $color-text-primary;
            }
          }

          &__title {
            font-size: $font-size-xl;
            font-weight: $font-weight-bold;
            color: $color-text-primary;
            margin: 0 0 $space-md;
          }

          &__desc {
            font-size: $font-size-sm;
            color: $tracker-muted-text;
            margin: 0 0 $space-md;
          }

          &__form {
            display: flex;
            flex-direction: column;
            gap: $space-md;
          }

          &__actions {
            display: flex;
            justify-content: flex-end;
            gap: $space-sm;
            margin-top: $space-sm;
            flex-wrap: wrap;
          }
        }

        // Form elements
        .form-group {
          display: flex;
          flex-direction: column;
          gap: $space-xs;
        }

        .form-row {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: $space-md;

          @include respond-to(sm) {
            grid-template-columns: 1fr;
          }
        }

        .form-label {
          font-size: $font-size-sm;
          font-weight: $font-weight-semibold;
          color: $color-text-primary;
        }

        .form-input,
        .form-textarea,
        .form-select {
          padding: $space-sm $space-md;
          border: 1px solid $tracker-card-stroke;
          border-radius: $radius-md;
          font-size: $font-size-sm;
          color: $color-text-primary;
          background: $tracker-card-bg;
          @include tracker-transition(border-color);

          &:focus {
            outline: none;
            border-color: $tracker-card-stroke;
          }

          @include focus-ring;
        }

        .form-textarea {
          resize: vertical;
          font-family: $font-sans;

          &--code {
            font-family: $font-mono;
            font-size: $font-size-xs;
            background: $color-code-bg;
            color: $color-code-text;
            border-color: $color-code-border;
          }
        }

        // Level-up overlay
        @keyframes level-up-pulse {
          0%,
          100% {
            box-shadow: 0 0 0 0 rgba(10, 73, 177, 0.4);
          }
          50% {
            box-shadow: 0 0 0 20px rgba(10, 73, 177, 0);
          }
        }

        .level-up-flash {
          animation: level-up-pulse 0.8s ease-out 3;
        }

        @keyframes panel-enter {
          from {
            opacity: 0;
            transform: translateY(10px);
          }
          to {
            opacity: 1;
            transform: translateY(0);
          }
        }

        @media (prefers-reduced-motion: reduce) {
          .tracker__header {
            animation: none;
          }
        }
      </style>

      <script>
        import { getTaskDecayLevel, getTaskDecayProgress } from "../utils/tracker/decay";
        import { showToast } from "../utils/tracker/toast";
        import { XP_VALUES, type AppState, type GameState, type Task, type TaskType } from "../types/tracker";

        /**
         * Tracker runtime architecture (client-side only):
         * - `state` is the single canonical source of truth for tasks + gamification metrics.
         * - UI subcomponents (`tracker-board`, `tracker-completed-tasks`) are render targets, not state owners.
         * - Mutations always flow through helpers in this file, then persist via `saveState(...)`.
         * - Persistence has two channels: localStorage (`tracker_v1`) + URL hash (`#data=`) for share/import.
         * - Board/completed/task components communicate intent through semantic custom DOM events.
         */

        // ===========================================================
