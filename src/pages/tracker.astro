          A7: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3 5 6v6c0 4.7 3 7.9 7 9 4-1.1 7-4.3 7-9V6l-7-3Z" /><path d="M9 11h6M9 14h6" /></svg>`,
          A8: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="8" /><circle cx="12" cy="12" r="4" /><circle cx="12" cy="12" r="1" /></svg>`,
          A9: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m4 8 3 3 5-6 5 6 3-3-2 10H6L4 8Z" /></svg>`,
          A10: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3 6 5-6 13L6 8l6-5Z" /></svg>`,
        };

        // Achievements definition
        const ACHIEVEMENTS = [
          { id: "first_task", icon: "A1", name: "First Steps", desc: "Complete your first task", check: (s: AppState) => s.tasks.filter((t) => t.completedAt).length >= 1 },
          { id: "five_tasks", icon: "A2", name: "Getting Started", desc: "Complete 5 tasks", check: (s: AppState) => s.tasks.filter((t) => t.completedAt).length >= 5 },
          { id: "ten_tasks", icon: "A3", name: "Building Momentum", desc: "Complete 10 tasks", check: (s: AppState) => s.tasks.filter((t) => t.completedAt).length >= 10 },
          { id: "fifty_tasks", icon: "A4", name: "Productivity Pro", desc: "Complete 50 tasks", check: (s: AppState) => s.tasks.filter((t) => t.completedAt).length >= 50 },
          { id: "first_long", icon: "A5", name: "Long Game", desc: "Complete a long-term goal", check: (s: AppState) => s.tasks.some((t) => t.completedAt && t.type === "long") },
          { id: "level_5", icon: "A6", name: "Level 5", desc: "Reach level 5", check: (s: AppState) => s.game.level >= 5 },
          { id: "level_10", icon: "A7", name: "Level 10", desc: "Reach level 10", check: (s: AppState) => s.game.level >= 10 },
          { id: "streak_7", icon: "A8", name: "Week Warrior", desc: "7-day activity streak", check: (s: AppState) => s.game.streak >= 7 },
          { id: "streak_30", icon: "A9", name: "Month Master", desc: "30-day activity streak", check: (s: AppState) => s.game.streak >= 30 },
          { id: "xp_500", icon: "A10", name: "XP Hunter", desc: "Earn 500 total XP", check: (s: AppState) => s.game.totalXP >= 500 },
        ];

        // ===========================================================
        // State management
        // ===========================================================

        function defaultState(): AppState {
          const now = new Date();
          return {
            tasks: [],
            game: {
              level: 1,
              xp: 0,
              totalXP: 0,
              completedThisMonth: 0,
              completedThisYear: 0,
              streak: 0,
              lastActivityDate: "",
              monthKey: monthKeyFromDate(now),
              yearKey: `${now.getFullYear()}`,
            },
            version: 1,
          };
        }

        function monthKeyFromDate(date: Date): string {
          return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}`;
        }

        function localDateKey(date: Date): string {
          return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2, "0")}-${String(date.getDate()).padStart(2, "0")}`;
        }

        function dayOrdinalFromKey(dateKey: string): number | null {
          const parts = dateKey.split("-");
          if (parts.length !== 3) return null;
          const [year, month, day] = parts.map(Number);
          if (!Number.isFinite(year) || !Number.isFinite(month) || !Number.isFinite(day)) return null;
          if (month < 1 || month > 12 || day < 1 || day > 31) return null;
          return Math.floor(Date.UTC(year, month - 1, day) / 86400000);
        }

        function isTaskType(value: unknown): value is TaskType {
          return value === "short" || value === "medium" || value === "long";
        }

        function normalizeTask(value: unknown, index: number): Task | null {
          if (!value || typeof value !== "object") return null;
          const task = value as Partial<Task>;
          if (typeof task.id !== "string" || typeof task.title !== "string" || !isTaskType(task.type)) return null;
          if (typeof task.createdAt !== "number") return null;
          const completedAt = typeof task.completedAt === "number" ? task.completedAt : null;

          return {
            id: task.id,
            title: task.title,
            description: typeof task.description === "string" ? task.description : "",
            type: task.type,
            createdAt: task.createdAt,
            dueDate: typeof task.dueDate === "string" ? task.dueDate : null,
            completedAt,
            order: typeof task.order === "number" ? task.order : index,
          };
        }

        function normalizeStatePayload(payload: unknown): AppState | null {
          if (!payload || typeof payload !== "object") return null;
          const app = payload as Partial<AppState>;
          if (!Array.isArray(app.tasks) || !app.game || typeof app.game !== "object") return null;

          const gameSource = app.game as Partial<GameState>;
          const now = new Date();
          const normalizedTasks = app.tasks.map((task, index) => normalizeTask(task, index)).filter((task): task is Task => task !== null);

          const normalizedGame: GameState = {
            level: typeof gameSource.level === "number" && gameSource.level > 0 ? Math.floor(gameSource.level) : 1,
            xp: typeof gameSource.xp === "number" && gameSource.xp >= 0 ? Math.floor(gameSource.xp) : 0,
            totalXP: typeof gameSource.totalXP === "number" && gameSource.totalXP >= 0 ? Math.floor(gameSource.totalXP) : 0,
            completedThisMonth: typeof gameSource.completedThisMonth === "number" && gameSource.completedThisMonth >= 0 ? Math.floor(gameSource.completedThisMonth) : 0,
            completedThisYear: typeof gameSource.completedThisYear === "number" && gameSource.completedThisYear >= 0 ? Math.floor(gameSource.completedThisYear) : 0,
            streak: typeof gameSource.streak === "number" && gameSource.streak >= 0 ? Math.floor(gameSource.streak) : 0,
            lastActivityDate: typeof gameSource.lastActivityDate === "string" ? gameSource.lastActivityDate : "",
            monthKey: typeof gameSource.monthKey === "string" ? gameSource.monthKey : monthKeyFromDate(now),
            yearKey: typeof gameSource.yearKey === "string" ? gameSource.yearKey : String(now.getFullYear()),
          };

          return {
            tasks: normalizedTasks,
            game: normalizedGame,
            version: typeof app.version === "number" ? app.version : 1,
          };
        }

        function loadState(): AppState {
          // Check URL hash first (for cross-device sync via URL)
          if (window.location.hash.startsWith("#data=")) {
            try {
              const encoded = window.location.hash.slice(6);
              const imported = decodeState(encoded);
              if (imported) {
                const merged = mergeStates(loadFromStorage(), imported);
                saveState(merged, false);
                return merged;
              }
              pendingImportError = "Import link format is invalid. Falling back to local data.";
            } catch {
              pendingImportError = "Import link encoding could not be parsed. Falling back to local data.";
            }
          }
          return loadFromStorage();
        }

        function loadFromStorage(): AppState {
          try {
            const raw = localStorage.getItem(STORAGE_KEY);
            if (!raw) return defaultState();
            const parsed = normalizeStatePayload(JSON.parse(raw));
            return parsed ?? defaultState();
          } catch {
            return defaultState();
          }
        }

        function saveState(state: AppState, pushHistory = true): void {
          try {
            localStorage.setItem(STORAGE_KEY, JSON.stringify(state));
          } catch {
            showToast({
              type: "info",
              icon: "!",
              title: "Save failed",
              text: "Browser storage is full or unavailable on this device.",
            });
            return;
          }
          syncShareUrl(state, pushHistory);
        }

        function encodeState(state: AppState): string {
          const json = JSON.stringify(state);
          const bytes = new TextEncoder().encode(json);
          let binary = "";
          bytes.forEach((b) => (binary += String.fromCharCode(b)));
          return btoa(binary);
        }

        function decodeState(encoded: string): AppState | null {
          try {
            const binary = atob(encoded);
            const bytes = Uint8Array.from(binary, (c) => c.charCodeAt(0));
            const json = new TextDecoder().decode(bytes);
            return normalizeStatePayload(JSON.parse(json));
          } catch {
            return null;
          }
        }

        function syncShareUrl(nextState: AppState, pushHistory = true): void {
          const hash = `#data=${encodeState(nextState)}`;
          if (window.location.hash === hash) return;

          const nextUrl = `${window.location.pathname}${hash}`;
          if (pushHistory) {
            history.pushState({ tracker: true }, "", nextUrl);
          } else {
            history.replaceState({ tracker: true }, "", nextUrl);
          }
        }

        function mergeStates(local: AppState, imported: AppState): AppState {
          // Merge tasks: prefer the most recently completed/updated version
          const taskMap = new Map<string, Task>();
          [...local.tasks, ...imported.tasks].forEach((t) => {
            const existing = taskMap.get(t.id);
            if (!existing || (t.completedAt ?? 0) > (existing.completedAt ?? 0)) {
              taskMap.set(t.id, t);
            }
          });
          // Use higher game stats
          const game: GameState = {
            level: Math.max(local.game.level, imported.game.level),
            xp: Math.max(local.game.xp, imported.game.xp),
            totalXP: Math.max(local.game.totalXP, imported.game.totalXP),
            completedThisMonth: Math.max(local.game.completedThisMonth, imported.game.completedThisMonth),
            completedThisYear: Math.max(local.game.completedThisYear, imported.game.completedThisYear),
            streak: Math.max(local.game.streak, imported.game.streak),
            lastActivityDate: local.game.lastActivityDate > imported.game.lastActivityDate ? local.game.lastActivityDate : imported.game.lastActivityDate,
            monthKey: local.game.monthKey,
            yearKey: local.game.yearKey,
          };
          return { tasks: Array.from(taskMap.values()), game, version: 1 };
        }

        // ===========================================================
        // App state
        // ===========================================================

        let pendingImportError = "";
        let state = loadState();
        let currentPage = 1;
        let completedFilterType: TaskType | "all" = "all";
        let draggedTaskId: string | null = null;
        let unlockedAchievements = new Set<string>(JSON.parse(localStorage.getItem("tracker_achievements") ?? "[]"));
        const astroScopeAttributeName =
          document
            .querySelector(".tracker")
            ?.getAttributeNames()
            .find((name) => name.startsWith("data-astro-cid-")) ?? null;

        // ===========================================================
        // Gamification helpers
        // ===========================================================

        function xpForNextLevel(level: number): number {
          return level * 100;
        }

        function gainXP(amount: number): void {
          const oldLevel = state.game.level;
          state.game.xp += amount;
          state.game.totalXP += amount;

          let xpNeeded = xpForNextLevel(state.game.level);
          while (state.game.xp >= xpNeeded) {
            state.game.xp -= xpNeeded;
            state.game.level++;
            xpNeeded = xpForNextLevel(state.game.level);
          }

          if (state.game.level > oldLevel) {
            onLevelUp(state.game.level);
          }

          showToast({
            type: "xp",
            icon: "+",
            title: `+${amount} XP!`,
            text: ENCOURAGE_COMPLETE[Math.floor(Math.random() * ENCOURAGE_COMPLETE.length)],
          });
        }

        function onLevelUp(newLevel: number): void {
          const title = LEVEL_TITLES[Math.min(newLevel - 1, LEVEL_TITLES.length - 1)];
          showToast({
            type: "level",
            icon: "▲",
            title: `Level up: ${newLevel}`,
            text: `You are now a ${title}! Keep crushing it!`,
          });
          document.getElementById("level-card")?.classList.add("level-up-flash");
          setTimeout(() => document.getElementById("level-card")?.classList.remove("level-up-flash"), 3000);
        }

        function recordActivity(): void {
          const now = new Date();
          const today = localDateKey(now);
          const nowMonth = monthKeyFromDate(now);
          const nowYear = `${now.getFullYear()}`;

          // Reset monthly/yearly counters if period changed
          if (state.game.monthKey !== nowMonth) {
            state.game.completedThisMonth = 0;
            state.game.monthKey = nowMonth;
          }
          if (state.game.yearKey !== nowYear) {
            state.game.completedThisYear = 0;
            state.game.yearKey = nowYear;
          }

          // Streak logic
          if (state.game.lastActivityDate === "") {
            state.game.streak = 1;
          } else {
            const todayOrdinal = dayOrdinalFromKey(today);
            const lastOrdinal = dayOrdinalFromKey(state.game.lastActivityDate);
            const diff = todayOrdinal !== null && lastOrdinal !== null ? todayOrdinal - lastOrdinal : null;
            if (diff === 0) {
              // same day
            } else if (diff === 1) {
              state.game.streak++;
            } else {
              state.game.streak = 1; // streak broken
            }
          }
          state.game.lastActivityDate = today;
        }

        // ===========================================================
        // Toast system
        // ===========================================================

        interface ToastOptions {
          type: "success" | "xp" | "level" | "info";
          icon: string;
          title: string;
          text?: string;
          duration?: number;
        }

        interface MetricData {
          value: number;
          label: string;
        }

        interface AchievementRenderData {
          icon: string;
          name: string;
          desc: string;
          unlocked: boolean;
        }

        function applyAstroScope(root: Element): void {
          if (!astroScopeAttributeName) return;
          root.setAttribute(astroScopeAttributeName, "");
          root.querySelectorAll("*").forEach((node) => {
            node.setAttribute(astroScopeAttributeName, "");
          });
        }

        function showToast(opts: ToastOptions): void {
          const container = document.getElementById("toast-container")!;
          const toast = document.createElement("div");
          const icon = document.createElement("span");
          const body = document.createElement("div");
          const title = document.createElement("p");

          toast.className = `toast toast--${opts.type}`;
          icon.className = "toast__icon";
          icon.setAttribute("aria-hidden", "true");
          icon.textContent = opts.icon;

          body.className = "toast__body";
          title.className = "toast__title";
          title.textContent = opts.title;
          body.appendChild(title);

          if (opts.text) {
            const text = document.createElement("p");
            text.className = "toast__text";
            text.textContent = opts.text;
            body.appendChild(text);
          }

          toast.append(icon, body);
          applyAstroScope(toast);
          container.appendChild(toast);
          const duration = opts.duration ?? 3500;
          setTimeout(() => {
            toast.classList.add("toast--hiding");
            setTimeout(() => toast.remove(), 350);
          }, duration);
        }

        // ===========================================================
        // Render helpers
        // ===========================================================

        function formatDate(ts: number | null): string {
          if (!ts) return "";
          return new Date(ts).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
        }

        function renderTaskCard(task: Task): HTMLElement | null {
          const template = document.getElementById("task-card-template");
          if (!(template instanceof HTMLTemplateElement)) return null;

          const card = template.content.firstElementChild?.cloneNode(true);
          if (!(card instanceof HTMLElement)) return null;

          const decay = getTaskDecayLevel(task);
          const decayProgress = getTaskDecayProgress(task);
          const xp = XP_VALUES[task.type];

          card.dataset.id = task.id;
          card.dataset.type = task.type;

          card.classList.remove("task-card--fresh", "task-card--stale", "task-card--rotten", "task-card--dragging", "task-card--drop-target");
          card.classList.add(`task-card--${decay}`);

          const titleEl = card.querySelector<HTMLElement>("[data-task-title]");
          const xpEl = card.querySelector<HTMLElement>("[data-task-xp]");
          const decayBar = card.querySelector<HTMLElement>("[data-task-decay-bar]");
          const particles = card.querySelector<HTMLElement>("[data-task-particles]");

          if (titleEl) titleEl.textContent = task.title;
          if (xpEl) xpEl.textContent = `+${xp} XP`;

          if (decayBar) {
            decayBar.style.width = `${decayProgress}%`;
            decayBar.hidden = decay === "fresh";
          }

          if (particles) {
            particles.hidden = decay !== "rotten";
          }

          card.querySelectorAll<HTMLElement>("[data-id]").forEach((actionEl) => {
            actionEl.dataset.id = task.id;
          });

          applyAstroScope(card);
          return card;
        }

        function renderCompletedTaskItem(task: CompletedTask): HTMLElement | null {
          const template = document.getElementById("completed-task-template");
          if (!(template instanceof HTMLTemplateElement)) return null;

          const item = template.content.firstElementChild?.cloneNode(true);
          if (!(item instanceof HTMLElement)) return null;

          const typeLabel = task.type === "short" ? "Weekly" : task.type === "medium" ? "Monthly" : "Quarterly";

          item.dataset.completedId = task.id;

          const titleEl = item.querySelector<HTMLElement>("[data-completed-title]");
          const typeEl = item.querySelector<HTMLElement>("[data-completed-type]");
          const dateEl = item.querySelector<HTMLElement>("[data-completed-date]");
          const xpEl = item.querySelector<HTMLElement>("[data-completed-xp]");
          const deleteBtn = item.querySelector<HTMLElement>("[data-action='delete-completed']");

          if (titleEl) titleEl.textContent = task.title;
          if (typeEl) typeEl.textContent = typeLabel;
          if (dateEl) dateEl.textContent = `Completed ${formatDate(task.completedAt)}`;
          if (xpEl) xpEl.textContent = `+${XP_VALUES[task.type]} XP`;
          if (deleteBtn) deleteBtn.dataset.id = task.id;

          applyAstroScope(item);
          return item;
        }

        function renderTasks(): void {
          const types: TaskType[] = ["short", "medium", "long"];
          types.forEach((type) => {
            const container = document.getElementById(`tasks-${type}`)!;
            const active = state.tasks.filter((t) => t.type === type && !t.completedAt).sort((a, b) => a.order - b.order);

            container.innerHTML = "";

            if (active.length === 0) {
              const empty = document.createElement("div");
              empty.className = "task-empty-state";
              empty.dataset.type = type;
              const icons: Record<TaskType, string> = { short: "W", medium: "M", long: "Q" };
              const labels: Record<TaskType, string> = { short: "No weekly tasks yet. Add one!", medium: "No monthly tasks yet. Add one!", long: "No quarterly goals yet. Add one!" };
              const icon = document.createElement("span");
              icon.className = "task-empty-state__icon";
              icon.textContent = icons[type];

              const label = document.createElement("p");
              label.textContent = labels[type];

              empty.append(icon, label);
              applyAstroScope(empty);
              container.appendChild(empty);
            } else {
              active.forEach((task) => {
                const taskCard = renderTaskCard(task);
                if (taskCard) {
                  container.appendChild(taskCard);
                }
              });
            }
          });
        }

        function renderStats(): void {
          const g = state.game;
          document.getElementById("level-number")!.textContent = String(g.level);
          const xpNeeded = xpForNextLevel(g.level);
          const pct = (g.xp / xpNeeded) * 100;
          const fill = document.getElementById("xp-bar-fill")!;
          fill.style.width = `${pct}%`;
          const bar = fill.parentElement!;
          bar.setAttribute("aria-valuenow", String(Math.round(pct)));
          bar.setAttribute("aria-valuemax", String(100));
          document.getElementById("xp-text")!.textContent = `${g.xp} / ${xpNeeded} XP`;
          document.getElementById("total-xp")!.textContent = `${g.totalXP} XP total`;
          document.getElementById("stat-month")!.textContent = String(g.completedThisMonth);
          document.getElementById("stat-year")!.textContent = String(g.completedThisYear);
          document.getElementById("stat-streak")!.textContent = String(g.streak);
          const title = LEVEL_TITLES[Math.min(g.level - 1, LEVEL_TITLES.length - 1)];
          document.getElementById("level-badge")!.setAttribute("title", title);
        }

        function renderCompleted(): void {
          const completed = state.tasks
            .filter((t) => t.completedAt !== null)
            .filter((t) => completedFilterType === "all" || t.type === completedFilterType)
            .sort((a, b) => (b.completedAt ?? 0) - (a.completedAt ?? 0));

          const totalPages = Math.max(1, Math.ceil(completed.length / PAGE_SIZE));
          if (currentPage > totalPages) currentPage = totalPages;

          const page = completed.slice((currentPage - 1) * PAGE_SIZE, currentPage * PAGE_SIZE);
          const container = document.getElementById("completed-list")!;
          container.innerHTML = "";

          if (page.length === 0) {
            const empty = document.createElement("p");
            empty.className = "empty-completed";
            empty.textContent = "No completed tasks yet — get going.";
            applyAstroScope(empty);
            container.appendChild(empty);
          } else {
            page.forEach((task) => {
              if (task.completedAt === null) return;

              const completedTask: CompletedTask = {
                ...task,
                completedAt: task.completedAt,
              };

              const completedItem = renderCompletedTaskItem(completedTask);
              if (completedItem) {
                container.appendChild(completedItem);
              }
            });
          }

          // Pagination
          renderPagination(totalPages);
        }

        function renderPagination(totalPages: number): void {
          const container = document.getElementById("pagination")!;
          container.innerHTML = "";

          if (totalPages <= 1) return;

          const createBtn = (label: string, page: number, disabled = false, active = false) => {
            const btn = document.createElement("button");
            btn.className = `pagination__btn${active ? " pagination__btn--active" : ""}`;
            btn.textContent = label;
            btn.disabled = disabled;
            btn.setAttribute("aria-label", `Page ${page}`);
            if (!disabled) {
              btn.addEventListener("click", () => {
                currentPage = page;
                renderCompleted();
              });
            }
            applyAstroScope(btn);
            return btn;
          };

          container.appendChild(createBtn("‹", currentPage - 1, currentPage === 1));
          for (let i = 1; i <= totalPages; i++) {
            container.appendChild(createBtn(String(i), i, false, i === currentPage));
          }
          container.appendChild(createBtn("›", currentPage + 1, currentPage === totalPages));
        }

        function renderFullStats(): void {
          const allCompleted = state.tasks.filter((t) => t.completedAt !== null);
          const activeCount = state.tasks.filter((t) => !t.completedAt).length;
          const totalXP = state.game.totalXP;
          const byType = { short: 0, medium: 0, long: 0 };
          allCompleted.forEach((t) => byType[t.type]++);

          const statsData: MetricData[] = [
            { value: allCompleted.length, label: "Total Completed" },
            { value: activeCount, label: "Active Tasks" },
            { value: totalXP, label: "Total XP Earned" },
            { value: byType.short, label: "Weekly Completed" },
            { value: byType.medium, label: "Monthly Completed" },
            { value: byType.long, label: "Quarterly Completed" },
            { value: state.game.streak, label: "Day Streak" },
            { value: state.game.level, label: "Current Level" },
          ];

          const grid = document.getElementById("full-stats-grid")!;
          grid.innerHTML = "";
          statsData.forEach((stat) => {
            const metric = createMetricCard(stat);
            if (metric) grid.appendChild(metric);
          });

          // Achievements
          renderAchievements();
        }

        function renderAchievements(): void {
          const grid = document.getElementById("achievement-grid")!;
          grid.innerHTML = "";

          const h3 = document.createElement("h3");
          h3.textContent = "Achievements";
          h3.className = "full-stats__achievements-title";
          applyAstroScope(h3);
          grid.appendChild(h3);

          ACHIEVEMENTS.forEach((ach) => {
            const unlocked = ach.check(state);
            if (unlocked && !unlockedAchievements.has(ach.id)) {
              unlockedAchievements.add(ach.id);
              localStorage.setItem("tracker_achievements", JSON.stringify([...unlockedAchievements]));
              showToast({ type: "success", icon: "A", title: `Achievement unlocked: ${ach.name}`, text: ach.desc });
            }
            const card = createAchievementCard({
              icon: ach.icon,
              name: ach.name,
              desc: ach.desc,
              unlocked,
            });

            if (card) grid.appendChild(card);
          });
        }

        function createMetricCard(data: MetricData): HTMLElement | null {
          const template = document.getElementById("metric-template");
          if (!(template instanceof HTMLTemplateElement)) return null;

          const fragment = template.content.cloneNode(true) as DocumentFragment;
          const iconEl = fragment.querySelector<HTMLElement>("[data-metric-icon]");
          const valueEl = fragment.querySelector<HTMLElement>("[data-metric-value]");
          const labelEl = fragment.querySelector<HTMLElement>("[data-metric-label]");

          if (!iconEl || !valueEl || !labelEl) return null;

          iconEl.innerHTML = METRIC_ICONS[data.label] ?? "";
          valueEl.textContent = String(data.value);
          labelEl.textContent = data.label;

          const metricCard = fragment.firstElementChild as HTMLElement | null;
          if (metricCard) applyAstroScope(metricCard);

          return metricCard;
        }

        function createAchievementCard(data: AchievementRenderData): HTMLElement | null {
          const template = document.getElementById("achievement-template");
          if (!(template instanceof HTMLTemplateElement)) return null;

          const fragment = template.content.cloneNode(true) as DocumentFragment;
          const card = fragment.querySelector<HTMLElement>("[data-achievement-card]");
          const iconEl = fragment.querySelector<HTMLElement>("[data-achievement-icon]");
          const nameEl = fragment.querySelector<HTMLElement>("[data-achievement-name]");
          const descEl = fragment.querySelector<HTMLElement>("[data-achievement-desc]");
          const badgeEl = fragment.querySelector<HTMLElement>("[data-achievement-badge]");

          if (!card || !iconEl || !nameEl || !descEl || !badgeEl) return null;

          card.classList.remove("achievement-card--locked", "achievement-card--unlocked");
          card.classList.add(`achievement-card--${data.unlocked ? "unlocked" : "locked"}`);
          iconEl.innerHTML = ACHIEVEMENT_ICONS[data.icon] ?? "";
          nameEl.textContent = data.name;
          descEl.textContent = data.desc;

          if (data.unlocked) {
            badgeEl.removeAttribute("hidden");
          } else {
            badgeEl.setAttribute("hidden", "true");
          }

          applyAstroScope(card);

          return card;
        }

        function renderAll(): void {
          renderTasks();
          renderStats();
          renderCompleted();
          renderFullStats();
        }

        // ===========================================================
        // Task CRUD
        // ===========================================================

        function addTask(title: string, type: TaskType): Task {
          const maxOrder = state.tasks.filter((t) => t.type === type && !t.completedAt).reduce((m, t) => Math.max(m, t.order), -1);

          const task: Task = {
            id: crypto.randomUUID(),
            title: title.trim(),
            description: "",
            type,
            createdAt: Date.now(),
            dueDate: null,
            completedAt: null,
            order: maxOrder + 1,
          };
          state.tasks.push(task);
          saveState(state);
          return task;
        }

        function loadDemoTasks(): void {
          if (state.tasks.length > 0) {
            const shouldReplace = confirm("Replace your current tasks with demo data?");
            if (!shouldReplace) return;
          }

          const now = Date.now();
          const day = 86400000;
          const today = new Date();

          const monthKey = monthKeyFromDate(today);
          const yearKey = `${today.getFullYear()}`;

          state = {
            tasks: [
              {
                id: crypto.randomUUID(),
                title: "Plan weekly sprint goals",
                description: "",
                type: "short",
                createdAt: now - 1 * day,
                dueDate: null,
                completedAt: null,
                order: 0,
              },
              {
                id: crypto.randomUUID(),
                title: "Clean backlog",
                description: "",
                type: "short",
                createdAt: now - 4 * day,
                dueDate: null,
                completedAt: null,
                order: 1,
              },
              {
                id: crypto.randomUUID(),
                title: "Write architecture note",
                description: "",
                type: "medium",
                createdAt: now - 9 * day,
                dueDate: null,
                completedAt: null,
                order: 0,
              },
              {
                id: crypto.randomUUID(),
                title: "Refine motion system",
                description: "",
                type: "medium",
                createdAt: now - 17 * day,
                dueDate: null,
                completedAt: null,
                order: 1,
              },
              {
                id: crypto.randomUUID(),
                title: "Ship Q2 portfolio update",
                description: "",
                type: "long",
                createdAt: now - 24 * day,
                dueDate: null,
                completedAt: null,
                order: 0,
              },
              {
                id: crypto.randomUUID(),
                title: "Audit Lighthouse regressions",
                description: "",
                type: "long",
                createdAt: now - 65 * day,
                dueDate: null,
                completedAt: null,
                order: 1,
              },
              {
                id: crypto.randomUUID(),
                title: "Refactor hero section",
                description: "",
                type: "short",
                createdAt: now - 8 * day,
                dueDate: null,
                completedAt: now - 2 * day,
                order: 0,
              },
              {
                id: crypto.randomUUID(),
                title: "Publish blog draft",
                description: "",
                type: "medium",
                createdAt: now - 18 * day,
                dueDate: null,
                completedAt: now - 6 * day,
                order: 0,
              },
            ],
            game: {
              level: 4,
              xp: 35,
              totalXP: 385,
              completedThisMonth: 2,
              completedThisYear: 2,
              streak: 3,
              lastActivityDate: localDateKey(today),
              monthKey,
              yearKey,
            },
            version: 1,
          };

          saveState(state);
          currentPage = 1;
          renderAll();
          showToast({ type: "success", icon: "✓", title: "Demo data loaded", text: "Sample tasks added for testing." });
        }

        function completeTask(id: string): void {
          const task = state.tasks.find((t) => t.id === id);
          if (!task || task.completedAt) return;
          task.completedAt = Date.now();

          recordActivity();
          state.game.completedThisMonth++;
          state.game.completedThisYear++;

          gainXP(XP_VALUES[task.type]);
          saveState(state);
          renderAll();
        }

        function deleteTask(id: string): void {
          state.tasks = state.tasks.filter((t) => t.id !== id);
          saveState(state);
          renderAll();
        }

        function editTask(id: string, title: string, type: TaskType): void {
          const task = state.tasks.find((t) => t.id === id);
          if (!task) return;
          task.title = title.trim();
          task.description = "";
          task.type = type;
          task.dueDate = null;
          saveState(state);
          renderAll();
        }

        // ===========================================================
        // Drag & Drop
        // ===========================================================

        function normalizeOrders(type: TaskType): void {
          state.tasks
            .filter((t) => t.type === type && !t.completedAt)
            .sort((a, b) => a.order - b.order)
            .forEach((task, index) => {
              task.order = index;
            });
        }

        function handleDrop(e: DragEvent): void {
          e.preventDefault();
          const targetGrid = e.currentTarget as HTMLElement;
          const targetType = targetGrid.dataset.type as TaskType;
          targetGrid.classList.remove("drag-over");

          if (!draggedTaskId) return;
          const task = state.tasks.find((t) => t.id === draggedTaskId);
          if (!task) return;
          const sourceType = task.type;

          // Find drop position
          const dropCard = (e.target as HTMLElement).closest<HTMLElement>(".task-card");

          if (dropCard && dropCard.dataset.id !== draggedTaskId) {
            const targetTask = state.tasks.find((t) => t.id === dropCard.dataset.id);
            if (targetTask) {
              task.type = targetType;
              // Insert between items using a fractional order, then normalize immediately below.
              task.order = targetTask.order - 0.5;
            }
          } else {
            // Drop at end of section
            task.type = targetType;
            const maxOrder = state.tasks.filter((t) => t.type === targetType && !t.completedAt && t.id !== draggedTaskId).reduce((m, t) => Math.max(m, t.order), -1);
            task.order = maxOrder + 1;
          }

          normalizeOrders(sourceType);
          normalizeOrders(targetType);
          saveState(state);
          renderAll();
          showToast({ type: "info", icon: "i", title: "Task moved", text: `Moved to ${targetType === "short" ? "weekly" : targetType === "medium" ? "monthly" : "quarterly"} section.` });
        }

        // ===========================================================
        // Modal helpers
        // ===========================================================

        function openModal(id: string): void {
          const modal = document.getElementById(id)!;
          modal.removeAttribute("hidden");
          // Focus first focusable element
          setTimeout(() => {
            const first = modal.querySelector<HTMLElement>("input, select, textarea, button:not(.modal__close)");
            first?.focus();
          }, 50);
        }

        function closeModal(id: string): void {
          document.getElementById(id)!.setAttribute("hidden", "");
        }

        // ===========================================================
        // Event wiring
        // ===========================================================

        document.addEventListener("tracker-task-dragstart", (event) => {
          const dragEvent = event as CustomEvent<{ id: string }>;
          draggedTaskId = dragEvent.detail?.id ?? null;
        });

        document.addEventListener("tracker-task-dragend", () => {
          draggedTaskId = null;
        });

        // Add task button
        document.getElementById("add-task-btn")!.addEventListener("click", () => {
          (document.getElementById("edit-task-id") as HTMLInputElement).value = "";
          (document.getElementById("task-title-input") as HTMLInputElement).value = "";
          (document.getElementById("task-type-input") as HTMLSelectElement).value = "short";
          (document.getElementById("task-modal-title") as HTMLElement).textContent = "Add Task";
          (document.getElementById("task-form-submit") as HTMLElement).textContent = "Add Task";
          openModal("task-modal");
        });

        document.getElementById("demo-data-btn")!.addEventListener("click", () => {
          loadDemoTasks();
        });

        // Add-section buttons
        document.querySelectorAll(".add-section-btn").forEach((btn) => {
          btn.addEventListener("click", () => {
            const type = (btn as HTMLElement).dataset.type as TaskType;
            (document.getElementById("edit-task-id") as HTMLInputElement).value = "";
            (document.getElementById("task-title-input") as HTMLInputElement).value = "";
            (document.getElementById("task-type-input") as HTMLSelectElement).value = type;
            (document.getElementById("task-modal-title") as HTMLElement).textContent = "Add Task";
            (document.getElementById("task-form-submit") as HTMLElement).textContent = "Add Task";
            openModal("task-modal");
          });
        });

        // Modal close buttons
        ["task-modal-close", "task-modal-cancel"].forEach((id) => {
          document.getElementById(id)!.addEventListener("click", () => closeModal("task-modal"));
        });
        ["export-modal-close", "export-modal-close2"].forEach((id) => {
          document.getElementById(id)!.addEventListener("click", () => closeModal("export-modal"));
        });
        ["import-modal-close", "import-modal-cancel"].forEach((id) => {
          document.getElementById(id)!.addEventListener("click", () => closeModal("import-modal"));
        });

        // Close on overlay click
        document.querySelectorAll(".modal-overlay").forEach((overlay) => {
          overlay.addEventListener("click", (e) => {
            if (e.target === overlay) {
              overlay.setAttribute("hidden", "");
            }
          });
        });

        // Close on Escape
        document.addEventListener("keydown", (e) => {
          if (e.key === "Escape") {
            document.querySelectorAll(".modal-overlay:not([hidden])").forEach((m) => m.setAttribute("hidden", ""));
          }
        });

        // Task form submit
        document.getElementById("task-form")!.addEventListener("submit", (e) => {
          e.preventDefault();
          const editId = (document.getElementById("edit-task-id") as HTMLInputElement).value;
          const title = (document.getElementById("task-title-input") as HTMLInputElement).value;
          const type = (document.getElementById("task-type-input") as HTMLSelectElement).value as TaskType;

          if (!title.trim()) return;

          if (editId) {
            editTask(editId, title, type);
            showToast({ type: "info", icon: "i", title: "Task updated", text: "" });
          } else {
            addTask(title, type);
            showToast({ type: "success", icon: "+", title: "Task added", text: `"${title}" added to your ${type === "short" ? "weekly" : type === "medium" ? "monthly" : "quarterly"} tasks.` });
          }
          closeModal("task-modal");
          renderAll();
        });

        // Board event delegation
        document.getElementById("tasks-short")!.addEventListener("click", handleBoardAction);
        document.getElementById("tasks-medium")!.addEventListener("click", handleBoardAction);
        document.getElementById("tasks-long")!.addEventListener("click", handleBoardAction);

        // Completed list delegation
        document.getElementById("completed-list")!.addEventListener("click", (e) => {
          const btn = (e.target as HTMLElement).closest<HTMLElement>("[data-action='delete-completed']");
          if (btn) {
            if (confirm("Delete this completed task?")) {
              deleteTask(btn.dataset.id!);
            }
          }
        });

        function handleBoardAction(e: Event): void {
          const target = e.target as HTMLElement;
          const btn = target.closest<HTMLElement>("[data-action]");
          if (!btn) return;
          const action = btn.dataset.action!;
          const id = btn.dataset.id!;

          if (action === "complete") {
            completeTask(id);
          } else if (action === "delete") {
            if (confirm("Delete this task?")) {
              deleteTask(id);
            }
          } else if (action === "edit") {
            const task = state.tasks.find((t) => t.id === id);
            if (!task) return;
            (document.getElementById("edit-task-id") as HTMLInputElement).value = task.id;
            (document.getElementById("task-title-input") as HTMLInputElement).value = task.title;
            (document.getElementById("task-type-input") as HTMLSelectElement).value = task.type;
            (document.getElementById("task-modal-title") as HTMLElement).textContent = "Edit Task";
            (document.getElementById("task-form-submit") as HTMLElement).textContent = "Save Changes";
            openModal("task-modal");
          }
        }

        // Drag over highlighting for task grids
        document.querySelectorAll(".task-grid").forEach((grid) => {
          grid.addEventListener("dragover", (e) => {
            e.preventDefault();
            grid.classList.add("drag-over");
          });
          grid.addEventListener("drop", (e) => handleDrop(e as DragEvent));
          grid.addEventListener("dragleave", (e) => {
            if (!grid.contains((e as DragEvent).relatedTarget as Node)) {
              grid.classList.remove("drag-over");
            }
          });
        });

        // Export
        document.getElementById("export-btn")!.addEventListener("click", () => {
          const code = encodeState(state);
          (document.getElementById("export-code") as HTMLTextAreaElement).value = code;
          openModal("export-modal");
        });

        document.getElementById("copy-code-btn")!.addEventListener("click", () => {
          const code = (document.getElementById("export-code") as HTMLTextAreaElement).value;
          navigator.clipboard.writeText(code).then(() => {
            showToast({ type: "success", icon: "✓", title: "Copied", text: "Paste this on another device to sync." });
          });
        });

        document.getElementById("copy-url-btn")!.addEventListener("click", () => {
          syncShareUrl(state, false);
          const url = window.location.href;
          navigator.clipboard.writeText(url).then(() => {
            showToast({ type: "success", icon: "✓", title: "URL copied", text: "Open this URL on another device to import." });
          });
        });

        // Import
        document.getElementById("import-btn")!.addEventListener("click", () => {
          (document.getElementById("import-code") as HTMLTextAreaElement).value = "";
          openModal("import-modal");
        });

        document.getElementById("do-import-btn")!.addEventListener("click", () => {
          const code = (document.getElementById("import-code") as HTMLTextAreaElement).value.trim();
          if (!code) return;
          const imported = decodeState(code);
          if (!imported) {
            showToast({ type: "info", icon: "!", title: "Invalid import code", text: "Please check the code and try again." });
            return;
          }
          state = mergeStates(state, imported);
          saveState(state);
          closeModal("import-modal");
          renderAll();
          showToast({ type: "success", icon: "✓", title: "Data imported", text: "Your tasks have been merged." });
        });

        // Completed filter
        document.getElementById("completed-filter-type")!.addEventListener("change", (e) => {
          completedFilterType = (e.target as HTMLSelectElement).value as TaskType | "all";
          currentPage = 1;
          renderCompleted();
        });

        // Clear completed
        document.getElementById("clear-completed-btn")!.addEventListener("click", () => {
          if (!confirm("Clear all completed tasks? This cannot be undone.")) return;
          state.tasks = state.tasks.filter((t) => !t.completedAt);
          saveState(state);
          renderAll();
          showToast({ type: "info", icon: "i", title: "Cleared", text: "All completed tasks removed." });
        });

        // ===========================================================
        // Tip rotation
        // ===========================================================

        function showRandomTip(): void {
          const tip = TIPS[Math.floor(Math.random() * TIPS.length)];
          document.getElementById("tip-text")!.textContent = tip;
        }

        // ===========================================================
        // Decay re-render (periodic)
        // ===========================================================

        // Re-render tasks every 10 minutes to refresh decay states
        setInterval(() => {
          renderTasks();
        }, 600_000);

        // ===========================================================
        // Init
        // ===========================================================

        showRandomTip();
        syncShareUrl(state, false);
        renderAll();

        if (pendingImportError) {
          showToast({ type: "info", icon: "!", title: "Import warning", text: pendingImportError, duration: 5000 });
        }

        // Show a welcome tip after a brief delay if first visit
        setTimeout(() => {
          const visited = localStorage.getItem("tracker_visited");
          if (!visited) {
            showToast({
              type: "info",
              icon: "i",
              title: "Welcome to your tracker",
              text: "Add your first task to earn XP and start levelling up!",
              duration: 6000,
            });
            localStorage.setItem("tracker_visited", "1");
          }
        }, 500);
      </script>
    </main>
  </body>
</html>
