        /** Adds a new active task at the end of its column order. */
        function addTask(title: string, type: TaskType): Task {
          const maxOrder = state.tasks.filter((t) => t.type === type && !t.completedAt).reduce((m, t) => Math.max(m, t.order), -1);

          const task: Task = {
            id: crypto.randomUUID(),
            title: title.trim(),
            description: "",
            type,
            createdAt: Date.now(),
            dueDate: null,
            completedAt: null,
            archivedAt: null,
            order: maxOrder + 1,
          };
          state.tasks.push(task);
          void saveState(state);
          return task;
        }

