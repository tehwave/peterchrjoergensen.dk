---
/**
 * Productivity Tracker & Kanban Board
 *
 * A single-page productivity app with:
 * - Three task sections: Short-term (weekly), Medium-term (monthly), Long-term (quarterly)
 * - Gamification: XP, levels, streaks
 * - Visual decay for overdue tasks with stink particles
 * - Drag-and-drop reordering within and between sections
 * - LocalStorage persistence + base64 export/import for cross-device sync
 * - Statistics and positive reinforcement toasts
 */
import "../styles/global.scss";

import { Font } from "astro:assets";
import { getImage } from "astro:assets";
import CompletedTaskTemplate from "../components/tracker/CompletedTask.astro";
import Footer from "../components/Footer.astro";
import Statistics from "../components/tracker/Statistics.astro";
import TaskTemplate from "../components/tracker/Task.astro";
import { XP_VALUES } from "../types/tracker";

// Texture images for the background, generated at build time using Astro's Assets API.
import textureSource from "../assets/black-paper.png";
const textureAVIF = await getImage({ src: textureSource, format: "avif" });
const textureWebP = await getImage({ src: textureSource, format: "webp" });
const textureFallback = await getImage({ src: textureSource, format: "png" });
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Productivity Tracker — Peter Chr. Jørgensen</title>
    <meta name="description" content="Personal productivity tracker and kanban board with gamification, visual task decay, and cross-device sync." />
    <meta name="robots" content="noindex, nofollow" />
    <meta name="generator" content={Astro.generator} />

    <!-- Resource Hints -->
    <link rel="preconnect" href="https://cdn.usefathom.com" />
    <link rel="preconnect" href="https://analytics.ahrefs.com" />

    <!-- Font preload links (generated by Astro Fonts API) -->
    <Font cssVariable="--font-inter" preload />
    <Font cssVariable="--font-caveat" preload />

    <!-- Favicon -->
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <!-- Fathom - beautiful, simple website analytics -->
    <script is:inline src="https://cdn.usefathom.com/script.js" data-site="OXXUABJE" defer></script>
    <!-- / Fathom -->

    <!-- Ahrefs Analytics -->
    <script is:inline src="https://analytics.ahrefs.com/analytics.js" data-key="PQ2PVfAM4xEKb65ihHICUQ" defer></script>
    <!-- / Ahrefs Analytics -->
  </head>
  <body class="tracker-layout">
    <style
      define:vars={{
        "texture-avif": `url(${textureAVIF.src})`,
        "texture-webp": `url(${textureWebP.src})`,
        "texture-fallback": `url(${textureFallback.src})`,
      }}
    ></style>
    <!-- 
      Skip Link - WCAG 2.4.1 Bypass Blocks (Level A)
      Allows keyboard users to skip navigation and jump directly to main content.
      Hidden off-screen by default, slides into view when focused via Tab key.
      Links to #main-content in Hero component.
    -->
    <style lang="scss">
      @use "../styles/variables" as *;

      /* Skip link styles - positioned off-screen until focused */
      .skip-link {
        position: absolute;
        top: -100px; /* Hidden above viewport */
        left: 0;
        background: $color-orange;
        color: $color-white;
        padding: 8px 16px;
        text-decoration: none;
        font-weight: 600;
        z-index: 10000;
        border-radius: 0 0 4px 0;
      }

      /* Slide into view when keyboard user presses Tab */
      .skip-link:focus {
        top: 0;
      }
    </style>
    <a href="#main-content" class="skip-link">Skip to main content</a>
    <main>
      <div class="tracker">
        <!-- ====================================================
         ABOVE THE FOLD: Stats + Task Board
         ==================================================== -->

        <!-- Stats Bar -->
        <header class="tracker__header">
          <div class="tracker__title-row">
            <div>
              <h1 class="tracker__title">Productivity Tracker</h1>
              <p class="tracker__subtitle" id="tip-text">Loading tip…</p>
            </div>
            <div class="tracker__toolbar">
              <button class="btn btn--primary" id="add-task-btn" aria-label="Add new task">
                <span aria-hidden="true">＋</span> Add Task
              </button>
              <button class="btn btn--secondary" id="demo-data-btn" aria-label="Load demo tasks">Load Demo</button>
              <button class="btn btn--secondary" id="export-btn" aria-label="Export data">Export</button>
              <button class="btn btn--secondary" id="import-btn" aria-label="Import data">Import</button>
            </div>
          </div>

          <div class="stats-bar">
            <!-- Level & XP -->
            <div class="stat-card stat-card--level" id="level-card">
              <div class="level-badge" id="level-badge">
                <span class="level-badge__icon">●</span>
                <span class="level-badge__label">Level</span>
                <span class="level-badge__number" id="level-number">1</span>
              </div>
              <div class="xp-area">
                <div class="xp-bar" role="progressbar" aria-label="XP progress" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100">
                  <div class="xp-bar__fill" id="xp-bar-fill" style="width: 0%"></div>
                  <div class="xp-bar__shimmer"></div>
                </div>
                <div class="xp-text" id="xp-text">0 / 100 XP</div>
              </div>
              <div class="total-xp" id="total-xp">0 XP total</div>
            </div>

            <!-- Monthly stat -->
            <div class="stat-card">
              <span class="stat-card__value" id="stat-month">0</span>
              <span class="stat-card__label">Done this month</span>
              <span class="stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="5" width="18" height="16" rx="2"></rect>
                  <path d="M16 3v4M8 3v4M3 10h18"></path>
                </svg>
              </span>
            </div>

            <!-- Yearly stat -->
            <div class="stat-card">
              <span class="stat-card__value" id="stat-year">0</span>
              <span class="stat-card__label">Done this year</span>
              <span class="stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="12" cy="12" r="8"></circle>
                  <circle cx="12" cy="12" r="4"></circle>
                  <circle cx="12" cy="12" r="1"></circle>
                </svg>
              </span>
            </div>

            <!-- Streak -->
            <div class="stat-card">
              <span class="stat-card__value" id="stat-streak">0</span>
              <span class="stat-card__label">Day streak</span>
              <span class="stat-card__icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 3c.4 2.4-.6 4.1-2.2 5.6C8.2 10 7 11.5 7 13.7 7 17.2 9.7 20 13 20s6-2.8 6-6.3c0-2.4-1.4-4.1-3.4-5.6-.7 2-2.1 3.4-3.6 4.3C12.9 10.6 12.5 7.4 12 3Z"></path>
                </svg>
              </span>
            </div>
          </div>

          <!-- Task Board -->
          <div class="tracker__board">
            <!-- Short-term section (2-column internally) -->
            <section class="task-section task-section--short" aria-labelledby="section-short-title">
              <div class="task-section__header">
                <div>
                  <h2 class="task-section__title" id="section-short-title">
                    <span class="task-section__icon">W</span>
                    This Week
                  </h2>
                  <p class="task-section__meta">Short-term · <strong>10 XP</strong> · Renews weekly</p>
                </div>
                <button class="btn btn--ghost add-section-btn" data-type="short" aria-label="Add weekly task">＋</button>
              </div>
              <div class="task-grid task-grid--two-col" id="tasks-short" data-type="short" role="list" aria-label="Short-term tasks">
                <!-- tasks injected by JS -->
                <div class="task-empty-state" data-type="short">
                  <span class="task-empty-state__icon">W</span>
                  <p>No weekly tasks yet. Add one!</p>
                </div>
              </div>
            </section>

            <!-- Medium and Long side-by-side -->
            <div class="task-sections-row">
              <!-- Medium-term section -->
              <section class="task-section task-section--medium" aria-labelledby="section-medium-title">
                <div class="task-section__header">
                  <div>
                    <h2 class="task-section__title" id="section-medium-title">
                      <span class="task-section__icon">M</span>
                      This Month
                    </h2>
                    <p class="task-section__meta">Medium-term · <strong>25 XP</strong> · Renews monthly</p>
                  </div>
                  <button class="btn btn--ghost add-section-btn" data-type="medium" aria-label="Add monthly task">＋</button>
                </div>
                <div class="task-grid" id="tasks-medium" data-type="medium" role="list" aria-label="Medium-term tasks">
                  <div class="task-empty-state" data-type="medium">
                    <span class="task-empty-state__icon">M</span>
                    <p>No monthly tasks yet. Add one!</p>
                  </div>
                </div>
              </section>

              <!-- Long-term section -->
              <section class="task-section task-section--long" aria-labelledby="section-long-title">
                <div class="task-section__header">
                  <div>
                    <h2 class="task-section__title" id="section-long-title">
                      <span class="task-section__icon">Q</span>
                      This Quarter
                    </h2>
                    <p class="task-section__meta">Long-term · <strong>50 XP</strong> · Renews quarterly</p>
                  </div>
                  <button class="btn btn--ghost add-section-btn" data-type="long" aria-label="Add quarterly task">＋</button>
                </div>
                <div class="task-grid" id="tasks-long" data-type="long" role="list" aria-label="Long-term tasks">
                  <div class="task-empty-state" data-type="long">
                    <span class="task-empty-state__icon">Q</span>
                    <p>No quarterly goals yet. Add one!</p>
                  </div>
                </div>
              </section>
            </div>
          </div>

          <!-- ====================================================
         BELOW THE FOLD: Completed Tasks + Full Stats
         ==================================================== -->

          <div class="below-fold">
            <!-- Completed Tasks -->
            <section class="completed-section" aria-labelledby="completed-title">
              <div class="section-heading-row">
                <h2 class="section-heading" id="completed-title">Completed Tasks</h2>
                <div class="completed-filters">
                  <select id="completed-filter-type" class="filter-select" aria-label="Filter by type">
                    <option value="all">All types</option>
                    <option value="short">Short-term</option>
                    <option value="medium">Medium-term</option>
                    <option value="long">Long-term</option>
                  </select>
                  <button class="btn btn--ghost btn--sm" id="clear-completed-btn">Clear completed</button>
                </div>
              </div>
              <div class="completed-list" id="completed-list" role="list" aria-label="Completed tasks">
                <p class="empty-completed">No completed tasks yet — get going.</p>
              </div>
              <div class="pagination" id="pagination" aria-label="Completed tasks pagination"></div>
            </section>

            <!-- Full Statistics -->
            <Statistics />
          </div>

          <template id="task-card-template">
            <TaskTemplate id="__TASK_ID__" title="__TASK_TITLE__" type="short" decay="fresh" xp={XP_VALUES.short} decayProgress={0} />
          </template>

          <template id="completed-task-template">
            <CompletedTaskTemplate id="__TASK_ID__" title="__TASK_TITLE__" typeLabel="Weekly" completedAtLabel="Completed 1 Jan 2000" xp={XP_VALUES.short} />
          </template>

          <!-- ====================================================
       MODALS
       ==================================================== -->

          <!-- Add / Edit Task Modal -->
          <div class="modal-overlay" id="task-modal" role="dialog" aria-modal="true" aria-labelledby="task-modal-title" hidden>
            <div class="modal">
              <button class="modal__close" id="task-modal-close" aria-label="Close">✕</button>
              <h3 class="modal__title" id="task-modal-title">Add Task</h3>
              <form class="modal__form" id="task-form" novalidate>
                <input type="hidden" id="edit-task-id" />
                <div class="form-group">
                  <label for="task-title-input" class="form-label">Title <span aria-hidden="true">*</span></label>
                  <input type="text" id="task-title-input" class="form-input" placeholder="What needs doing?" required maxlength="120" />
                </div>
                <div class="form-group">
                  <label for="task-type-input" class="form-label">Timeframe</label>
                  <select id="task-type-input" class="form-select">
                    <option value="short">This Week (10 XP)</option>
                    <option value="medium">This Month (25 XP)</option>
                    <option value="long">This Quarter (50 XP)</option>
                  </select>
                </div>
                <div class="modal__actions">
                  <button type="button" class="btn btn--ghost" id="task-modal-cancel">Cancel</button>
                  <button type="submit" class="btn btn--primary" id="task-form-submit">Add Task</button>
                </div>
              </form>
            </div>
          </div>

          <!-- Export Modal -->
          <div class="modal-overlay" id="export-modal" role="dialog" aria-modal="true" aria-labelledby="export-modal-title" hidden>
            <div class="modal">
              <button class="modal__close" id="export-modal-close" aria-label="Close">✕</button>
              <h3 class="modal__title" id="export-modal-title">Export Data</h3>
              <p class="modal__desc">Copy this code to back up or move your data to another device.</p>
              <textarea class="form-textarea form-textarea--code" id="export-code" readonly rows="6" aria-label="Export code"></textarea>
              <div class="modal__actions">
                <button class="btn btn--ghost" id="export-modal-close2">Close</button>
                <button class="btn btn--secondary" id="copy-url-btn">Copy URL</button>
                <button class="btn btn--primary" id="copy-code-btn">Copy code</button>
              </div>
            </div>
          </div>

          <!-- Import Modal -->
          <div class="modal-overlay" id="import-modal" role="dialog" aria-modal="true" aria-labelledby="import-modal-title" hidden>
            <div class="modal">
              <button class="modal__close" id="import-modal-close" aria-label="Close">✕</button>
              <h3 class="modal__title" id="import-modal-title">Import Data</h3>
              <p class="modal__desc">Paste your export code below. <strong>This will merge with your current data.</strong></p>
              <textarea class="form-textarea form-textarea--code" id="import-code" placeholder="Paste export code here…" rows="6" aria-label="Import code"></textarea>
              <div class="modal__actions">
                <button class="btn btn--ghost" id="import-modal-cancel">Cancel</button>
                <button class="btn btn--primary" id="do-import-btn">Import</button>
              </div>
            </div>
          </div>

          <!-- Toast Container -->
          <div class="toast-container" id="toast-container" aria-live="polite" aria-atomic="false"></div>
        </header>
      </div>

      <Footer />
      <style lang="scss">
        @use "../styles/variables" as *;
        @use "../styles/mixins" as *;

        // ============================================================
        // Page layout
        // ============================================================

        .tracker-layout {
          min-height: 100vh;
          margin: 0;
          background: radial-gradient(circle at 18% -6%, $tracker-bg-gradient-top, transparent 42%), radial-gradient(circle at 100% 100%, $tracker-bg-gradient-bottom, transparent 44%), $color-bg;

          main {
            padding-block: $space-xl $space-3xl;

            @include respond-to(md) {
              padding-block: $space-lg $space-2xl;
            }
          }
        }

        .tracker {
          padding: 0;
          max-width: 1400px;
          margin: 0 auto;
          background: transparent;
          border: none;
          backdrop-filter: none;
          box-shadow: none;
          display: flex;
          flex-direction: column;
          gap: $space-lg;
          overflow: visible;

          @include respond-to(md) {
            gap: $space-md;
          }

          // ============================================================
          // Header / Stats Bar
          // ============================================================

          &__header {
            margin-bottom: 0;
            background: transparent;
            border: 0;
            border-radius: 0;
            padding: $space-lg $space-xl;
            box-shadow: none;
            animation: panel-enter 0.45s var(--ease-out) both;

            @include respond-to(md) {
              padding: $space-md;
            }
          }

          &__title-row {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            gap: $space-lg;
            margin-bottom: $space-lg;

            @include respond-to(md) {
              flex-direction: column;
            }
          }

          &__title {
            font-size: $font-size-2xl;
            font-weight: $font-weight-bold;
            color: $color-text-primary;
            margin: 0 0 $space-xs;
            letter-spacing: $tracking-tight;
          }

          &__subtitle {
            font-size: $font-size-sm;
            color: $tracker-muted-text;
            margin: 0;
            max-width: 55ch;
            font-style: italic;
          }

          &__toolbar {
            display: flex;
            gap: $space-sm;
            flex-shrink: 0;
            flex-wrap: wrap;

            @include respond-to(md) {
              width: 100%;
            }
          }
        }

        // Stats bar
        .stats-bar {
          display: grid;
          grid-template-columns: 2fr 1fr 1fr 1fr;

          gap: $space-md;

          @include respond-to(lg) {
            grid-template-columns: 1fr 1fr;
          }

          @media (max-width: 560px) {
            grid-template-columns: 1fr;
          }

          @include respond-to(sm) {
            grid-template-columns: 1fr;
          }
        }

        .stat-card {
          @include elevated-panel($tracker-card-bg, $tracker-card-stroke, $shadow-xs);
          border-radius: $radius-lg;
          padding: $space-md $space-lg;
          display: flex;
          flex-direction: column;
          gap: $space-xs;
          position: relative;
          overflow: hidden;

          &--level {
            background: linear-gradient(135deg, $color-blue-dark 0%, $color-blue 100%);
            border-color: transparent;
            color: $color-text-light;
            box-shadow: $shadow-sm;
          }

          &__value {
            font-size: $font-size-2xl;
            font-weight: $font-weight-black;
            color: $color-text-primary;
            line-height: 1;
          }

          &__label {
            font-size: $font-size-xs;
            text-transform: uppercase;
            letter-spacing: $tracking-wider;
            color: $tracker-soft-text;
            font-weight: $font-weight-semibold;
          }

          &__icon {
            position: absolute;
            top: $space-md;
            right: $space-md;
            width: 28px;
            height: 28px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            opacity: 0.2;

            svg {
              width: 28px;
              height: 28px;
            }
          }
        }

        // Level badge
        .level-badge {
          display: flex;
          align-items: center;
          gap: $space-sm;
          margin-bottom: $space-sm;

          &__icon {
            font-size: 1.5rem;
          }

          &__label {
            font-size: $font-size-xs;
            text-transform: uppercase;
            letter-spacing: $tracking-wider;
            color: rgba(255, 255, 255, 0.7);
          }

          &__number {
            font-size: $font-size-2xl;
            font-weight: $font-weight-black;
            color: $color-text-light;
          }
        }

        .xp-area {
          display: flex;
          align-items: center;
          gap: $space-sm;
        }

        .xp-bar {
          flex: 1;
          height: 10px;
          background: rgba(255, 255, 255, 0.2);
          border-radius: 5px;
          overflow: hidden;
          position: relative;

          &__fill {
            height: 100%;
            background: linear-gradient(90deg, $color-orange-light, $color-orange);
            border-radius: 5px;
            @include transition(width, 0.5s, ease-out);
          }

          &__shimmer {
            position: absolute;
            inset: 0;
            background: linear-gradient(90deg, transparent 0%, rgba(255, 255, 255, 0.3) 50%, transparent 100%);
            animation: shimmer 2s infinite;
          }
        }

        @keyframes shimmer {
          0% {
            transform: translateX(-100%);
          }
          100% {
            transform: translateX(200%);
          }
        }

        .xp-text {
          font-size: $font-size-xs;
          color: rgba(255, 255, 255, 0.85);
          white-space: nowrap;
          font-weight: $font-weight-semibold;
        }

        .total-xp {
          font-size: $font-size-xs;
          color: rgba(255, 255, 255, 0.6);
          margin-top: $space-xs;
        }

        // ============================================================
        // Task Board
        // ============================================================

        .tracker {
          &__board {
            display: flex;
            flex-direction: column;
            gap: $space-lg;
            animation: panel-enter 0.55s var(--ease-out) both;
          }
        }

        .task-sections-row {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: $space-lg;

          @include respond-to(lg) {
            grid-template-columns: 1fr;
          }
        }

        // Task section
        .task-section {
          @include elevated-panel($tracker-card-bg, $tracker-card-stroke, none);
          border-radius: $radius-lg;
          padding: $space-lg;
          position: relative;
          background-image:
            linear-gradient(180deg, rgba(252, 252, 253, 0.96) 0%, rgba(247, 248, 250, 0.92) 100%), linear-gradient(rgba(75, 85, 101, 0.08) 1px, transparent 1px),
            linear-gradient(90deg, rgba(75, 85, 101, 0.08) 1px, transparent 1px);
          background-size:
            100% 100%,
            18px 18px,
            18px 18px;
          animation: grid-drift 18s linear infinite;

          &--short {
            background-image:
              linear-gradient(180deg, rgba(41, 136, 250, 0.12) 0%, rgba(252, 252, 253, 0.95) 100%), linear-gradient(rgba(75, 85, 101, 0.08) 1px, transparent 1px),
              linear-gradient(90deg, rgba(75, 85, 101, 0.08) 1px, transparent 1px);
          }

          &--medium {
            background-image:
              linear-gradient(180deg, rgba(236, 131, 5, 0.12) 0%, rgba(252, 252, 253, 0.95) 100%), linear-gradient(rgba(75, 85, 101, 0.08) 1px, transparent 1px),
              linear-gradient(90deg, rgba(75, 85, 101, 0.08) 1px, transparent 1px);
          }

          &--long {
            background-image:
              linear-gradient(180deg, rgba(124, 58, 237, 0.12) 0%, rgba(252, 252, 253, 0.95) 100%), linear-gradient(rgba(75, 85, 101, 0.08) 1px, transparent 1px),
              linear-gradient(90deg, rgba(75, 85, 101, 0.08) 1px, transparent 1px);
          }

          &__header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: $space-lg;
            gap: $space-md;
          }

          &__title {
            font-size: $font-size-lg;
            font-weight: $font-weight-bold;
            color: $color-text-primary;
            margin: 0 0 $space-xs;
            display: flex;
            align-items: center;
            gap: $space-sm;
          }

          &__icon {
            font-size: 1.1em;
          }

          &__meta {
            font-size: $font-size-xs;
            color: $tracker-soft-text;
            margin: 0;
          }
        }

        // Task grid
        .task-grid {
          display: flex;
          flex-direction: column;
          gap: $space-sm;
          min-height: 60px;

          &--two-col {
            @media (min-width: #{$breakpoint-lg}) {
              display: grid;
              grid-template-columns: 1fr 1fr;
              gap: $space-sm;
            }
          }

          // Drop target highlight
          &.drag-over {
            background: rgba(41, 136, 250, 0.05);
            border-radius: $radius-md;
            outline: 1px dashed $tracker-card-stroke;
            outline-offset: 2px;
          }
        }

        // Task card
        .task-card {
          @include elevated-panel($color-white, $tracker-card-stroke, $shadow-sm);
          border-radius: $radius-md;
          padding: $space-sm $space-md;
          cursor: grab;
          position: relative;
          overflow: hidden;
          display: flex;
          flex-direction: column;
          gap: $space-xs;
          @include tracker-transition(all);

          &:hover {
            box-shadow: $shadow-lg;
            transform: translateY(-2px);
            border-color: $tracker-card-stroke;
            background: $color-white;
          }

          &:active {
            cursor: grabbing;
          }

          &--dragging {
            opacity: 0.4;
          }

          &--drop-target {
            box-shadow: 0 0 0 3px rgba(41, 136, 250, 0.28);
          }

          // Decay states
          &--stale {
            background: $color-decay-stale-bg;

            &::after {
              content: "!";
              position: absolute;
              top: $space-xs;
              right: $space-xs;
              font-size: 0.85rem;
              animation: wobble 3s ease-in-out infinite;
            }
          }

          &--rotten {
            background: $color-decay-rotten-bg;
            animation: shake 4s ease-in-out infinite;
            filter: hue-rotate(20deg) saturate(1.3);

            &::before {
              content: "";
              position: absolute;
              inset: 0;
              background: repeating-linear-gradient(-45deg, transparent, transparent 8px, rgba(100, 130, 20, 0.08) 8px, rgba(100, 130, 20, 0.08) 16px);
              pointer-events: none;
              z-index: 0;
            }

            &::after {
              content: "OLD";
              position: absolute;
              top: $space-xs;
              right: $space-xs;
              font-size: 0.65rem;
              letter-spacing: 0.05em;
              font-weight: $font-weight-bold;
              animation: wobble 1.5s ease-in-out infinite;
            }
          }

          &__title {
            font-size: $font-size-sm;
            font-weight: $font-weight-semibold;
            color: $color-text-primary;
            margin: 0;
            line-height: $leading-snug;
            position: relative;
            z-index: 1;
          }

          &__meta {
            display: flex;
            align-items: center;
            gap: $space-sm;
            flex-wrap: wrap;
            position: relative;
            z-index: 1;
          }

          &__xp {
            font-size: $font-size-xs;
            font-weight: $font-weight-semibold;
            color: $color-orange;
            background: rgba(236, 131, 5, 0.12);
            border: 1px solid $tracker-card-stroke;
            padding: 1px 8px;
            border-radius: $radius-full;
          }

          &__actions {
            display: flex;
            gap: $space-xs;
            margin-top: $space-xs;
            position: relative;
            z-index: 1;
          }

          &__decay-bar {
            position: absolute;
            bottom: 0;
            left: 0;
            height: 3px;
            background: linear-gradient(90deg, $color-decay-rotten, $color-decay-stale, $color-decay-overdue);
            @include transition(width, 0.5s);
          }
        }

        // Stink particles
        .stink-particles {
          position: absolute;
          inset: 0;
          pointer-events: none;
          z-index: 2;
          overflow: hidden;
        }

        .stink-particle {
          position: absolute;
          width: var(--size, 10px);
          height: var(--size, 10px);
          border-radius: 50%;
          background: radial-gradient(circle, rgba(90, 122, 26, 0.7), rgba(90, 122, 26, 0.1) 70%, transparent 100%);
          filter: blur(0.4px);
          animation: stink-rise var(--duration, 3s) ease-out var(--delay, 0s) infinite;
          opacity: 0;
          bottom: 0;

          @include reduced-motion {
            display: none;
          }
        }

        @keyframes stink-rise {
          0% {
            opacity: 0;
            transform: translateY(0) scale(0.6) rotate(0deg);
