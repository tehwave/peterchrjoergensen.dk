---
type SurfaceElement = "div" | "section" | "article" | "aside" | "main" | "footer";

interface Props {
  tone: "dark" | "blue" | "light";
  as?: SurfaceElement;
  width?: "full" | "contained";
  height?: "auto" | "viewport";
  depth?: "none" | "start" | "end";
  id?: string;
  labelledby?: string;
  class?: string;
}

const { tone, as: Tag = "div", width = "full", height = "auto", depth = "none", id, labelledby, class: className }: Props = Astro.props;
---

<Tag
  class:list={["surface", `surface--${tone}`, `surface--width-${width}`, `surface--height-${height}`, `surface--depth-${depth}`, className]}
  id={id}
  aria-labelledby={labelledby}
  data-surface={tone}
  data-surface-depth={depth}
>
  <div class="surface__depth" aria-hidden="true"></div>
  <div class="surface__content">
    <slot />
  </div>
</Tag>

<style lang="scss">
  .surface {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    color: var(--surface-text);
    background-color: var(--surface-background);

    &:where(footer) {
      overflow: visible;
    }

    &::before,
    &::after {
      position: absolute;
      inset: 0;
      z-index: 0;
      pointer-events: none;
      content: "";
    }

    &--width-full {
      width: 100%;
    }

    &--width-contained {
      width: min(calc(100% - 2rem), 72rem);
      margin-inline: auto;
    }

    &--height-viewport {
      min-height: 100vh;
      min-height: 100svh;
    }

    &--depth-start > &__depth {
      background:
        radial-gradient(ellipse 76% 68% at 12% 18%, rgba(var(--surface-radiance), 0.14), transparent 68%),
        linear-gradient(135deg, rgba(var(--surface-highlight), 0.07), transparent 52%, rgba(var(--surface-shadow), 0.05));
    }

    &--depth-end > &__depth {
      background:
        radial-gradient(ellipse 78% 72% at 88% 76%, rgba(var(--surface-radiance), 0.13), transparent 70%),
        linear-gradient(315deg, rgba(var(--surface-highlight), 0.08), transparent 56%, rgba(var(--surface-shadow), 0.045));
    }

    &--dark {
      --surface-radiance: 41, 136, 250;
      --surface-highlight: 139, 242, 243;
      --surface-shadow: 0, 0, 20;
      --surface-background: #091057;
      --surface-heading: #dceefb;
      --surface-text: #c8e6fb;
      --surface-muted: rgba(200, 230, 251, 0.7);
      --surface-border: rgba(200, 230, 251, 0.22);
      --surface-link: #8bf2f3;
      --surface-accent: #ec8305;

      &::before {
        background-image: url("/hero-texture.svg");
        background-repeat: repeat;
        background-position: center -3.5rem;
        background-size: clamp(30rem, 58vw, 46rem) auto;
      }

      &::after {
        background-image: url("/hero-texture.svg"), url("/hero-grain.svg");
        background-repeat: repeat;
        background-position:
          calc(50% + 9rem) 4rem,
          center;
        background-size:
          clamp(46rem, 78vw, 68rem) auto,
          26rem 26rem;
        opacity: 0.32;
      }
    }

    &--blue {
      --surface-radiance: 139, 242, 243;
      --surface-highlight: 255, 255, 255;
      --surface-shadow: 9, 16, 87;
      --surface-background: #0a49b1;
      --surface-heading: #f7fbff;
      --surface-text: #e3f1ff;
      --surface-muted: rgba(227, 241, 255, 0.76);
      --surface-border: rgba(227, 241, 255, 0.26);
      --surface-link: #bdf8f8;
      --surface-accent: #ffad45;

      &::before {
        background-image: url("/hero-texture.svg");
        background-repeat: repeat;
        background-position: center -3.5rem;
        background-size: clamp(30rem, 58vw, 46rem) auto;
      }

      &::after {
        background-image: url("/hero-texture.svg"), url("/hero-grain.svg");
        background-repeat: repeat;
        background-position:
          calc(50% + 9rem) 4rem,
          center;
        background-size:
          clamp(46rem, 78vw, 68rem) auto,
          26rem 26rem;
        opacity: 0.26;
      }
    }

    &--light {
      --surface-radiance: 236, 131, 5;
      --surface-highlight: 255, 250, 240;
      --surface-shadow: 122, 68, 16;
      --surface-background: #fff4e3;
      --surface-heading: #091057;
      --surface-text: #252853;
      --surface-muted: rgba(37, 40, 83, 0.68);
      --surface-border: rgba(122, 68, 16, 0.2);
      --surface-link: #135eaa;
      --surface-accent: #c96705;

      &::before {
        background: radial-gradient(circle at 12% 18%, rgba(236, 131, 5, 0.1), transparent 30rem), radial-gradient(circle at 82% 72%, rgba(236, 131, 5, 0.07), transparent 36rem);
      }

      &::after {
        background-image: url("/paper-texture.svg");
        background-repeat: repeat;
        background-position: center;
        background-size: clamp(28rem, 52vw, 38rem) auto;
        opacity: 0.72;
      }
    }

    &__depth {
      position: absolute;
      inset: 0;
      z-index: 1;
      pointer-events: none;
    }

    &__content {
      position: relative;
      z-index: 2;
      min-height: inherit;
    }
  }
</style>
