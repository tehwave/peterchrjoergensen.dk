---
import type { DecayLevel, TaskType } from "../../types/tracker";

interface Props {
  id: string;
  title: string;
  type: TaskType;
  decay: DecayLevel;
  decayProgress?: number;
  isDragging?: boolean;
  isDropTarget?: boolean;
}

const { id, title, type, decay, decayProgress = 0, isDragging = false, isDropTarget = false } = Astro.props;
const safeDecayProgress = Math.min(100, Math.max(0, decayProgress));
const flameCount = decay === "rotten" ? 12 : decay === "stale" ? 7 : 3;
---

<tracker-task-card
  class:list={[
    "task-card",
    `task-card--${decay}`,
    {
      "task-card--dragging": isDragging,
      "task-card--drop-target": isDropTarget,
    },
  ]}
  role="listitem"
  draggable="true"
  data-id={id}
  data-title={title}
  data-type={type}
  data-decay={decay}
>
  <div class="task-card__row">
    <p class="task-card__title" data-task-title title="Double-click to rename">{title}</p>
    <input class="task-card__title-input" data-task-title-input type="text" maxlength="120" aria-label="Edit task title" hidden />

    <div class="task-card__items" role="group" aria-label="Task status and actions">
      <span class="task-card__decay-label task-card__decay-label--stale" data-task-decay-label="stale">Stale</span>
      <span class="task-card__decay-label task-card__decay-label--rotten" data-task-decay-label="rotten">Old</span>
      <button class="task-card__action-btn task-card__action-btn--done" data-action="complete" type="button" aria-label="Complete task">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m5 12 5 5 9-9"></path>
        </svg>
      </button>
      <button class="task-card__action-btn task-card__action-btn--delete" data-action="delete" type="button" aria-label="Delete task">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M3 6h18"></path>
          <path d="M8 6V4h8v2"></path>
          <path d="M19 6l-1 14H6L5 6"></path>
          <path d="M10 11v6"></path>
          <path d="M14 11v6"></path>
        </svg>
      </button>
    </div>
  </div>

  <div class="task-card__decay-bar" data-task-decay-bar style={`width: ${safeDecayProgress}%`} hidden={decay === "fresh"}></div>

  <div class:list={["fire-particles", `fire-particles--${decay}`]} data-task-particles>
    {
      Array.from({ length: flameCount }).map((_, index) => (
        <span class="fire-particle" data-particle-index={index} aria-hidden="true">
          🔥
        </span>
      ))
    }
  </div>
</tracker-task-card>

<script is:inline>
  const TITLE_MIN_LENGTH = 1;

  class TrackerTaskCard extends HTMLElement {
    constructor() {
      super();
      this.titleEl = null;
      this.titleInputEl = null;
      this.isEditing = false;
    }

    connectedCallback() {
      if (this.dataset.taskCardInitialized === "true") return;
      this.dataset.taskCardInitialized = "true";

      this.titleEl = this.querySelector("[data-task-title]");
      this.titleInputEl = this.querySelector("[data-task-title-input]");

      this.syncTitleFromDataset();
      this.setupInlineEditing();
      this.setupActionButtons();

      this.addEventListener("dragstart", (event) => {
        if (this.isEditing) {
          event.preventDefault();
          return;
        }

        this.classList.add("task-card--dragging");
        event.dataTransfer?.setData("text/plain", this.dataset.id ?? "");
        if (event.dataTransfer) {
          event.dataTransfer.effectAllowed = "move";
        }

        this.dispatchEvent(
          new CustomEvent("tracker-task-dragstart", {
            bubbles: true,
            detail: { id: this.dataset.id ?? "" },
          }),
        );
      });

      this.addEventListener("dragend", () => {
        this.classList.remove("task-card--dragging");
        document.querySelectorAll(".task-grid.drag-over").forEach((grid) => grid.classList.remove("drag-over"));
        document.querySelectorAll(".task-card--drop-target").forEach((card) => card.classList.remove("task-card--drop-target"));

        this.dispatchEvent(
          new CustomEvent("tracker-task-dragend", {
            bubbles: true,
          }),
        );
      });

      this.addEventListener("dragover", (event) => {
        if (this.isEditing) return;

        event.preventDefault();

        if (event.dataTransfer) {
          event.dataTransfer.dropEffect = "move";
        }

        const activeDragging = document.querySelector(".task-card--dragging");
        document.querySelectorAll(".task-card--drop-target").forEach((card) => {
          if (card !== this) {
            card.classList.remove("task-card--drop-target");
          }
        });

        if (activeDragging?.dataset.id !== this.dataset.id) {
          this.classList.add("task-card--drop-target");
        }
      });

      const decayState = this.dataset.decay ?? "fresh";
      const isStale = decayState === "stale";
      const isRotten = decayState === "rotten";
      const particles = this.querySelectorAll(".fire-particle");
      particles.forEach((particle) => {
        const durationBase = isRotten ? 0.72 : isStale ? 1.08 : 1.56;
        const durationRange = isRotten ? 1.05 : isStale ? 1.2 : 1.5;
        const sizeBase = isRotten ? 17 : isStale ? 13 : 10;
        const sizeRange = isRotten ? 10 : isStale ? 8 : 6;
        const riseBase = isRotten ? 104 : isStale ? 82 : 62;
        const riseRange = isRotten ? 34 : isStale ? 28 : 20;
        const peakBase = isRotten ? 0.92 : isStale ? 0.76 : 0.5;
        const peakRange = isRotten ? 0.08 : isStale ? 0.12 : 0.14;

        particle.style.setProperty("--duration", `${durationBase + Math.random() * durationRange}s`);
        particle.style.setProperty("--delay", `${Math.random() * 1.1}s`);
        particle.style.left = `${6 + Math.random() * 88}%`;
        particle.style.setProperty("--size", `${sizeBase + Math.random() * sizeRange}px`);
        particle.style.setProperty("--drift", `${-14 + Math.random() * 28}px`);
        particle.style.setProperty("--rise", `${riseBase + Math.random() * riseRange}px`);
        particle.style.setProperty("--opacity-peak", `${peakBase + Math.random() * peakRange}`);
      });
    }

    syncTitleFromDataset() {
      if (!this.titleEl || !this.titleInputEl) return;
      const title = (this.dataset.title ?? "").trim();
      if (!title) return;
      this.titleEl.textContent = title;
      this.titleInputEl.value = title;
    }

    setupActionButtons() {
      this.addEventListener("click", (event) => {
        const target = event.target;
        const btn = target instanceof Element ? target.closest("[data-action]") : null;
        if (!btn) return;

        const id = this.dataset.id ?? "";
        if (!id) return;

        const action = btn.dataset.action;
        if (action === "complete") {
          this.dispatchEvent(
            new CustomEvent("tracker-task-complete", {
              bubbles: true,
              detail: { id },
            }),
          );
        }

        if (action === "delete") {
          this.dispatchEvent(
            new CustomEvent("tracker-task-delete", {
              bubbles: true,
              detail: { id },
            }),
          );
        }
      });
    }

    setupInlineEditing() {
      if (!this.titleEl || !this.titleInputEl) return;

      this.titleEl.addEventListener("dblclick", (event) => {
        event.preventDefault();
        this.startInlineEdit();
      });

      this.titleInputEl.addEventListener("keydown", (event) => {
        if (event.key === "Enter") {
          event.preventDefault();
          this.commitInlineEdit();
        }

        if (event.key === "Escape") {
          event.preventDefault();
          this.cancelInlineEdit();
        }
      });

      this.titleInputEl.addEventListener("blur", () => {
        if (!this.isEditing) return;
        this.commitInlineEdit();
      });
    }

    startInlineEdit() {
      if (!this.titleEl || !this.titleInputEl || this.isEditing) return;

      this.isEditing = true;
      this.classList.add("task-card--editing");
      this.titleInputEl.value = this.dataset.title ?? this.titleEl.textContent ?? "";
      this.titleEl.setAttribute("hidden", "true");
      this.titleInputEl.hidden = false;
      this.titleInputEl.focus();
      this.titleInputEl.select();
    }

    commitInlineEdit() {
      if (!this.titleEl || !this.titleInputEl || !this.isEditing) return;

      const nextTitle = this.titleInputEl.value.trim();
      if (nextTitle.length < TITLE_MIN_LENGTH) {
        this.cancelInlineEdit();
        return;
      }

      const previousTitle = this.dataset.title ?? this.titleEl.textContent ?? "";
      this.finishInlineEdit(nextTitle);

      if (nextTitle !== previousTitle) {
        this.dispatchEvent(
          new CustomEvent("tracker-task-titlechange", {
            bubbles: true,
            detail: { id: this.dataset.id ?? "", title: nextTitle },
          }),
        );
      }
    }

    cancelInlineEdit() {
      if (!this.titleEl || !this.titleInputEl) return;
      const fallback = this.dataset.title ?? this.titleEl.textContent ?? "";
      this.finishInlineEdit(fallback);
    }

    finishInlineEdit(finalTitle) {
      if (!this.titleEl || !this.titleInputEl) return;

      const next = finalTitle.trim();
      this.dataset.title = next;
      this.titleEl.textContent = next;
      this.titleInputEl.value = next;

      this.titleInputEl.hidden = true;
      this.titleEl.removeAttribute("hidden");
      this.isEditing = false;
      this.classList.remove("task-card--editing");
    }
  }

  if (!customElements.get("tracker-task-card")) {
    customElements.define("tracker-task-card", TrackerTaskCard);
  }
</script>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  tracker-task-card {
    display: block;
  }

  .task-card {
    @include elevated-panel($color-white, $tracker-card-stroke, $shadow-sm);
    border-radius: $radius-md;
    padding: $space-sm $space-md;
    cursor: grab;
    position: relative;
    overflow: hidden;
    @include tracker-transition(all);

    &:hover {
      box-shadow: $shadow-lg;
      transform: translateY(-2px);
      border-color: $tracker-card-stroke;
      background: $color-white;
    }

    &:active {
      cursor: grabbing;
    }

    &--dragging {
      opacity: 0.4;
    }

    &--drop-target {
      box-shadow: 0 0 0 3px rgba(41, 136, 250, 0.28);
    }

    &--editing {
      cursor: text;
    }

    &--stale {
      background: $color-decay-stale-bg;

      .task-card__decay-label--stale {
        display: inline-flex;
      }
    }

    &--rotten {
      background: linear-gradient(165deg, rgba(249, 115, 22, 0.12), rgba(239, 68, 68, 0.12)), #fff5f5;
      filter: saturate(1.15);

      &::before {
        content: "";
        position: absolute;
        inset: 0;
        background: repeating-linear-gradient(-45deg, transparent, transparent 8px, rgba(239, 68, 68, 0.1) 8px, rgba(249, 115, 22, 0.1) 16px);
        pointer-events: none;
        z-index: 0;
      }

      .task-card__decay-label--rotten {
        display: inline-flex;
      }
    }

    &__row {
      align-items: center;
      display: grid;
      gap: $space-sm;
      grid-template-columns: minmax(0, 1fr) auto;
      min-height: 36px;
      position: relative;
      z-index: 1;
    }

    &__title {
      color: $color-text-primary;
      cursor: text;
      font-size: $font-size-sm;
      font-weight: $font-weight-semibold;
      line-height: $leading-snug;
      margin: 0;
      min-width: 0;
      overflow-wrap: anywhere;
      user-select: none;
    }

    &__title-input {
      background: $color-white;
      border: 1px solid $tracker-card-stroke;
      border-radius: $radius-sm;
      color: $color-text-primary;
      font-size: $font-size-sm;
      font-weight: $font-weight-semibold;
      line-height: $leading-snug;
      margin: 0;
      padding: 4px 8px;
      width: 100%;

      @include focus-ring;
    }

    &__items {
      align-items: center;
      display: inline-flex;
      gap: $space-xs;
      justify-content: flex-end;
      position: relative;
      z-index: 1;
    }

    &__decay-label {
      align-items: center;
      background: rgba(17, 24, 39, 0.08);
      border: 1px solid rgba(17, 24, 39, 0.15);
      border-radius: 999px;
      color: $color-text-secondary;
      display: none;
      font-size: $font-size-xs;
      font-weight: $font-weight-bold;
      letter-spacing: 0.05em;
      line-height: 1;
      padding: 0.2rem 0.45rem;
      text-transform: uppercase;

      &--stale {
        color: $color-text-primary;
      }

      &--rotten {
        background: rgba(239, 68, 68, 0.12);
        border-color: rgba(220, 38, 38, 0.32);
        color: $color-text-primary;
      }
    }

    &__action-btn {
      align-items: center;
      aspect-ratio: 1;
      background: $tracker-card-bg;
      border: 1px solid $tracker-card-stroke;
      border-radius: 999px;
      color: $tracker-muted-text;
      cursor: pointer;
      display: inline-flex;
      height: 30px;
      justify-content: center;
      padding: 0;
      @include tracker-transition(all);
      @include focus-ring;

      svg {
        height: 15px;
        width: 15px;
      }

      &:hover {
        transform: translateY(-1px);
      }

      &--done {
        background: $color-success-bg;
        border-color: rgba(5, 150, 105, 0.25);
        color: $color-success-dark;

        &:hover {
          background: $color-success-bg-hover;
        }
      }

      &--delete {
        background: $color-danger-bg;
        border-color: rgba(220, 38, 38, 0.2);
        color: $color-danger-text;

        &:hover {
          background: $color-danger-bg-hover;
        }
      }
    }

    &__decay-bar {
      position: absolute;
      bottom: 0;
      left: 0;
      height: 3px;
      background: linear-gradient(90deg, #fb923c, #ef4444, #b91c1c);
      @include transition(width, 0.5s);
    }
  }

  .fire-particles {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 2;
    overflow: hidden;

    &--fresh {
      opacity: 0.58;
    }

    &--stale {
      opacity: 0.82;
    }

    &--rotten {
      opacity: 1;
    }
  }

  .fire-particle {
    position: absolute;
    font-size: var(--size, 14px);
    line-height: 1;
    animation: flame-rise var(--duration, 1.8s) ease-out var(--delay, 0s) infinite;
    opacity: 0;
    bottom: 0;
    filter: drop-shadow(0 0 4px rgba(255, 116, 0, 0.45)) drop-shadow(0 0 8px rgba(255, 72, 0, 0.2));
    transform-origin: center bottom;
    will-change: transform, opacity;

    @include reduced-motion {
      display: none;
    }
  }

  @keyframes flame-rise {
    0% {
      opacity: 0;
      transform: translate3d(0, 0, 0) scale(0.7) rotate(-8deg);
    }
    12% {
      opacity: calc(var(--opacity-peak, 0.9) * 0.72);
      transform: translate3d(calc(var(--drift, 0) * -0.24), -16px, 0) scale(0.88) rotate(12deg);
    }
    25% {
      opacity: var(--opacity-peak, 0.9);
      transform: translate3d(calc(var(--drift, 0) * 0.26), -28px, 0) scale(1.08) rotate(-10deg);
    }
    78% {
      opacity: calc(var(--opacity-peak, 0.9) * 0.52);
      transform: translate3d(calc(var(--drift, 0) * 0.72), calc(var(--rise, 80px) * -0.72), 0) scale(1.15) rotate(8deg);
    }
    100% {
      opacity: 0;
      transform: translate3d(var(--drift, 0), calc(var(--rise, 80px) * -1), 0) scale(1.26) rotate(-4deg);
    }
  }
</style>
