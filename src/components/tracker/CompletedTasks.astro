---
/**
 * Completed tasks section (UI-state controller + list rendering).
 *
 * Responsibilities:
 * - Own completed-list presentation state (type filter, pagination, swap transitions)
 * - Render completed snapshots pushed from tracker page via `setCompletedTasks(...)`
 * - Emit history intent events (archive/restore/clear) for page-level mutation logic
 *
 * Canonical data mutation remains in `src/pages/tracker.astro`.
 */
import CompletedTaskTemplate from "./CompletedTask.astro";
import { XP_VALUES } from "../../types/tracker";
---

<tracker-completed-tasks class="completed-section" aria-labelledby="completed-title">
  <div class="section-heading-row">
    <h2 class="section-heading" id="completed-title">Completed Tasks</h2>
    <div class="completed-filters">
      <select id="completed-filter-type" class="filter-select" aria-label="Filter by type">
        <option value="all">All types</option>
        <option value="short">Short-term</option>
        <option value="medium">Medium-term</option>
        <option value="long">Long-term</option>
      </select>
      <button class="btn btn--ghost btn--sm" id="archive-completed-btn" type="button">Archive all</button>
      <button class="btn btn--ghost btn--sm" id="restore-archived-btn" type="button" hidden>Restore all archived</button>
      <button class="btn btn--ghost btn--sm" id="clear-history-btn" type="button" hidden>Clear history</button>
    </div>
  </div>
  <div class="completed-list" id="completed-list" role="list" aria-label="Completed tasks">
    <p class="empty-completed">No completed tasks yet — get going.</p>
  </div>
  <div class="pagination" id="pagination" aria-label="Completed tasks pagination"></div>

  <!--
    Inert server-rendered blueprint used by the client controller to clone
    completed-card markup with Astro-scoped styles intact.
  -->
  <template data-completed-task-template>
    <CompletedTaskTemplate id="__TASK_ID__" title="__TASK_TITLE__" typeLabel="Weekly" completedAtLabel="Completed 1 Jan 2000" xp={XP_VALUES.short} />
  </template>

  <!--
    Hidden bootstrap instance ensures the custom element definition and scoped
    styles are present before dynamic template cloning begins.
  -->
  <div hidden aria-hidden="true">
    <CompletedTaskTemplate id="__BOOTSTRAP_COMPLETED__" title="Bootstrap" typeLabel="Weekly" completedAtLabel="Completed 1 Jan 2000" xp={XP_VALUES.short} />
  </div>
</tracker-completed-tasks>

<script>
  /** Supported tracker task horizons for completed items. */
  type TaskType = "short" | "medium" | "long";

  /** XP lookup used to render reward labels on completed cards. */
  const XP_BY_TYPE: Record<TaskType, number> = {
    short: 10,
    medium: 25,
    long: 50,
  };

  /** Minimal completed-task snapshot consumed by this list UI. */
  interface CompletedTaskData {
    id: string;
    title: string;
    type: TaskType;
    completedAt: number;
    archivedAt: number | null;
  }

  /** Number of completed cards shown per page. */
  const PAGE_SIZE = 8;

  /**
   * Completed-list UI controller.
   *
   * Owns view-local state (filter + pagination + transitions) and exposes
   * `setCompletedTasks(...)` as the bridge from page-level canonical state.
   */
  class TrackerCompletedTasks extends HTMLElement {
    /** Current visible page in completed-task pagination. */
    private currentPage = 1;
    /** Active completed-task type filter. */
    private completedFilterType: TaskType | "all" = "all";
    /** Last validated completed snapshot payload from parent orchestrator. */
    private completedTasks: CompletedTaskData[] = [];
    /** Astro scoped-style attribute copied to runtime-created DOM nodes. */
    private astroScopeAttributeName: string | null = null;
    /** Prevents overlapping list swap transitions. */
    private transitionInProgress = false;
    /** Coalesces render requests that occur mid-transition. */
    private queuedRender = false;

    /** Initializes event listeners and first paint once per element. */
    connectedCallback() {
      if (this.dataset.completedTasksInitialized === "true") return;
      this.dataset.completedTasksInitialized = "true";
      this.astroScopeAttributeName = this.getAttributeNames().find((name) => name.startsWith("data-astro-cid-")) ?? null;

      const filter = this.querySelector<HTMLSelectElement>("#completed-filter-type");
      filter?.addEventListener("change", (event) => {
        const target = event.target;
        if (!(target instanceof HTMLSelectElement)) return;
        const value = target.value;
        if (value !== "all" && value !== "short" && value !== "medium" && value !== "long") return;
        this.completedFilterType = value;
        this.currentPage = 1;
        this.requestRender();
      });

      // Surface completed history intents to the page orchestrator; this component does not mutate canonical state directly.
      this.addEventListener("click", (event) => {
        const target = event.target;
        const archiveAllButton = target instanceof Element ? target.closest("#archive-completed-btn") : null;
        const restoreAllButton = target instanceof Element ? target.closest("#restore-archived-btn") : null;
        const clearHistoryButton = target instanceof Element ? target.closest("#clear-history-btn") : null;

        if (archiveAllButton) {
          this.dispatchEvent(
            new CustomEvent("tracker-completed-archive-all", {
              bubbles: true,
            }),
          );
          return;
        }

        if (restoreAllButton) {
          this.dispatchEvent(
            new CustomEvent("tracker-completed-restore-all", {
              bubbles: true,
            }),
          );
          return;
        }

        if (clearHistoryButton) {
          this.dispatchEvent(
            new CustomEvent("tracker-completed-clear-history", {
              bubbles: true,
            }),
          );
        }
      });

      this.requestRender();
    }

    /**
     * Receives canonical completed-task snapshots and normalizes shape before render.
     */
    setCompletedTasks(tasks: CompletedTaskData[]): void {
      this.completedTasks = tasks.filter((task): task is CompletedTaskData => {
        const hasValidArchivedAt = task.archivedAt === null || typeof task.archivedAt === "number";
        return (
          typeof task?.id === "string" &&
          typeof task.title === "string" &&
          (task.type === "short" || task.type === "medium" || task.type === "long") &&
          typeof task.completedAt === "number" &&
          hasValidArchivedAt
        );
      });

      const totalPages = Math.max(1, Math.ceil(this.getVisibleCompletedTasks().length / PAGE_SIZE));
      if (this.currentPage > totalPages) {
        this.currentPage = totalPages;
      }

      this.requestRender();
    }

    /** Applies the current type filter and keeps newest completions first. */
    private getFilteredCompletedTasks(): CompletedTaskData[] {
      return this.completedTasks.filter((task) => this.completedFilterType === "all" || task.type === this.completedFilterType).sort((a, b) => b.completedAt - a.completedAt);
    }

    /** Returns completed tasks that are not archived (visible list). */
    private getVisibleCompletedTasks(): CompletedTaskData[] {
      return this.getFilteredCompletedTasks().filter((task) => task.archivedAt === null);
    }

    /** Returns archived completed tasks count for header control visibility. */
    private getArchivedCompletedCount(): number {
      return this.completedTasks.filter((task) => task.archivedAt !== null).length;
    }

    /** Formats completion timestamps for UI labels. */
    private formatDate(ts: number): string {
      return new Date(ts).toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
    }

    /** Re-applies Astro scope attributes to runtime-created DOM nodes. */
    private applyAstroScope(root: Element): void {
      if (!this.astroScopeAttributeName) return;
      root.setAttribute(this.astroScopeAttributeName, "");
      root.querySelectorAll("*").forEach((node) => {
        node.setAttribute(this.astroScopeAttributeName!, "");
      });
    }

    /** Clones and hydrates a completed-task card from the inert template. */
    private renderCompletedTaskItem(task: CompletedTaskData): HTMLElement | null {
      const template = this.querySelector("[data-completed-task-template]");
      if (!(template instanceof HTMLTemplateElement)) return null;

      const item = template.content.firstElementChild?.cloneNode(true);
      if (!(item instanceof HTMLElement)) return null;

      const typeLabel = task.type === "short" ? "Weekly" : task.type === "medium" ? "Monthly" : "Quarterly";

      item.dataset.completedId = task.id;

      const titleEl = item.querySelector<HTMLElement>("[data-completed-title]");
      const typeEl = item.querySelector<HTMLElement>("[data-completed-type]");
      const dateEl = item.querySelector<HTMLElement>("[data-completed-date]");
      const xpEl = item.querySelector<HTMLElement>("[data-completed-xp]");

      if (titleEl) titleEl.textContent = task.title;
      if (typeEl) typeEl.textContent = typeLabel;
      if (dateEl) dateEl.textContent = `Completed ${this.formatDate(task.completedAt)}`;
      if (xpEl) xpEl.textContent = `+${XP_BY_TYPE[task.type]} XP`;

      return item;
    }

    /** Renders page controls and wires navigation callbacks. */
    private renderPagination(totalPages: number): void {
      const container = this.querySelector("#pagination");
      if (!(container instanceof HTMLElement)) return;
      container.innerHTML = "";

      if (totalPages <= 1) return;

      const createBtn = (label: string, page: number, disabled = false, active = false): HTMLButtonElement => {
        const btn = document.createElement("button");
        btn.className = `pagination__btn${active ? " pagination__btn--active" : ""}`;
        btn.textContent = label;
        btn.disabled = disabled;
        btn.type = "button";
        btn.setAttribute("aria-label", `Page ${page}`);
        if (!disabled) {
          btn.addEventListener("click", () => {
            this.currentPage = page;
            this.requestRender();
          });
        }
        this.applyAstroScope(btn);
        return btn;
      };

      container.appendChild(createBtn("‹", this.currentPage - 1, this.currentPage === 1));
      for (let i = 1; i <= totalPages; i++) {
        container.appendChild(createBtn(String(i), i, false, i === this.currentPage));
      }
      container.appendChild(createBtn("›", this.currentPage + 1, this.currentPage === totalPages));
    }

    /** Coalesces render calls while swap transitions are running. */
    private requestRender(): void {
      if (this.transitionInProgress) {
        this.queuedRender = true;
        return;
      }

      void this.render();
    }

    /** Await one animation frame to ensure class toggles trigger transitions. */
    private nextFrame(): Promise<void> {
      return new Promise((resolve) => {
        window.requestAnimationFrame(() => resolve());
      });
    }

    /** Waits for opacity transition completion with a timeout safety net. */
    private waitForTransition(el: HTMLElement, timeoutMs: number): Promise<void> {
      return new Promise((resolve) => {
        let settled = false;

        const finish = () => {
          if (settled) return;
          settled = true;
          el.removeEventListener("transitionend", onEnd);
          resolve();
        };

        const onEnd = (event: Event) => {
          if (event.target === el) finish();
        };

        el.addEventListener("transitionend", onEnd);
        window.setTimeout(finish, timeoutMs);
      });
    }

    /**
     * Performs a full list repaint for current filter/page with optional fade transition.
     */
    private async render(): Promise<void> {
      this.transitionInProgress = true;
      const filtered = this.getVisibleCompletedTasks();
      const archivedCount = this.getArchivedCompletedCount();
      const totalPages = Math.max(1, Math.ceil(filtered.length / PAGE_SIZE));
      if (this.currentPage > totalPages) {
        this.currentPage = totalPages;
      }

      const page = filtered.slice((this.currentPage - 1) * PAGE_SIZE, this.currentPage * PAGE_SIZE);
      const container = this.querySelector("#completed-list");
      if (!(container instanceof HTMLElement)) {
        this.transitionInProgress = false;
        return;
      }

      const prefersReducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
      const previousHeight = container.offsetHeight;
      if (previousHeight > 0) {
        container.style.minHeight = `${previousHeight}px`;
      }

      if (!prefersReducedMotion) container.classList.add("is-swapping");

      container.innerHTML = "";

      const restoreButton = this.querySelector<HTMLButtonElement>("#restore-archived-btn");
      const clearHistoryButton = this.querySelector<HTMLButtonElement>("#clear-history-btn");
      if (restoreButton) {
        restoreButton.hidden = archivedCount === 0;
        restoreButton.textContent = `Restore all archived (${archivedCount})`;
      }
      if (clearHistoryButton) {
        clearHistoryButton.hidden = archivedCount === 0;
      }

      if (page.length === 0) {
        const empty = document.createElement("p");
        empty.className = "empty-completed";
        empty.textContent = archivedCount > 0 ? "No visible completed tasks. Archived history is hidden." : "No completed tasks yet — get going.";
        this.applyAstroScope(empty);
        container.appendChild(empty);
      } else {
        page.forEach((task) => {
          const completedItem = this.renderCompletedTaskItem(task);
          if (completedItem) {
            container.appendChild(completedItem);
          }
        });
      }

      this.renderPagination(totalPages);

      if (!prefersReducedMotion) {
        await this.nextFrame();
        container.classList.remove("is-swapping");
        await this.waitForTransition(container, 220);
      }

      container.style.minHeight = "";

      this.transitionInProgress = false;
      if (this.queuedRender) {
        this.queuedRender = false;
        this.requestRender();
      }
    }
  }

  if (!customElements.get("tracker-completed-tasks")) {
    customElements.define("tracker-completed-tasks", TrackerCompletedTasks);
  }
</script>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  tracker-completed-tasks {
    display: block;
  }

  .completed-section {
    @include elevated-panel($tracker-surface-bg-elevated, 0, none);
    display: flex;
    flex-direction: column;
    border-radius: $radius-xl;
    padding: $space-lg;
    height: 100%;
    animation: panel-enter 0.65s var(--ease-out) both;
    background: transparent;
    border: 2px dotted $tracker-surface-stroke;
    box-shadow: none;

    @include respond-to(md) {
      padding: $space-md;
    }
  }

  .section-heading-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: $space-md;
    margin-bottom: $space-lg;
    flex-wrap: wrap;
  }

  .section-heading {
    font-size: $font-size-2xl;
    font-weight: $font-weight-bold;
    color: $color-text-primary;
    margin: 0;
  }

  .completed-filters {
    display: flex;
    gap: $space-sm;
    align-items: center;
    flex-wrap: wrap;
  }

  .filter-select {
    font-size: $font-size-sm;
    padding: $space-xs $space-sm;
    border: 1px solid $tracker-card-stroke;
    border-radius: $radius-sm;
    background: $tracker-card-bg;
    color: $color-text-primary;
    cursor: pointer;

    @include focus-ring;
  }

  .completed-list {
    display: flex;
    flex-direction: column;
    flex: 1 1 auto;
    gap: $space-sm;
    min-height: 0;
    transform-origin: 50% 0;
    transition: opacity 200ms var(--ease-out);
    will-change: opacity;

    &.is-swapping {
      opacity: 0.42;
    }
  }

  .empty-completed {
    text-align: center;
    color: $tracker-muted-text;
    font-size: $font-size-sm;
    padding: $space-2xl;
  }

  .pagination {
    display: flex;
    gap: $space-xs;
    margin-top: auto;
    padding-top: $space-lg;
    flex-wrap: wrap;
    justify-content: center;
  }

  .pagination__btn {
    min-width: 36px;
    height: 36px;
    padding: 0 $space-sm;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border: 1px solid $tracker-card-stroke;
    border-radius: $radius-sm;
    background: $tracker-card-bg;
    font-size: $font-size-sm;
    cursor: pointer;
    @include tracker-transition(all);
    @include focus-ring;

    &:hover {
      border-color: $tracker-card-stroke;
      color: $color-blue;
    }

    &--active {
      background: $color-blue;
      color: $color-white;
      border-color: $tracker-card-stroke;
    }

    &:disabled {
      opacity: 0.4;
      cursor: not-allowed;
    }
  }

  .btn {
    display: inline-flex;
    align-items: center;
    gap: $space-xs;
    padding: $space-xs $space-md;
    border-radius: $radius-md;
    font-size: $font-size-sm;
    font-weight: $font-weight-semibold;
    cursor: pointer;
    border: 1px solid transparent;
    @include tracker-transition(all);
    text-decoration: none;
    white-space: nowrap;

    @include focus-ring;

    &--ghost {
      background: transparent;
      color: $tracker-muted-text;
      border-color: transparent;

      &:hover {
        background: rgba(31, 39, 51, 0.07);
        color: $color-text-primary;
      }
    }

    &--sm {
      min-height: 36px;
      padding: 2px $space-sm;
      font-size: $font-size-xs;
    }
  }

  @supports (animation-timeline: view()) {
    :global(.completed-list tracker-completed-task) {
      animation-name: completed-item-in;
      animation-duration: 1ms;
      animation-fill-mode: both;
      animation-timing-function: var(--ease-out);
      animation-timeline: view(block);
      animation-range: entry 10% cover 36%;
    }

    :global(.completed-list tracker-completed-task:nth-child(2n)) {
      animation-range: entry 14% cover 40%;
    }
  }

  @keyframes completed-item-in {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.99);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.completed-list tracker-completed-task) {
      animation: none;
    }

    .completed-list {
      transition: none;
    }
  }
</style>
