---
/**
 * Achievement card template component.
 *
 * Exposes a hidden template (`#achievement-template`) cloned by tracker runtime
 * to render lock/unlock achievement cards with scoped styles intact.
 */
type Props = Record<string, never>;

const {} = Astro.props;
---

<!-- Hidden template cloned into `.achievement-grid` at runtime. -->
<template id="achievement-template">
  <div class="achievement-card achievement-card--locked" data-achievement-card>
    <!-- Icon and copy are injected from achievement definitions in client-side state. -->
    <span class="achievement-card__icon" data-achievement-icon aria-hidden="true"></span>
    <p class="achievement-card__name" data-achievement-name></p>
    <p class="achievement-card__desc" data-achievement-desc></p>
    <!-- Screen-reader status announces locked/unlocked state changes. -->
    <span class="achievement-card__status sr-only" data-achievement-status></span>
    <!-- Visual-only unlocked badge; hidden attribute toggled by runtime script. -->
    <span class="achievement-card__badge" data-achievement-badge hidden aria-hidden="true">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M20 6 9 17l-5-5"></path>
      </svg>
    </span>
  </div>
</template>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  // Keep template available in DOM for cloning while hidden from layout.
  :global(#achievement-template) {
    display: none;
  }

  // Base achievement card appearance and transitions shared by both states.
  :global(.achievement-card) {
    @include elevated-panel($tracker-card-bg, $tracker-card-stroke, $shadow-xs);
    border-radius: $radius-lg;
    padding: $space-sm $space-md;
    text-align: center;
    position: relative;
    @include tracker-transition(all);
  }

  // Locked state intentionally looks muted and unavailable.
  :global(.achievement-card--locked) {
    border-style: dashed;
    border-color: $tracker-card-stroke-strong;
    background: repeating-linear-gradient(-45deg, rgba(47, 56, 71, 0.08) 0 6px, rgba(47, 56, 71, 0) 6px 12px), $tracker-card-bg-subtle;
    box-shadow: inset 0 0 0 1px rgba(47, 56, 71, 0.12);
  }

  // Unlocked state uses success accents and subtle glow.
  :global(.achievement-card--unlocked) {
    border-color: $tracker-card-stroke;
    background: linear-gradient(135deg, rgba(5, 150, 105, 0.12), $tracker-card-bg);
    box-shadow:
      0 0 0 1px rgba(5, 150, 105, 0.4),
      inset 0 0 16px rgba(5, 150, 105, 0.12);
  }

  :global(.achievement-card__icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 1.75rem;
    height: 1.75rem;
    margin-bottom: $space-xs;
    color: $tracker-soft-text;
  }

  :global(.achievement-card--unlocked .achievement-card__icon) {
    color: $color-success;
  }

  :global(.achievement-card--locked .achievement-card__icon) {
    color: $tracker-soft-text;
    opacity: 0.8;
  }

  :global(.achievement-card__icon svg) {
    width: 1.75rem;
    height: 1.75rem;
  }

  :global(.achievement-card__name) {
    font-size: $font-size-xs;
    font-weight: $font-weight-semibold;
    color: $color-text-primary;
    margin: 0 0 2px;
  }

  :global(.achievement-card__desc) {
    font-size: 11px;
    color: $tracker-muted-text;
    margin: 0;
  }

  // Utility class for accessible, non-visual announcements.
  :global(.achievement-card .sr-only) {
    position: absolute !important;
    width: 1px !important;
    height: 1px !important;
    padding: 0 !important;
    margin: -1px !important;
    overflow: hidden !important;
    clip: rect(0, 0, 0, 0) !important;
    white-space: nowrap !important;
    border: 0 !important;
  }

  :global(.achievement-card__badge) {
    position: absolute;
    top: -6px;
    right: -6px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    background: $color-success;
    color: $color-white;
    border-radius: $radius-full;
  }

  :global(.achievement-card__badge[hidden]) {
    display: none;
  }

  :global(.achievement-card__badge svg) {
    width: 12px;
    height: 12px;
  }

  @supports (animation-timeline: view()) {
    // Progressive enhancement: scroll-linked entrance/pop animations.
    :global(.achievement-grid .achievement-card) {
      animation-name: achievement-card-in;
      animation-duration: 1ms;
      animation-fill-mode: both;
      animation-timing-function: var(--ease-out);
      animation-timeline: view(block);
      animation-range: entry 10% cover 34%;
    }

    :global(.achievement-grid .achievement-card:nth-child(3n)) {
      animation-range: entry 14% cover 38%;
    }

    :global(.achievement-grid .achievement-card__icon) {
      animation-name: achievement-icon-in;
      animation-duration: 1ms;
      animation-fill-mode: both;
      animation-timing-function: var(--ease-out-back);
      animation-timeline: view(block);
      animation-range: entry 18% cover 40%;
    }

    :global(.achievement-grid .achievement-card--unlocked .achievement-card__badge) {
      animation-name: achievement-badge-pop;
      animation-duration: 1ms;
      animation-fill-mode: both;
      animation-timing-function: var(--ease-out-back);
      animation-timeline: view(block);
      animation-range: entry 24% cover 44%;
    }
  }

  @keyframes achievement-card-in {
    from {
      opacity: 0;
      transform: translateY(12px) scale(0.985);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes achievement-icon-in {
    from {
      opacity: 0;
      transform: scale(0.82) rotate(-3deg);
    }

    to {
      opacity: 1;
      transform: scale(1) rotate(0deg);
    }
  }

  @keyframes achievement-badge-pop {
    from {
      opacity: 0;
      transform: scale(0.7);
    }

    to {
      opacity: 1;
      transform: scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    // Accessibility fallback: disable animation for reduced-motion users.
    :global(.achievement-grid .achievement-card),
    :global(.achievement-grid .achievement-card__icon),
    :global(.achievement-grid .achievement-card--unlocked .achievement-card__badge) {
      animation: none;
    }
  }
</style>
