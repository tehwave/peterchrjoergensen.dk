---
type Props = Record<string, never>;

const {} = Astro.props;
---

<template id="metric-template">
  <div class="full-stat-card">
    <span class="full-stat-card__icon" data-metric-icon aria-hidden="true"></span>
    <span class="full-stat-card__value" data-metric-value></span>
    <span class="full-stat-card__label" data-metric-label></span>
  </div>
</template>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  :global(#metric-template) {
    display: none;
  }

  :global(.full-stat-card) {
    @include elevated-panel($tracker-card-bg, $tracker-card-stroke, $shadow-xs);
    border-radius: $radius-lg;
    border-left: 3px solid $color-blue;
    padding: $space-sm $space-md;
    display: grid;
    grid-template-columns: 24px 1fr;
    column-gap: $space-sm;
    row-gap: 2px;
    align-items: center;
  }

  :global(.full-stat-card:hover) {
    box-shadow: $shadow-sm;
    transform: translateY(-1px);
    @include tracker-transition(all);
  }

  :global(.full-stat-card__icon) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    color: rgba(10, 73, 177, 0.7);
    grid-column: 1;
    grid-row: 1 / span 2;
  }

  :global(.full-stat-card__icon svg) {
    width: 24px;
    height: 24px;
  }

  :global(.full-stat-card__value) {
    font-size: $font-size-2xl;
    font-weight: $font-weight-black;
    color: $color-blue;
    line-height: 1;
    display: block;
    grid-column: 2;
    grid-row: 1;
  }

  :global(.full-stat-card__label) {
    font-size: $font-size-xs;
    text-transform: uppercase;
    letter-spacing: $tracking-wide;
    color: $tracker-soft-text;
    grid-column: 2;
    grid-row: 2;
  }

  @supports (animation-timeline: view()) {
    :global(.full-stats-grid .full-stat-card) {
      animation-name: metric-card-in;
      animation-duration: 1ms;
      animation-fill-mode: both;
      animation-timing-function: var(--ease-out);
      animation-timeline: view(block);
      animation-range: entry 8% cover 32%;
    }

    :global(.full-stats-grid .full-stat-card__icon) {
      animation-name: metric-icon-in;
      animation-duration: 1ms;
      animation-fill-mode: both;
      animation-timing-function: var(--ease-out-back);
      animation-timeline: view(block);
      animation-range: entry 14% cover 34%;
    }

    :global(.full-stats-grid .full-stat-card:nth-child(2n)) {
      animation-range: entry 12% cover 36%;
    }
  }

  @keyframes metric-card-in {
    from {
      opacity: 0;
      transform: translateY(10px) scale(0.985);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @keyframes metric-icon-in {
    from {
      opacity: 0;
      transform: translateY(4px) scale(0.85);
    }

    to {
      opacity: 1;
      transform: translateY(0) scale(1);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    :global(.full-stats-grid .full-stat-card),
    :global(.full-stats-grid .full-stat-card__icon) {
      animation: none;
    }
  }
</style>
