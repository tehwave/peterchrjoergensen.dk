---

<div class="toast-container" id="toast-container" role="status" aria-live="polite" aria-atomic="false" aria-relevant="additions text"></div>

<style lang="scss">
  @use "../../styles/variables" as *;
  @use "../../styles/mixins" as *;

  .toast-container {
    position: fixed;
    right: $space-lg;
    bottom: $space-lg;
    z-index: 3000;
    display: flex;
    flex-direction: column;
    gap: $space-sm;
    max-width: 360px;
    pointer-events: none;
  }

  .toast {
    @include elevated-panel($tracker-card-bg, $tracker-card-stroke, $shadow-md);
    display: flex;
    align-items: center;
    gap: $space-md;
    padding: $space-sm $space-md;
    border-radius: $radius-lg;
    background-color: $color-white;
    pointer-events: auto;
    cursor: default;
    animation: toast-in 0.3s var(--ease-out-back) forwards;

    &--success {
      border-color: $tracker-card-stroke;
      background-image: linear-gradient(90deg, rgba(5, 150, 105, 0.08), $color-white);

      .toast__icon {
        color: $color-success-dark;
        background: rgba(5, 150, 105, 0.14);
      }
    }

    &--xp {
      border-color: $tracker-card-stroke;
      background-image: linear-gradient(90deg, rgba(236, 131, 5, 0.05), $color-white);

      .toast__icon {
        color: $color-orange-dark;
        background: rgba(236, 131, 5, 0.14);
      }
    }

    &--level {
      border-color: $tracker-card-stroke;
      background-image: linear-gradient(90deg, rgba(10, 73, 177, 0.05), $color-white);

      .toast__icon {
        color: $color-blue-dark;
        background: rgba(10, 73, 177, 0.14);
      }
    }

    &--info {
      border-color: $tracker-card-stroke;
      background-image: linear-gradient(90deg, rgba(41, 136, 250, 0.05), $color-white);

      .toast__icon {
        color: $color-blue;
        background: rgba(41, 136, 250, 0.14);
      }
    }

    &--hiding {
      animation: toast-out 0.3s ease-in forwards;
    }

    &__icon {
      width: 2rem;
      min-width: 2rem;
      height: 2rem;
      flex-shrink: 0;
      border-radius: $radius-full;
      display: inline-flex;
      align-items: center;
      justify-content: center;

      svg {
        width: 1.1rem;
        height: 1.1rem;
      }
    }

    &__body {
      flex: 1;
    }

    &__title {
      margin: 0;
      font-size: $font-size-sm;
      font-weight: $font-weight-bold;
      color: $color-text-primary;
    }

    &__text {
      margin: 0;
      font-size: $font-size-xs;
      color: $tracker-soft-text;
    }
  }

  @keyframes toast-in {
    from {
      opacity: 0;
      transform: translateX(40px) scale(0.9);
    }

    to {
      opacity: 1;
      transform: translateX(0) scale(1);
    }
  }

  @keyframes toast-out {
    from {
      opacity: 1;
      transform: translateX(0) scale(1);
    }

    to {
      opacity: 0;
      transform: translateX(40px) scale(0.9);
    }
  }

  @include respond-to(sm) {
    .toast-container {
      right: $space-sm;
      bottom: $space-sm;
      left: $space-sm;
      max-width: none;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .toast,
    .toast--hiding {
      animation-duration: 0.01ms;
      animation-iteration-count: 1;
      animation-delay: 0ms;
    }
  }
</style>
