---
/**
 * Blog section for home page.
 * Displays latest blog posts with excerpts and metadata.
 * Posts are sorted by publication date (newest first).
 */
import { getCollection } from "astro:content";
import AnimateOnScroll from "./AnimateOnScroll.astro";
import BlogPostCard from "./BlogPostCard.astro";
import Button from "./Button.astro";
import { getReadingTime } from "../utils/reading-time";
import type { Locale } from "../i18n/locale";
import { getMessages } from "../i18n/messages";
import { groupTranslations, selectTranslation } from "../i18n/content";

interface Props {
  locale?: Locale;
}

const { locale = "en" } = Astro.props;
const copy = getMessages(locale).blog;

// Get all blog posts, sorted by date (newest first)
const allPosts = await getCollection("blog");
const localizedPosts = Array.from(groupTranslations(allPosts).values()).map((group) => ({ ...selectTranslation(group, locale), translationKey: group.translationKey }));
const sortedPosts = localizedPosts.sort((a, b) => b.entry.data.pubDate.getTime() - a.entry.data.pubDate.getTime()).slice(0, 3);

// Calculate remaining reading time for posts not shown
const remainingPosts = localizedPosts.slice(3);
const remainingMinutes = remainingPosts.reduce((total, post) => {
  return total + getReadingTime(post.entry.body || "");
}, 0);
---

<section class="blog" id="blog">
  <div class="blog__container">
    <div class="blog__header">
      <span class="blog__label">{copy.label}</span>
      <h2 class="blog__heading">{copy.latest}</h2>
    </div>

    <div class="blog__grid">
      {
        sortedPosts.map(({ entry: post, translationKey, isFallback }, index) => {
          const readingTime = getReadingTime(post.body || "");
          const animationDelay = index * 0.1; // 100ms = 0.1s per post

          return (
            <AnimateOnScroll animation="fade-up" delay={animationDelay} class="blog__card-wrapper">
              <BlogPostCard
                title={post.data.title}
                description={post.data.description}
                pubDate={post.data.pubDate}
                readingTime={readingTime}
                tags={post.data.tags}
                href={`/blog/${translationKey}/`}
                heroImage={post.data.heroImage}
                heroImageAlt={post.data.heroImageAlt}
                locale={locale}
                englishOnly={isFallback}
              />
            </AnimateOnScroll>
          );
        })
      }
    </div>

    <div class="blog__footer">
      <p class="blog__thanks">{copy.thanks}</p>
      <Button as="a" href="/blog/" waveState="hover" class="blog__view-all">
        {remainingMinutes > 0 ? `${copy.moreMinutesPrefix} ${remainingMinutes} ${copy.moreMinutesSuffix}` : copy.viewAll}
      </Button>
    </div>
  </div>
</section>

<style lang="scss">
  @use "../styles/mixins" as *;
  @use "../styles/variables" as *;

  .blog {
    position: relative;
    padding: $space-4xl $space-xl;

    @include respond-to(md) {
      padding: $space-3xl $space-lg;
    }

    &__container {
      position: relative;
      z-index: 1;
      max-width: $max-width;
      margin: 0 auto;
    }

    &__header {
      margin-bottom: $space-3xl;
      text-align: center;
    }

    &__label {
      display: block;
      color: $color-orange;
      font-size: $font-size-sm;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: $space-md;
    }

    &__heading {
      font-size: clamp($font-size-2xl, 4vw, $font-size-3xl);
      color: $color-text-dark;
      line-height: 1.2;
    }

    &__grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
      gap: $space-2xl;

      @include respond-to(md) {
        grid-template-columns: 1fr;
        gap: $space-xl;
      }
    }

    &__card-wrapper {
      display: flex;
    }

    &__footer {
      margin-top: $space-3xl;
      text-align: center;
    }

    &__thanks {
      margin-bottom: $space-md;
      font-size: $font-size-base;
    }

    :global(.blog__view-all.button-sample) {
      min-height: 52px;
      padding: 0 $space-lg;
      color: $color-text-dark;
    }

    :global(.blog__view-all.button-sample:hover),
    :global(.blog__view-all.button-sample:focus-visible) {
      color: $color-black;
    }

    :global(.blog__view-all.button-sample .button-sample__label) {
      color: inherit;
    }
  }

  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
