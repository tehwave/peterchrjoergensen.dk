---
interface Props {
  as?: "button" | "a";
  href?: string;
  type?: "button" | "submit" | "reset";
  shape?: "pill" | "circle";
  waveState?: "default" | "hover" | "active";
  waveMount?: "self" | "external";
  circleSize?: "sm" | "md" | "lg";
  ariaLabel?: string;
  ariaPressed?: boolean;
  disabled?: boolean;
  class?: string;
  target?: string;
  rel?: string;
}

const {
  as = "button",
  href = "#",
  type = "button",
  shape = "pill",
  waveState = "default",
  waveMount = "self",
  circleSize = "md",
  ariaLabel,
  ariaPressed,
  disabled = false,
  class: className = "",
  target,
  rel,
}: Props = Astro.props;

const isLink = as === "a";
const isCircle = shape === "circle";

if (isCircle && !ariaLabel) {
  throw new Error('Button.astro: `ariaLabel` is required when shape="circle".');
}

const classes = [
  "button-sample",
  {
    "button-sample--bottom": true,
    "button-sample--hover": waveState === "hover",
    "button-sample--locked": waveState === "active",
    "button-sample--active": waveState === "active",
    "button-sample--circle": isCircle,
    "button-sample--circle-sm": isCircle && circleSize === "sm",
    "button-sample--circle-md": isCircle && circleSize === "md",
    "button-sample--circle-lg": isCircle && circleSize === "lg",
  },
  className,
];
---

{
  isLink ? (
    <a class:list={classes} href={disabled ? undefined : href} aria-label={ariaLabel} aria-disabled={disabled || undefined} tabindex={disabled ? -1 : undefined} target={target} rel={rel}>
      {waveState === "default" ? (
        <canvas class="button-sample__field button-sample__field--bottom" data-button-wave={waveMount} data-wave-canvas data-wave-variant="tidal" data-wave-role="bottom" aria-hidden="true" />
      ) : waveState === "hover" ? (
        <canvas
          class="button-sample__field button-sample__field--bottom"
          data-button-wave={waveMount}
          data-wave-canvas
          data-wave-variant="ribbon"
          data-wave-role="bottom"
          data-wave-hover-speed="1.9"
          data-wave-hover-fill="1"
          aria-hidden="true"
        />
      ) : (
        <canvas
          class="button-sample__field button-sample__field--bottom"
          data-button-wave={waveMount}
          data-wave-canvas
          data-wave-variant="ribbon"
          data-wave-role="bottom"
          data-wave-hover-fill="1"
          data-wave-fill-locked="1"
          data-wave-paused="1"
          aria-hidden="true"
        />
      )}

      {isCircle ? (
        <span class="button-sample__icon" aria-hidden="true">
          <slot name="icon">
            <slot />
          </slot>
        </span>
      ) : (
        <span class="button-sample__label">
          <slot />
        </span>
      )}
    </a>
  ) : (
    <button class:list={classes} type={type} aria-label={ariaLabel} aria-pressed={ariaPressed} disabled={disabled}>
      {waveState === "default" ? (
        <canvas class="button-sample__field button-sample__field--bottom" data-button-wave={waveMount} data-wave-canvas data-wave-variant="tidal" data-wave-role="bottom" aria-hidden="true" />
      ) : waveState === "hover" ? (
        <canvas
          class="button-sample__field button-sample__field--bottom"
          data-button-wave={waveMount}
          data-wave-canvas
          data-wave-variant="ribbon"
          data-wave-role="bottom"
          data-wave-hover-speed="1.9"
          data-wave-hover-fill="1"
          aria-hidden="true"
        />
      ) : (
        <canvas
          class="button-sample__field button-sample__field--bottom"
          data-button-wave={waveMount}
          data-wave-canvas
          data-wave-variant="ribbon"
          data-wave-role="bottom"
          data-wave-hover-fill="1"
          data-wave-fill-locked="1"
          data-wave-paused="1"
          aria-hidden="true"
        />
      )}

      {isCircle ? (
        <span class="button-sample__icon" aria-hidden="true">
          <slot name="icon">
            <slot />
          </slot>
        </span>
      ) : (
        <span class="button-sample__label">
          <slot />
        </span>
      )}
    </button>
  )
}

<script>
  import { setupWaveLifecycle } from "../utils/wave-lifecycle";
  type ButtonWaveModules = typeof import("../utils/wave-engine") & typeof import("../utils/wave-renderers/strip-wave");

  let buttonWaveModulesPromise: Promise<ButtonWaveModules> | null = null;

  const getSelfManagedCanvases = (): HTMLCanvasElement[] => {
    return Array.from(document.querySelectorAll('canvas[data-button-wave]:not([data-button-wave="external"])[data-wave-canvas]')).filter(
      (canvas): canvas is HTMLCanvasElement => canvas instanceof HTMLCanvasElement,
    );
  };

  const loadButtonWaveModules = (): Promise<ButtonWaveModules> => {
    if (!buttonWaveModulesPromise) {
      buttonWaveModulesPromise = Promise.all([
        import("../utils/wave-engine"),
        import("../utils/wave-renderers/strip-wave"),
      ]).then(([waveEngine, stripWave]) => ({
        ...waveEngine,
        ...stripWave,
      }));
    }

    return buttonWaveModulesPromise;
  };

  /**
   * Keeps the button design fully server-rendered, then mounts the decorative
   * wave engine after load/idle or as soon as a user interacts with a button.
   */
  function scheduleButtonWaveMount(): () => void {
    const canvases = getSelfManagedCanvases();
    if (canvases.length === 0) return () => {};

    let cancelled = false;
    let cleanupMountedWaves: (() => void) | null = null;
    let idleId: number | null = null;
    let timeoutId: ReturnType<typeof setTimeout> | null = null;

    const buttonRoots = canvases
      .map((canvas) => canvas.closest(".button-sample"))
      .filter((button): button is HTMLElement => button instanceof HTMLElement);

    const removeInteractionListeners = (() => {
      const listeners = buttonRoots.flatMap((button) => {
        const triggerMount = () => {
          void mountButtonWaves();
        };

        const options = { passive: true } as const;
        button.addEventListener("pointerenter", triggerMount, options);
        button.addEventListener("focusin", triggerMount);
        button.addEventListener("touchstart", triggerMount, options);

        return [
          () => button.removeEventListener("pointerenter", triggerMount, options),
          () => button.removeEventListener("focusin", triggerMount),
          () => button.removeEventListener("touchstart", triggerMount, options),
        ];
      });

      return () => {
        listeners.forEach((removeListener) => removeListener());
      };
    })();

    const mountButtonWaves = async () => {
      if (cancelled || cleanupMountedWaves) return;

      const {
        attachWaveHoverInteraction,
        mountWaveEngine,
        createStripWaveScene,
        drawStripWaveScene,
        updateStripWaveScene,
      } = await loadButtonWaveModules();

      if (cancelled || cleanupMountedWaves) return;

      cleanupMountedWaves = mountWaveEngine({
        canvasSelector: 'canvas[data-button-wave]:not([data-button-wave="external"])[data-wave-canvas]',
        createScene: ({ canvas, context }) => createStripWaveScene(canvas, context),
        drawScene: drawStripWaveScene,
        updateScene: updateStripWaveScene,
        size: { minWidth: 120, minHeight: 80, maxDpr: 2 },
        onSceneMount: ({ scene, reduceMotionQuery, renderStatic, registerCleanup }) => {
          const cleanupHover = attachWaveHoverInteraction({
            canvas: scene.canvas,
            hoverSpeedMultiplier: scene.hoverSpeedMultiplier,
            hoverFillEnabled: scene.hoverFillEnabled,
            fillLocked: scene.fillLocked,
            setSpeedMultiplier: (value) => {
              scene.speedMultiplier = value;
            },
            setTargetFillProgress: (value) => {
              scene.targetFillProgress = value;
            },
            setFillProgress: (value) => {
              scene.fillProgress = value;
            },
            isReducedMotion: () => reduceMotionQuery.matches,
            renderStatic,
          });

          registerCleanup(cleanupHover);
        },
      });

      removeInteractionListeners();
    };

    const runDeferredMount = () => {
      if (cancelled) return;

      if ("requestIdleCallback" in window) {
        idleId = requestIdleCallback(() => {
          void mountButtonWaves();
        }, { timeout: 2500 });
        return;
      }

      timeoutId = setTimeout(() => {
        void mountButtonWaves();
      }, 1200);
    };

    if (document.readyState === "complete") {
      runDeferredMount();
    } else {
      window.addEventListener("load", runDeferredMount, { once: true });
    }

    return () => {
      cancelled = true;
      window.removeEventListener("load", runDeferredMount);
      removeInteractionListeners();
      cleanupMountedWaves?.();

      if (idleId !== null && "cancelIdleCallback" in window) {
        cancelIdleCallback(idleId);
      }

      if (timeoutId !== null) {
        clearTimeout(timeoutId);
      }
    };
  }

  setupWaveLifecycle({
    scopeKey: "button-component",
    init: scheduleButtonWaveMount,
  });
</script>

<style lang="scss">
  @use "../styles/variables" as *;
  @use "../styles/mixins" as *;

  .button-sample {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 54px;
    padding: 0 1.3rem;
    border: 0;
    background: rgba($color-white, 0.98);
    color: $color-blue-dark;
    border-radius: 999px 920px 980px 840px / 900px 1020px 860px 980px;
    box-shadow:
      0 10px 20px rgba(15, 23, 42, 0.06),
      inset 0 1.2px 0 rgba($color-white, 0.88),
      inset 0 -2.8px 8px rgba($color-blue-dark, 0.08);
    cursor: pointer;
    transition:
      box-shadow 260ms var(--ease-out),
      background-color 260ms var(--ease-out);
    text-decoration: none;

    &:focus-visible {
      outline: 2px solid $color-blue;
      outline-offset: 3px;
    }

    &:disabled,
    &[aria-disabled="true"] {
      cursor: not-allowed;
      opacity: 0.72;
    }

    &--bottom {
      overflow: clip;
    }

    &--active {
      background: rgba($color-white, 0.98);
      box-shadow:
        0 12px 24px rgba(15, 23, 42, 0.08),
        inset 0 1.2px 0 rgba($color-white, 0.9),
        inset 0 -4px 10px rgba($color-blue-dark, 0.12);
    }

    &--hover,
    &--locked {
      .button-sample__field--bottom {
        inset: 0;
        width: 100%;
        height: 100%;
        transform: none;
      }

      &:hover .button-sample__field--bottom,
      &:focus-visible .button-sample__field--bottom {
        filter: saturate(1.12);
      }
    }

    &--circle {
      padding: 0.68rem;
      min-height: 0;
      aspect-ratio: 1;
      border-radius: 50%;
      overflow: clip;
    }

    &--circle-sm {
      inline-size: 44px;
      block-size: 44px;
    }

    &--circle-md {
      inline-size: 52px;
      block-size: 52px;
    }

    &--circle-lg {
      inline-size: 62px;
      block-size: 62px;
    }

    &__field {
      position: absolute;
      display: block;
      pointer-events: none;
      transition:
        transform 260ms var(--ease-out),
        filter 260ms var(--ease-out),
        opacity 260ms var(--ease-out);

      &--bottom {
        inset: auto -8px -10px -8px;
        width: calc(100% + 16px);
        height: 78px;
        transform-origin: center bottom;
      }
    }

    &__label {
      position: relative;
      z-index: 1;
      font-weight: $font-weight-semibold;
      padding: 0.3rem 0.15rem;
    }

    &__icon {
      position: relative;
      z-index: 1;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
      font-size: 1.15rem;
    }
  }
</style>
