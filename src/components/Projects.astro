---
/**
 * Project portfolio with category filtering.
 *
 * Displays projects from two sources:
 * - Featured MDX projects (src/content/projects/) with dedicated pages
 * - Simple projects (src/data/projects.ts) with external links
 *
 * Projects are shuffled on build for equal visibility.
 */
import ProjectCard from "./ProjectCard.astro";
import AnimateOnScroll from "./AnimateOnScroll.astro";
import { projects as simpleProjects } from "../data/projects";
import { getCollection } from "astro:content";

type Props = Record<string, never>;

// Get featured projects (MDX with dedicated pages)
const featuredProjects = await getCollection("projects");

// Merge both sources: featured MDX projects + simple data projects
const allProjects = [
  // Featured projects with internal pages
  ...featuredProjects.map((p) => ({
    title: p.data.title,
    description: p.data.description,
    alt: p.data.heroImageAlt || p.data.title,
    tags: p.data.tags,
    image: p.data.heroImage,
    link: p.id,
    category: p.data.category,
    hasPage: true,
  })),
  // Simple projects with external links
  ...simpleProjects.map((p) => ({
    ...p,
    hasPage: false,
  })),
];

// Fisher-Yates shuffle for equal visibility
function shuffle<T>(array: T[]): T[] {
  const shuffled = [...array];
  for (let i = shuffled.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [shuffled[i], shuffled[j]] = [shuffled[j], shuffled[i]];
  }
  return shuffled;
}

const randomizedProjects = shuffle(allProjects);

const categories = [
  { id: "all", label: "All" },
  { id: "web", label: "Web" },
  { id: "games", label: "Games" },
] as const;
---

<section class="projects" id="projects">
  <div class="projects__container">
    <div class="projects__header">
      <div class="projects__header-content">
        <span class="projects__label">MY WORK</span>
        <h2 class="projects__heading">
          Projects I've built<br />over the years
        </h2>
      </div>
      <div class="projects__filters" role="group" aria-label="Filter projects by category">
        {
          categories.map((cat) => (
            <button class:list={["projects__filter", { "projects__filter--active": cat.id === "all" }]} data-filter={cat.id} type="button" aria-pressed={cat.id === "all" ? "true" : "false"}>
              {cat.label}
            </button>
          ))
        }
      </div>
    </div>
    <div class="projects__grid" id="projects-grid">
      {
        randomizedProjects.map((project) => (
          <div class:list={["projects__item", { "projects__item--featured": project.hasPage }]} data-category={project.category}>
            <AnimateOnScroll>
              <ProjectCard
                title={project.title}
                description={project.description}
                alt={project.alt}
                tags={project.tags}
                image={project.image}
                link={project.link}
                hasPage={project.hasPage}
                category={project.category}
              />
            </AnimateOnScroll>
          </div>
        ))
      }
    </div>
    <button class="projects__skip-to-end" id="projects-skip-to-end" type="button" aria-label="Skip to end of projects section" aria-hidden="true" tabindex="-1"> Seen enough? Skip ahead </button>
    <div class="projects__end-anchor" id="projects-end" aria-hidden="true"></div>
  </div>
</section>

<script>
  /**
   * Projects filter animation model
   * -------------------------------
   * We intentionally run filtering as a two-phase sequence to avoid visible layout
   * jumps and intermittent "entry animation skipped" glitches:
   *
   * 1) Exit phase: cards that are currently visible are put in `--hiding`.
   * 2) Layout commit: filtered-out cards get `--hidden` while everything is still hidden.
   * 3) Entry phase: cards for the new filter are unhidden first, then in the next frame
   *    we remove `--hiding` so the browser always sees a transitionable change.
   *
   * This extra frame boundary is deliberate. If unhide + de-hide happen in one frame,
   * browsers may coalesce style updates and render cards instantly with no fade/pop.
   */
  // Skip CTA listeners are kept at module scope so we can reliably tear them down
  // before re-binding (filters + Astro page swaps).
  let skipVisibilityCleanup: (() => void) | null = null;
  // Monotonic token used as a cancellation guard for async callbacks.
  // Every click increments the token; stale callbacks bail out.
  let activeFilterAnimationToken = 0;
  // Timeout handles used by the two animation phases + post-animation measurement.
  // We clear these on every new filter click to prevent old callbacks from mutating
  // state after a newer interaction has started.
  let filterPhaseTimeoutId: number | null = null;
  let filterMeasurementTimeoutId: number | null = null;
  const PROJECT_ROW_POSITION_TOLERANCE = 1;
  const PROJECT_FILTER_STAGGER_MS = 35;

  function notifyProjectCardsChanged(): void {
    document.dispatchEvent(new CustomEvent("project-card:waves-sync"));
  }

  function parseCssTimeToMs(value: string): number {
    const trimmedValue = value.trim();

    if (!trimmedValue) {
      return 0;
    }

    if (trimmedValue.endsWith("ms")) {
      return Number.parseFloat(trimmedValue);
    }

    if (trimmedValue.endsWith("s")) {
      return Number.parseFloat(trimmedValue) * 1000;
    }

    return 0;
  }

  function getProjectFilterTransitionDurationMs(projectItem: HTMLElement | undefined): number {
    if (!projectItem) {
      return 0;
    }

    const computedStyle = window.getComputedStyle(projectItem);
    const durations = computedStyle.transitionDuration.split(",");
    const delays = computedStyle.transitionDelay.split(",");
    const transitionCount = Math.max(durations.length, delays.length);
    let longestTransitionMs = 0;

    for (let index = 0; index < transitionCount; index += 1) {
      const duration = parseCssTimeToMs(durations[index] ?? durations[durations.length - 1] ?? "0s");
      const delay = parseCssTimeToMs(delays[index] ?? delays[delays.length - 1] ?? "0s");
      longestTransitionMs = Math.max(longestTransitionMs, duration + delay);
    }

    return longestTransitionMs;
  }

  function prefersReducedMotion(): boolean {
    return window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  }

  function getVisibleProjectItems(projectItems: NodeListOf<HTMLElement>): HTMLElement[] {
    return Array.from(projectItems).filter((item) => !item.classList.contains("projects__item--hidden") && !item.classList.contains("projects__item--hiding"));
  }

  function getProjectItemsInVisualOrder(projectItems: HTMLElement[]): HTMLElement[] {
    const projectItemBounds = new Map(projectItems.map((projectItem) => [projectItem, projectItem.getBoundingClientRect()]));

    return [...projectItems].sort((firstItem, secondItem) => {
      const firstBounds = projectItemBounds.get(firstItem);
      const secondBounds = projectItemBounds.get(secondItem);

      if (!firstBounds || !secondBounds) {
        return 0;
      }

      const topDifference = firstBounds.top - secondBounds.top;

      if (Math.abs(topDifference) > PROJECT_ROW_POSITION_TOLERANCE) {
        return topDifference;
      }

      return firstBounds.left - secondBounds.left;
    });
  }

  function getGridColumnCount(grid: HTMLElement): number {
    const templateColumns = window.getComputedStyle(grid).gridTemplateColumns;
    const columns = templateColumns.split(" ").filter(Boolean).length;
    return Math.max(columns, 1);
  }

  function getProjectItemColumnSpan(projectItem: HTMLElement, columns: number): number {
    if (columns <= 1) {
      return 1;
    }

    return projectItem.classList.contains("projects__item--featured") ? Math.min(2, columns) : 1;
  }

  function getThresholdItem(projectItems: HTMLElement[], columns: number): HTMLElement | null {
    const visibleProjectItems = getProjectItemsInVisualOrder(projectItems);
    let occupiedColumns = 0;

    for (let index = 0; index < visibleProjectItems.length; index += 1) {
      const projectItem = visibleProjectItems[index];
      if (!projectItem) {
        continue;
      }

      const itemSpan = getProjectItemColumnSpan(projectItem, columns);

      if (occupiedColumns > 0 && occupiedColumns + itemSpan > columns) {
        return projectItem;
      }

      occupiedColumns += itemSpan;

      if (occupiedColumns === columns) {
        return visibleProjectItems[index + 1] ?? null;
      }
    }

    return null;
  }

  function setSkipButtonState(button: HTMLButtonElement, shouldShow: boolean): void {
    button.setAttribute("aria-hidden", shouldShow ? "false" : "true");
    button.tabIndex = shouldShow ? 0 : -1;
    button.classList.toggle("projects__skip-to-end--visible", shouldShow);
  }

  // Ensure observer instances do not stack across re-inits.
  function disconnectSkipObservers(): void {
    skipVisibilityCleanup?.();
    skipVisibilityCleanup = null;
  }

  function clearPendingFilterAnimationTimers(): void {
    // Defensive cleanup for rapid filter switching.
    // Without this, late timeout callbacks can reapply stale classes and cause
    // instant-appear behavior or inconsistent entry animations.
    if (filterPhaseTimeoutId !== null) {
      window.clearTimeout(filterPhaseTimeoutId);
      filterPhaseTimeoutId = null;
    }

    if (filterMeasurementTimeoutId !== null) {
      window.clearTimeout(filterMeasurementTimeoutId);
      filterMeasurementTimeoutId = null;
    }
  }

  function initFilters() {
    notifyProjectCardsChanged();

    const filterButtons = document.querySelectorAll<HTMLButtonElement>(".projects__filter");
    const projectItems = document.querySelectorAll<HTMLElement>(".projects__item");
    const projectsGrid = document.querySelector<HTMLElement>("#projects-grid");
    const skipToEndButton = document.querySelector<HTMLButtonElement>("#projects-skip-to-end");
    const projectsEndAnchor = document.querySelector<HTMLElement>("#projects-end");

    // Rebuild skip observers against the current visible grid state.
    // This must run after filtering because hidden cards change row layout.
    const observeSkipToEndVisibility = () => {
      disconnectSkipObservers();

      if (!projectsGrid || !skipToEndButton || !projectsEndAnchor) {
        return;
      }

      const visibleItems = getVisibleProjectItems(projectItems);
      const columns = getGridColumnCount(projectsGrid);

      const thresholdItem = getThresholdItem(visibleItems, columns);
      if (!thresholdItem) {
        setSkipButtonState(skipToEndButton, false);
        return;
      }

      const syncButton = () => {
        const hasPassedThreshold = thresholdItem.getBoundingClientRect().top < 0;
        const hasReachedSectionEnd = projectsEndAnchor.getBoundingClientRect().top <= window.innerHeight;
        setSkipButtonState(skipToEndButton, hasPassedThreshold && !hasReachedSectionEnd);
      };

      let isTicking = false;
      const handleVisibilityChange = () => {
        if (isTicking) {
          return;
        }

        isTicking = true;
        window.requestAnimationFrame(() => {
          isTicking = false;
          syncButton();
        });
      };

      window.addEventListener("scroll", handleVisibilityChange, { passive: true });
      window.addEventListener("resize", handleVisibilityChange);
      skipVisibilityCleanup = () => {
        window.removeEventListener("scroll", handleVisibilityChange);
        window.removeEventListener("resize", handleVisibilityChange);
      };
      syncButton();
    };

    if (skipToEndButton) {
      skipToEndButton.onclick = () => {
        // Jump to the end anchor inside Projects (not footer / next section).
        projectsEndAnchor?.scrollIntoView({ behavior: "smooth", block: "start" });
      };
    }

    filterButtons.forEach((button) => {
      button.onclick = () => {
        // Cancel any in-flight sequencing from previous clicks before starting
        // a new animation transaction.
        clearPendingFilterAnimationTimers();
        activeFilterAnimationToken += 1;
        const animationToken = activeFilterAnimationToken;
        const filter = button.dataset.filter;
        const revealedProjectItems: HTMLElement[] = [];
        const retainedProjectItems: HTMLElement[] = [];
        const hiddenProjectItems: HTMLElement[] = [];
        const transitionDurationMs = getProjectFilterTransitionDurationMs(projectItems[0]);
        const shouldAnimateProjectItems = !prefersReducedMotion() && transitionDurationMs > 0;

        // Update active button
        filterButtons.forEach((btn) => {
          btn.classList.remove("projects__filter--active");
          btn.setAttribute("aria-pressed", "false");
        });
        button.classList.add("projects__filter--active");
        button.setAttribute("aria-pressed", "true");

        // Always normalize transient classes before deriving next animation state.
        // This guarantees we classify cards from a clean baseline.
        projectItems.forEach((item) => {
          item.style.transitionDelay = "";
          item.classList.remove("projects__item--hiding");
        });

        // Filter projects with animation
        projectItems.forEach((item) => {
          const category = item.dataset.category;
          const shouldShow = filter === "all" || category === filter;
          const isCurrentlyHidden = item.classList.contains("projects__item--hidden");

          if (shouldShow) {
            if (isCurrentlyHidden) {
              item.classList.add("projects__item--hiding");
              revealedProjectItems.push(item);
            } else {
              retainedProjectItems.push(item);
            }
          } else {
            if (isCurrentlyHidden) {
              return;
            }

            hiddenProjectItems.push(item);
          }
        });

        if (!shouldAnimateProjectItems) {
          // Reduced motion / no transition path:
          // apply final visibility state immediately and skip staged sequencing.
          hiddenProjectItems.forEach((item) => {
            item.classList.add("projects__item--hidden");
            item.classList.remove("projects__item--hiding");
          });

          retainedProjectItems.forEach((item) => {
            item.classList.remove("projects__item--hiding");
          });

          revealedProjectItems.forEach((item) => {
            item.classList.add("projects__item--hiding");
            item.classList.remove("projects__item--hidden");
            item.classList.remove("projects__item--hiding");
          });

          const measurementDelay = 0;

          // Recompute threshold with updated visible items after filter animation.
          window.requestAnimationFrame(() => {
            if (animationToken !== activeFilterAnimationToken) {
              return;
            }

            observeSkipToEndVisibility();
            notifyProjectCardsChanged();
            filterMeasurementTimeoutId = window.setTimeout(() => {
              if (animationToken !== activeFilterAnimationToken) {
                return;
              }

              observeSkipToEndVisibility();
              notifyProjectCardsChanged();
            }, measurementDelay);
          });

          return;
        }

        const allVisibleProjectItems = [...retainedProjectItems, ...hiddenProjectItems];
        // Phase 1: pop/fade all currently visible cards out in place.
        allVisibleProjectItems.forEach((item) => {
          item.classList.add("projects__item--hiding");
        });

        filterPhaseTimeoutId = window.setTimeout(() => {
          if (animationToken !== activeFilterAnimationToken) {
            return;
          }

          hiddenProjectItems.forEach((item) => {
            item.classList.add("projects__item--hidden");
          });

          window.requestAnimationFrame(() => {
            if (animationToken !== activeFilterAnimationToken) {
              return;
            }

            retainedProjectItems.forEach((item) => {
              item.style.transitionDelay = "";
            });

            // Phase 2a: unhide entering cards but keep them visually hidden.
            // This creates a concrete before/after state for the upcoming transition.
            revealedProjectItems.forEach((item, index) => {
              item.style.transitionDelay = `${index * PROJECT_FILTER_STAGGER_MS}ms`;
              item.classList.remove("projects__item--hidden");

              const onTransitionEnd = (event: TransitionEvent) => {
                if (event.target !== item) {
                  return;
                }

                item.style.transitionDelay = "";
                item.removeEventListener("transitionend", onTransitionEnd);
              };

              item.addEventListener("transitionend", onTransitionEnd);
            });

            window.requestAnimationFrame(() => {
              if (animationToken !== activeFilterAnimationToken) {
                return;
              }

              // Phase 2b: remove `--hiding` in a fresh frame to force entry animation.
              // This is the key fix for "entry sometimes skipped" timing bugs.
              retainedProjectItems.forEach((item) => {
                item.classList.remove("projects__item--hiding");
              });

              revealedProjectItems.forEach((item) => {
                item.classList.remove("projects__item--hiding");
              });
            });
          });
        }, transitionDurationMs);

        const phaseOneDurationMs = transitionDurationMs;
        const phaseTwoDurationMs = transitionDurationMs + Math.max(revealedProjectItems.length - 1, 0) * PROJECT_FILTER_STAGGER_MS;
        const measurementDelay = phaseOneDurationMs + phaseTwoDurationMs;

        // Recompute threshold with updated visible items after filter animation.
        window.requestAnimationFrame(() => {
          if (animationToken !== activeFilterAnimationToken) {
            return;
          }

          observeSkipToEndVisibility();
          notifyProjectCardsChanged();
          // Match hide transition duration for stable post-animation measurement.
          filterMeasurementTimeoutId = window.setTimeout(() => {
            if (animationToken !== activeFilterAnimationToken) {
              return;
            }

            observeSkipToEndVisibility();
            notifyProjectCardsChanged();
          }, measurementDelay);
        });
      };
    });

    observeSkipToEndVisibility();
  }

  // Store handler to prevent duplicates
  let filterHandler: (() => void) | null = null;

  const ensureFilterHandler = () => {
    if (filterHandler) {
      document.removeEventListener("astro:after-swap", filterHandler);
    }
    filterHandler = initFilters;
    document.addEventListener("astro:after-swap", filterHandler);
  };

  // Run on initial load
  initFilters();
  ensureFilterHandler();
</script>

<style lang="scss">
  @use "sass:color";
  @use "../styles/variables" as *;
  @use "../styles/mixins" as *;

  .projects {
    position: relative;
    padding: $space-4xl $space-xl;

    @include respond-to(md) {
      padding: $space-3xl $space-lg;
    }

    &__container {
      position: relative;
      z-index: 1;
      max-width: $max-width;
      margin: 0 auto;
    }

    &__header {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      gap: $space-xl;
      margin-bottom: $space-3xl;

      @include respond-to(md) {
        flex-direction: column;
        align-items: flex-start;
        gap: $space-lg;
      }
    }

    &__header-content {
      flex: 1;
    }

    &__label {
      display: block;
      color: $color-orange;
      font-size: $font-size-sm;
      font-weight: 600;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      margin-bottom: $space-md;
    }

    &__heading {
      font-size: clamp($font-size-2xl, 4vw, $font-size-3xl);
      color: $color-text-dark;
      line-height: 1.2;
    }

    &__subtitle {
      color: $color-text-muted;
    }

    &__filters {
      display: flex;
      gap: $space-sm;
      flex-wrap: wrap;
      flex-shrink: 0;
    }

    &__filter {
      padding: $space-sm $space-lg;
      border: 1px solid $color-border;
      border-radius: 100px;
      background-color: $color-white;
      color: $color-text-dark;
      font-family: inherit;
      font-size: $font-size-base;
      font-weight: $font-weight-semibold;
      cursor: pointer;
      @include transition(all, 0.2s);
      @include focus-visible;

      &:hover {
        border-color: $color-orange;
        color: $color-orange;
        transform: translateY(-2px);
      }

      &--active {
        background-color: $color-blue-dark;
        border-color: $color-blue-dark;
        color: $color-white;

        &:hover {
          background-color: color.adjust($color-blue-dark, $lightness: 5%);
          border-color: color.adjust($color-blue-dark, $lightness: 5%);
          color: $color-white;
          transform: translateY(-2px);
        }
      }
    }

    &__grid {
      display: grid;
      grid-auto-flow: row dense;
      grid-template-columns: repeat(3, 1fr);
      gap: $space-xl;
      align-items: stretch;

      @include respond-to(lg) {
        grid-template-columns: repeat(2, 1fr);
      }

      @include respond-to(sm) {
        grid-template-columns: 1fr;
        gap: $space-lg;
      }
    }

    &__item {
      display: flex;
      min-width: 0;
      transition:
        opacity 0.45s cubic-bezier(0.34, 1.56, 0.64, 1),
        transform 0.45s cubic-bezier(0.34, 1.56, 0.64, 1);

      &--featured {
        grid-column: span 2;
      }

      // Animating state (fading out, but still in layout)
      &--hiding {
        opacity: 0;
        transform: translateY(12px) scale(0.97);
        pointer-events: none;
      }

      // Fully hidden state (removed from layout)
      &--hidden {
        display: none;
      }

      @include respond-to(sm) {
        &--featured {
          grid-column: auto;
        }
      }

      @include reduced-motion {
        transition: none;
      }
    }

    &__skip-to-end {
      position: fixed;
      right: $space-lg;
      bottom: $space-lg;
      z-index: 20;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      padding: $space-sm $space-lg;
      border: 1px solid $color-blue-dark;
      border-radius: 999px;
      background-color: $color-blue-dark;
      color: $color-white;
      font-size: $font-size-base;
      font-weight: $font-weight-semibold;
      line-height: 1;
      box-shadow: 0 8px 20px rgba($color-black, 0.22);
      cursor: pointer;
      opacity: 0;
      transform: translateY(20px);
      pointer-events: none;
      transition:
        opacity 0.25s ease,
        transform 0.25s ease;
      @include focus-visible;

      &:hover {
        background-color: color.adjust($color-blue-dark, $lightness: 6%);
        border-color: color.adjust($color-blue-dark, $lightness: 6%);
        transform: translateY(-2px);
      }

      &--visible {
        opacity: 1;
        transform: translateY(0);
        pointer-events: auto;
      }

      @include respond-to(sm) {
        right: $space-md;
        bottom: $space-md;
        padding: $space-sm $space-md;
        font-size: $font-size-sm;
      }

      @include reduced-motion {
        transition: none;
      }
    }

    &__end-anchor {
      height: 1px;
      width: 100%;
      pointer-events: none;
      opacity: 0;
    }
  }
</style>
