---
/**
 * WaterTank — draggable rubber-duck-in-a-tank micro-component.
 *
 * Renders a navy + pastel aquarium window on a `<canvas>` driven by the shared
 * wave engine. Water is a 1D spring surface; the duck has gravity + buoyancy
 * physics plus charm passes (blinking, squash, hearts, cheek blush).
 *
 * Interactions:
 * - Click/tap open water → splash (ripples propagate across the surface).
 * - Click/tap the duck → dunks it (it bobs back up with hearts).
 * - Press and drag on the duck → pick it up; release to drop with inertia.
 *
 * Purely decorative (`aria-hidden="true"`). Pauses via `IntersectionObserver`
 * when scrolled offscreen through the shared wave lifecycle.
 */
type Props = Record<string, never>;
---

<div class="water-tank" aria-hidden="true">
  <div class="water-tank__frame">
    <canvas class="water-tank__canvas" data-water-tank-canvas></canvas>
  </div>
  <span class="water-tank__hint">click · drag the duck</span>
</div>

<script>
  import { mountWaveEngine, syncCanvasSceneSize } from "../utils/wave-engine";
  import { setupWaveLifecycle } from "../utils/wave-lifecycle";
  import {
    createWaterTankScene,
    dragDuck,
    drawWaterTankScene,
    dunkDuck,
    grabDuck,
    pointHitsDuck,
    releaseDuck,
    splashAt,
    syncWaterTankSceneLayout,
    updateWaterTankScene,
  } from "../utils/wave-renderers/water-tank";

  function mountWaterTank(): () => void {
    return mountWaveEngine({
      canvasSelector: "[data-water-tank-canvas]",
      createScene: ({ canvas, context }) => createWaterTankScene(canvas, context),
      drawScene: drawWaterTankScene,
      updateScene: updateWaterTankScene,
      syncSceneSize: (scene) => {
        syncCanvasSceneSize(scene, { minWidth: 160, minHeight: 100, maxDpr: 2 });
        syncWaterTankSceneLayout(scene);
      },
      intersectionThreshold: 0.05,
      onSceneMount: ({ scene, registerCleanup, updatePlayback }) => {
        const canvas = scene.canvas;

        const getCanvasPoint = (event: PointerEvent) => {
          const rect = canvas.getBoundingClientRect();
          return {
            x: ((event.clientX - rect.left) / rect.width) * scene.width,
            y: ((event.clientY - rect.top) / rect.height) * scene.height,
          };
        };

        // Track per-pointer drag state so multi-touch doesn't accidentally
        // grab the duck twice or release it from the wrong finger.
        let activePointerId: number | null = null;
        let pointerStartX = 0;
        let pointerStartY = 0;
        let pointerMoved = false;
        let grabbedThisPointer = false;

        const handlePointerDown = (event: PointerEvent) => {
          if (activePointerId !== null) return;
          activePointerId = event.pointerId;
          const { x, y } = getCanvasPoint(event);
          pointerStartX = x;
          pointerStartY = y;
          pointerMoved = false;
          grabbedThisPointer = false;

          if (pointHitsDuck(scene, x, y)) {
            grabDuck(scene, x, y, performance.now());
            grabbedThisPointer = true;
            canvas.setPointerCapture(event.pointerId);
            canvas.classList.add("is-grabbing");
          }

          updatePlayback();
        };

        const handlePointerMove = (event: PointerEvent) => {
          if (event.pointerId !== activePointerId) return;
          const { x, y } = getCanvasPoint(event);
          const dx = x - pointerStartX;
          const dy = y - pointerStartY;
          if (dx * dx + dy * dy > 16) pointerMoved = true;

          // Hover cursor feedback when not dragging.
          if (!grabbedThisPointer) {
            canvas.classList.toggle("is-over-duck", pointHitsDuck(scene, x, y));
            return;
          }

          dragDuck(scene, x, y, performance.now());
          updatePlayback();
        };

        const endPointer = (event: PointerEvent) => {
          if (event.pointerId !== activePointerId) return;
          const { x, y } = getCanvasPoint(event);

          if (grabbedThisPointer) {
            releaseDuck(scene);
            canvas.classList.remove("is-grabbing");
            try {
              canvas.releasePointerCapture(event.pointerId);
            } catch {
              // Ignore if already released (e.g., pointercancel).
            }
          } else if (!pointerMoved) {
            // A tap with no drag: splash or dunk depending on where it landed.
            if (pointHitsDuck(scene, x, y)) {
              dunkDuck(scene, x, 5.5);
              splashAt(scene, x, 3.2, Math.max(32, scene.duck.radius * 1.3));
            } else {
              const depthRatio = Math.min(
                1,
                Math.max(0, (y - scene.restWaterY) / Math.max(1, scene.height - scene.restWaterY)),
              );
              const strength = 4.5 + depthRatio * 5;
              splashAt(scene, x, strength, Math.max(36, scene.width * 0.09));
            }
          }

          activePointerId = null;
          grabbedThisPointer = false;
          pointerMoved = false;
          updatePlayback();
        };

        const handlePointerHover = (event: PointerEvent) => {
          if (activePointerId !== null) return;
          const { x, y } = getCanvasPoint(event);
          canvas.classList.toggle("is-over-duck", pointHitsDuck(scene, x, y));
        };

        const handlePointerLeave = () => {
          canvas.classList.remove("is-over-duck");
        };

        canvas.addEventListener("pointerdown", handlePointerDown);
        canvas.addEventListener("pointermove", handlePointerMove);
        canvas.addEventListener("pointermove", handlePointerHover);
        canvas.addEventListener("pointerup", endPointer);
        canvas.addEventListener("pointercancel", endPointer);
        canvas.addEventListener("pointerleave", handlePointerLeave);

        registerCleanup(() => {
          canvas.removeEventListener("pointerdown", handlePointerDown);
          canvas.removeEventListener("pointermove", handlePointerMove);
          canvas.removeEventListener("pointermove", handlePointerHover);
          canvas.removeEventListener("pointerup", endPointer);
          canvas.removeEventListener("pointercancel", endPointer);
          canvas.removeEventListener("pointerleave", handlePointerLeave);
          canvas.classList.remove("is-grabbing", "is-over-duck");
        });
      },
    });
  }

  setupWaveLifecycle({
    scopeKey: "water-tank-component",
    init: mountWaterTank,
  });
</script>

<style lang="scss">
  @use "../styles/variables" as *;
  @use "../styles/mixins" as *;

  .water-tank {
    width: 100%;
    max-width: 520px;
    margin-top: $space-lg;
    position: sticky;
    top: 140px;

    @include respond-to(lg) {
      max-width: 100%;
      position: static;
    }

    &__frame {
      position: relative;
      width: 100%;
      aspect-ratio: 1 / 1;
      border-radius: 43% 57% 61% 39% / 54% 39% 61% 46%;
      overflow: hidden;
      background-color: $color-blue-dark;
      background-image: url("data:image/svg+xml;charset=utf-8,%3Csvg width='52' height='26' xmlns='http://www.w3.org/2000/svg'%3E%3Cpath d='M10 10c0-2.21-1.79-4-4-4a6 6 0 01-6-6h2c0 2.21 1.79 4 4 4a6 6 0 016 6c0 2.21 1.79 4 4 4a6 6 0 016 6c0 2.21 1.79 4 4 4v2a6 6 0 01-6-6c0-2.21-1.79-4-4-4a6 6 0 01-6-6zm25.464-1.95l8.486 8.486-1.414 1.414-8.486-8.486 1.414-1.414z' fill='%23DCEEFB' fill-opacity='.05' fill-rule='evenodd'/%3E%3C/svg%3E");
      isolation: isolate;
      transition: border-radius 2s ease-in-out, transform 400ms cubic-bezier(0.175, 0.885, 0.32, 1.275);
      animation: blob-morph 8s ease-in-out infinite alternate;

      &:hover {
        transform: translateY(-4px) scale(1.02);
      }
    }

    @keyframes blob-morph {
      0% { border-radius: 43% 57% 61% 39% / 54% 39% 61% 46%; }
      33% { border-radius: 51% 49% 48% 52% / 37% 55% 45% 63%; }
      66% { border-radius: 41% 59% 49% 51% / 58% 39% 61% 42%; }
      100% { border-radius: 43% 57% 61% 39% / 54% 39% 61% 46%; }
    }

    &__canvas {
      display: block;
      width: 100%;
      height: 100%;
      position: relative;
      z-index: 1;
      cursor: pointer;
      touch-action: none;

      &.is-over-duck {
        cursor: grab;
      }

      &.is-grabbing {
        cursor: grabbing;
      }
    }

    &__hint {
      display: block;
      text-align: center;
      margin-top: $space-md;
      font-size: 0.75rem;
      letter-spacing: 0.1em;
      text-transform: lowercase;
      color: rgba($color-text-light, 0.45);
      pointer-events: none;
      user-select: none;
    }

    @media (prefers-reduced-motion: reduce) {
      &__frame {
        transition: none;
        animation: none;

        &:hover {
          transform: none;
        }
      }
    }
  }
</style>
