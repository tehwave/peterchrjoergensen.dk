---
/**
 * Individual project display card.
 *
 * Supports two modes:
 * 1. Simple project: External link, icon indicator
 * 2. Full case study: Entire card clickable, internal route, arrow indicator
 *
 * Falls back to letter placeholder when image unavailable.
 */
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";

interface Props {
  title: string;
  description: string;
  alt: string;
  tags?: string[];
  image?: ImageMetadata;
  link?: string;
  hasPage?: boolean; // True if project has MDX page (internal route)
  animationDelay?: number;
}

const { title, description, alt, tags = [], image, link, hasPage = false } = Astro.props;

// "#" is used in data to indicate "no link yet" — treat as missing
const hasLink = link && link !== "#";

// Determine link destination and type
const isInternal = hasPage;
const linkUrl = isInternal ? `/projects/${link}/` : link;
---

{
  isInternal && hasLink ? (
    <a href={linkUrl} class:list={["project-card", "project-card--clickable", { "project-card--with-wave": hasPage }]} aria-label={`View ${title} case study`}>
      <div class="project-card__image-wrapper">
        {image ? (
          <Picture
            src={image}
            formats={["avif", "webp"]}
            alt={alt}
            class="project-card__image"
            loading="lazy"
            quality="mid"
            widths={[400, 600, 800]}
            sizes="(min-width: 1024px) 400px, (min-width: 768px) 45vw, 90vw"
          />
        ) : (
          <div class="project-card__placeholder" aria-hidden="true">
            <span>{title.charAt(0)}</span>
          </div>
        )}
        <span class="project-card__image-badge" aria-hidden="true">
          View case study
        </span>
      </div>
      <div class="project-card__content">
        <h3 class="project-card__title">
          {title}
          <svg
            class="project-card__arrow-icon"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </h3>
        <p class="project-card__description">{description}</p>
        {tags.length > 0 && (
          <div class="project-card__tags">
            {tags.map((tag) => (
              <span class="project-card__tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
      <canvas class="project-card__wave" data-project-card-wave aria-hidden="true" />
    </a>
  ) : (
    <article class="project-card">
      <div class="project-card__image-wrapper">
        {image ? (
          <Picture
            src={image}
            formats={["avif", "webp"]}
            alt={alt}
            class="project-card__image"
            loading="lazy"
            quality="mid"
            widths={[400, 600, 800]}
            sizes="(min-width: 1024px) 400px, (min-width: 768px) 45vw, 90vw"
          />
        ) : (
          <div class="project-card__placeholder" aria-hidden="true">
            <span>{title.charAt(0)}</span>
          </div>
        )}
      </div>
      <div class="project-card__content">
        <h3 class="project-card__title">
          {hasLink ? (
            <a href={linkUrl} target="_blank" rel="noopener noreferrer" class="project-card__external-link">
              {title}
              <svg class="project-card__external-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M7 17L17 7M17 7H7M17 7V17" />
              </svg>
            </a>
          ) : (
            title
          )}
        </h3>
        <p class="project-card__description">{description}</p>
        {tags.length > 0 && (
          <div class="project-card__tags">
            {tags.map((tag) => (
              <span class="project-card__tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </article>
  )
}

<script>
  interface ProjectWaveScene {
    canvas: HTMLCanvasElement;
    context: CanvasRenderingContext2D;
    width: number;
    height: number;
    dpr: number;
    visible: boolean;
    phaseOffset: number;
  }

  const PROJECT_WAVE_PALETTE = ["#57e3ff", "#4f8cff", "#9560ff", "#ff63cf", "#ff9a68"] as const;

  let projectWaveObserver: IntersectionObserver | null = null;
  let projectWaveScenes: ProjectWaveScene[] = [];
  let projectWaveFrameId: number | null = null;
  let projectWaveResizeHandler: (() => void) | null = null;
  let projectWaveVisibilityHandler: (() => void) | null = null;
  let projectWaveMotionQuery: MediaQueryList | null = null;
  let projectWaveMotionChangeHandler: ((event: MediaQueryListEvent) => void) | null = null;
  let projectWaveSyncHandler: (() => void) | null = null;
  let projectWavePageLoadHandler: (() => void) | null = null;

  function teardownProjectCardWaves(): void {
    if (projectWaveFrameId !== null) {
      window.cancelAnimationFrame(projectWaveFrameId);
      projectWaveFrameId = null;
    }

    projectWaveObserver?.disconnect();
    projectWaveObserver = null;

    if (projectWaveResizeHandler) {
      window.removeEventListener("resize", projectWaveResizeHandler);
      projectWaveResizeHandler = null;
    }

    if (projectWaveVisibilityHandler) {
      document.removeEventListener("visibilitychange", projectWaveVisibilityHandler);
      projectWaveVisibilityHandler = null;
    }

    if (projectWaveMotionQuery && projectWaveMotionChangeHandler) {
      projectWaveMotionQuery.removeEventListener("change", projectWaveMotionChangeHandler);
    }

    projectWaveMotionQuery = null;
    projectWaveMotionChangeHandler = null;
    projectWaveScenes = [];
  }

  function syncProjectWaveSceneSize(scene: ProjectWaveScene): void {
    const rect = scene.canvas.getBoundingClientRect();
    scene.width = Math.max(120, Math.floor(rect.width));
    scene.height = Math.max(72, Math.floor(rect.height));
    scene.dpr = Math.min(window.devicePixelRatio || 1, 2);

    scene.canvas.width = Math.max(1, Math.floor(scene.width * scene.dpr));
    scene.canvas.height = Math.max(1, Math.floor(scene.height * scene.dpr));
    scene.context.setTransform(scene.dpr, 0, 0, scene.dpr, 0, 0);
  }

  function drawProjectWave(scene: ProjectWaveScene, time: number): void {
    const { context, width, height, phaseOffset } = scene;
    const baseY = height * 0.7;
    const maxAmplitude = 10;

    context.clearRect(0, 0, width, height);

    for (let layer = 0; layer < 3; layer += 1) {
      const gradient = context.createLinearGradient(0, 0, width, 0);
      for (let index = 0; index < PROJECT_WAVE_PALETTE.length; index += 1) {
        gradient.addColorStop(index / (PROJECT_WAVE_PALETTE.length - 1), PROJECT_WAVE_PALETTE[(index + layer) % PROJECT_WAVE_PALETTE.length]);
      }

      const amplitude = maxAmplitude - layer * 2;
      const frequency = 0.012 + layer * 0.0018;
      const phase = time * (0.00022 + layer * 0.00005) + phaseOffset + layer * 0.8;

      context.save();
      context.globalCompositeOperation = "screen";
      context.globalAlpha = 0.5 - layer * 0.09;
      context.strokeStyle = gradient;
      context.fillStyle = gradient;
      context.lineWidth = 1.5;
      context.beginPath();

      for (let x = 0; x <= width + 2; x += 3) {
        const waveY = baseY + Math.sin(x * frequency + phase) * amplitude + Math.cos(x * frequency * 1.76 + phase * 0.84) * (amplitude * 0.34);
        if (x === 0) {
          context.moveTo(x, waveY);
        } else {
          context.lineTo(x, waveY);
        }
      }

      context.lineTo(width, height + 4);
      context.lineTo(0, height + 4);
      context.closePath();
      context.fill();
      context.restore();
    }
  }

  function renderProjectWaves(time: number): void {
    for (const scene of projectWaveScenes) {
      if (!scene.visible) {
        continue;
      }
      drawProjectWave(scene, time);
    }

    projectWaveFrameId = window.requestAnimationFrame(renderProjectWaves);
  }

  function updateProjectWavePlayback(): void {
    const hasVisibleScene = projectWaveScenes.some((scene) => scene.visible);
    const shouldAnimate = Boolean(!projectWaveMotionQuery?.matches && !document.hidden && hasVisibleScene);

    if (!shouldAnimate) {
      if (projectWaveFrameId !== null) {
        window.cancelAnimationFrame(projectWaveFrameId);
        projectWaveFrameId = null;
      }

      for (const scene of projectWaveScenes) {
        drawProjectWave(scene, 0);
      }
      return;
    }

    if (projectWaveFrameId === null) {
      projectWaveFrameId = window.requestAnimationFrame(renderProjectWaves);
    }
  }

  function initProjectCardWaves(): void {
    teardownProjectCardWaves();

    const canvases = Array.from(document.querySelectorAll("[data-project-card-wave]"));
    const waveCanvases = canvases.filter((canvas): canvas is HTMLCanvasElement => canvas instanceof HTMLCanvasElement);

    if (waveCanvases.length === 0) {
      return;
    }

    projectWaveScenes = waveCanvases
      .map((canvas, index) => {
        const context = canvas.getContext("2d", { alpha: true });
        if (!context) {
          return null;
        }

        const scene: ProjectWaveScene = {
          canvas,
          context,
          width: 0,
          height: 0,
          dpr: 1,
          visible: true,
          phaseOffset: index * 0.65,
        };

        syncProjectWaveSceneSize(scene);
        return scene;
      })
      .filter((scene): scene is ProjectWaveScene => Boolean(scene));

    if (projectWaveScenes.length === 0) {
      return;
    }

    projectWaveObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          const target = entry.target;
          if (!(target instanceof HTMLCanvasElement)) {
            continue;
          }

          const scene = projectWaveScenes.find((item) => item.canvas === target);
          if (!scene) {
            continue;
          }

          scene.visible = entry.isIntersecting;
        }

        updateProjectWavePlayback();
      },
      { threshold: 0.05 },
    );

    projectWaveScenes.forEach((scene) => {
      projectWaveObserver?.observe(scene.canvas);
    });

    projectWaveResizeHandler = () => {
      projectWaveScenes.forEach((scene) => syncProjectWaveSceneSize(scene));
      updateProjectWavePlayback();
    };

    projectWaveVisibilityHandler = () => {
      updateProjectWavePlayback();
    };

    projectWaveMotionQuery = window.matchMedia("(prefers-reduced-motion: reduce)");
    projectWaveMotionChangeHandler = () => {
      updateProjectWavePlayback();
    };

    window.addEventListener("resize", projectWaveResizeHandler, { passive: true });
    document.addEventListener("visibilitychange", projectWaveVisibilityHandler);
    projectWaveMotionQuery.addEventListener("change", projectWaveMotionChangeHandler);

    updateProjectWavePlayback();
  }

  function ensureProjectCardWaveHandlers(): void {
    if (projectWaveSyncHandler) {
      document.removeEventListener("project-card:waves-sync", projectWaveSyncHandler);
    }

    if (projectWavePageLoadHandler) {
      document.removeEventListener("astro:page-load", projectWavePageLoadHandler);
    }

    projectWaveSyncHandler = initProjectCardWaves;
    projectWavePageLoadHandler = initProjectCardWaves;

    document.addEventListener("project-card:waves-sync", projectWaveSyncHandler);
    document.addEventListener("astro:page-load", projectWavePageLoadHandler);
  }

  initProjectCardWaves();
  ensureProjectCardWaveHandlers();

  document.addEventListener(
    "astro:before-preparation",
    () => {
      teardownProjectCardWaves();
    },
    { once: true },
  );
</script>

<style lang="scss">
  @use "sass:color";
  @use "../styles/variables" as *;
  @use "../styles/mixins" as *;

  .project-card {
    background-color: $color-white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px $color-shadow;
    @include transition(all, 0.3s);
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;

    &:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px $color-shadow-hover;

      .project-card__image {
        transform: scale(1.05);
      }

      .project-card__placeholder {
        background: linear-gradient(135deg, color.adjust($color-blue, $lightness: 5%) 0%, $color-blue-dark 100%);
      }
    }

    // Clickable card state (for internal pages)
    &--clickable {
      cursor: pointer;
      @include focus-visible;

      &:hover {
        .project-card__title {
          color: $color-orange;
        }

        .project-card__arrow-icon {
          transform: translateX(4px);
          opacity: 1;
        }

        .project-card__image-badge {
          transform: translateY(-2px);
        }
      }

      &:focus-visible {
        outline: 2px solid $color-orange;
        outline-offset: 2px;
      }
    }

    &--with-wave {
      position: relative;
      border: 1px solid rgba($color-blue-dark, 0.14);
      background-color: $color-white;
      box-shadow:
        0 2px 8px $color-shadow,
        0 10px 24px rgba($color-blue-dark, 0.08);
    }

    &__image-wrapper {
      position: relative;
      z-index: 1;
      aspect-ratio: 16 / 10;
      overflow: hidden;
      background-color: $color-cream;
      // Reserve space to prevent CLS
      contain: layout style paint;
    }

    &__image {
      width: 100%;
      height: 100%;
      object-fit: cover;
      @include transition(transform, 0.3s);
      // Explicit aspect-ratio for CLS prevention
      aspect-ratio: 16 / 10;
    }

    &__placeholder {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      background: linear-gradient(135deg, $color-blue 0%, $color-blue-dark 100%);
      @include transition(background, 0.3s);

      span {
        font-size: $font-size-4xl;
        font-weight: 700;
        color: $color-white;
        opacity: 0.9;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.2);
      }
    }

    &__image-badge {
      position: absolute;
      left: $space-xl;
      top: $space-xl;
      z-index: 2;
      display: inline-flex;
      align-items: center;
      padding: 0.35rem 0.65rem;
      border-radius: 999px;
      background: rgba($color-blue-dark, 0.88);
      color: $color-white;
      font-size: $font-size-xs;
      font-weight: $font-weight-semibold;
      letter-spacing: 0.02em;
      box-shadow: 0 4px 12px rgba($color-black, 0.2);
      @include transition(transform, 0.2s);
    }

    &__content {
      position: relative;
      z-index: 1;
      padding: $space-xl;
      display: flex;
      flex-direction: column;
      gap: $space-sm;
      flex-grow: 1;
    }

    &__title {
      font-size: $font-size-lg;
      font-weight: 600;
      color: $color-text-dark;
      display: flex;
      align-items: center;
      gap: $space-xs;
      @include transition(color, 0.2s);
    }

    // Arrow icon for internal pages (full card clickable)
    &__arrow-icon {
      opacity: 0.6;
      flex-shrink: 0;
      @include transition(all, 0.2s);
    }

    // External link styling (title-only clickable)
    &__external-link {
      color: inherit;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: $space-xs;
      border-radius: 4px;
      @include focus-visible;

      &:hover {
        color: $color-orange;
      }
    }

    &__external-icon {
      opacity: 0.6;
      @include transition(transform, 0.2s);

      .project-card__external-link:hover & {
        transform: translate(2px, -2px);
        opacity: 1;
      }
    }

    &__description {
      font-size: $font-size-sm;
      color: $color-text-muted;
      line-height: 1.6;
      flex-grow: 1;
    }

    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: $space-xs;
      margin-top: auto;
    }

    &__tag {
      font-size: $font-size-xs;
      color: $color-text-muted;
      background-color: $color-blue-pale;
      padding: $space-xs $space-sm;
      border-radius: 4px;
    }

    &__wave {
      position: absolute;
      inset: auto -10px -16px -10px;
      width: calc(100% + 20px);
      height: 112px;
      display: block;
      pointer-events: none;
      z-index: 0;
      opacity: 0.92;
    }
  }
</style>
