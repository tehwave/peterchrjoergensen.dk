---
/**
 * Individual project display card.
 *
 * Supports two modes:
 * 1. Simple project: External link, icon indicator
 * 2. Full case study: Entire card clickable, internal route, arrow indicator
 *
 * Falls back to letter placeholder when image unavailable.
 */
import { Picture } from "astro:assets";
import type { ImageMetadata } from "astro";
import type { ProjectCategory } from "../types";

interface Props {
  title: string;
  description: string;
  alt: string;
  tags?: string[];
  image?: ImageMetadata;
  link?: string;
  hasPage?: boolean; // True if project has MDX page (internal route)
  animationDelay?: number;
  /** Category (or categories) used to drive the colored image backdrop. */
  category?: ProjectCategory | ProjectCategory[];
}

const { title, description, alt, tags = [], image, link, hasPage = false, category } = Astro.props;

// "#" is used in data to indicate "no link yet" — treat as missing
const hasLink = link && link !== "#";

// Determine link destination and type
const isInternal = hasPage;
const linkUrl = isInternal ? `/projects/${link}/` : link;
// These must stay aligned with the max-width breakpoints in `respond-to(lg)`
// and `respond-to(sm)` from `_mixins.scss`, so image source sizing flips when
// the grid actually changes column count.
const desktopMultiColumnMinWidth = 1025;
const tabletMultiColumnMinWidth = 641;
const desktopGridWidth = "min(calc(100vw - (var(--space-xl) * 2)), var(--max-width))";
const tabletGridWidth = "calc(100vw - (var(--space-lg) * 2))";
const gridGap = "var(--space-xl)";
const standardCardDesktopWidth = `calc((${desktopGridWidth} - (${gridGap} * 2)) / 3)`;
const featuredCardTabletWidth = tabletGridWidth;
const standardCardTabletWidth = `calc((${tabletGridWidth} - ${gridGap}) / 2)`;
const mobileCardWidth = tabletGridWidth;
const imageWidths = hasPage ? [400, 800, 1200, 1600] : [400, 600, 800];
const imageSizes = hasPage
  ? `(min-width: ${desktopMultiColumnMinWidth}px) ${standardCardDesktopWidth}, (min-width: ${tabletMultiColumnMinWidth}px) ${featuredCardTabletWidth}, ${mobileCardWidth}`
  : `(min-width: ${desktopMultiColumnMinWidth}px) ${standardCardDesktopWidth}, (min-width: ${tabletMultiColumnMinWidth}px) ${standardCardTabletWidth}, ${mobileCardWidth}`;

// Normalize category into a sorted, space-separated token list so multi-category
// cards can be styled with a combined gradient in the future.
const categoryList = (Array.isArray(category) ? category : category ? [category] : []).slice().sort();
const dataCategory = categoryList.length > 0 ? categoryList.join(" ") : undefined;
---

{
  isInternal && hasLink ? (
    <a
      href={linkUrl}
      class:list={["project-card", "project-card--clickable", { "project-card--featured": hasPage, "project-card--with-wave": hasPage }]}
      data-category={dataCategory}
      aria-label={`View ${title} case study`}
    >
      <div class="project-card__image-wrapper">
        {image ? (
          <Picture src={image} formats={["avif", "webp"]} alt={alt} class="project-card__image" loading="lazy" quality="mid" widths={imageWidths} sizes={imageSizes} />
        ) : (
          <div class="project-card__placeholder" aria-hidden="true">
            <span>{title.charAt(0)}</span>
          </div>
        )}
        <span class="project-card__image-badge" aria-hidden="true">
          View case study
        </span>
      </div>
      <div class="project-card__content">
        <h3 class="project-card__title">
          {title}
          <svg
            class="project-card__arrow-icon"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            aria-hidden="true"
          >
            <line x1="5" y1="12" x2="19" y2="12" />
            <polyline points="12 5 19 12 12 19" />
          </svg>
        </h3>
        <p class="project-card__description">{description}</p>
        {tags.length > 0 && (
          <div class="project-card__tags">
            {tags.map((tag) => (
              <span class="project-card__tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
      <canvas class="project-card__wave" data-project-card-wave aria-hidden="true" />
    </a>
  ) : (
    <article class="project-card" data-category={dataCategory}>
      <div class="project-card__image-wrapper">
        {image ? (
          <Picture src={image} formats={["avif", "webp"]} alt={alt} class="project-card__image" loading="lazy" quality="mid" widths={imageWidths} sizes={imageSizes} />
        ) : (
          <div class="project-card__placeholder" aria-hidden="true">
            <span>{title.charAt(0)}</span>
          </div>
        )}
      </div>
      <div class="project-card__content">
        <h3 class="project-card__title">
          {hasLink ? (
            <a href={linkUrl} target="_blank" rel="noopener noreferrer" class="project-card__external-link">
              {title}
              <svg class="project-card__external-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M7 17L17 7M17 7H7M17 7V17" />
              </svg>
            </a>
          ) : (
            title
          )}
        </h3>
        <p class="project-card__description">{description}</p>
        {tags.length > 0 && (
          <div class="project-card__tags">
            {tags.map((tag) => (
              <span class="project-card__tag">{tag}</span>
            ))}
          </div>
        )}
      </div>
    </article>
  )
}

<script>
  import type { WaveSceneBase } from "../utils/wave-engine";
  import { mountWaveEngine } from "../utils/wave-engine";
  import { ensureScopedDocumentListener, setupWaveLifecycle } from "../utils/wave-lifecycle";

  interface ProjectCardWaveScene extends WaveSceneBase {
    phaseOffset: number;
  }

  const PROJECT_CARD_WAVE_PALETTE = ["#57e3ff", "#4f8cff", "#9560ff", "#ff63cf", "#ff9a68"] as const;

  function createProjectCardWaveScene(canvas: HTMLCanvasElement, context: CanvasRenderingContext2D, index: number): ProjectCardWaveScene {
    return {
      canvas,
      context,
      width: 0,
      height: 0,
      dpr: 1,
      visible: true,
      phaseTime: 0,
      speedMultiplier: 1,
      paused: false,
      phaseOffset: index * 0.65,
    };
  }

  function drawProjectCardWaveScene(scene: ProjectCardWaveScene, time: number): void {
    const { context, width, height, phaseOffset } = scene;
    const baseY = height * 0.7;
    const maxAmplitude = 10;

    context.clearRect(0, 0, width, height);

    for (let layer = 0; layer < 3; layer += 1) {
      const gradient = context.createLinearGradient(0, 0, width, 0);
      for (let index = 0; index < PROJECT_CARD_WAVE_PALETTE.length; index += 1) {
        gradient.addColorStop(index / (PROJECT_CARD_WAVE_PALETTE.length - 1), PROJECT_CARD_WAVE_PALETTE[(index + layer) % PROJECT_CARD_WAVE_PALETTE.length]);
      }

      const amplitude = maxAmplitude - layer * 2;
      const frequency = 0.012 + layer * 0.0018;
      const phase = time * (0.00022 + layer * 0.00005) + phaseOffset + layer * 0.8;

      context.save();
      context.globalCompositeOperation = "screen";
      context.globalAlpha = 0.5 - layer * 0.09;
      context.strokeStyle = gradient;
      context.fillStyle = gradient;
      context.lineWidth = 1.5;
      context.beginPath();

      for (let x = 0; x <= width + 2; x += 3) {
        const waveY = baseY + Math.sin(x * frequency + phase) * amplitude + Math.cos(x * frequency * 1.76 + phase * 0.84) * (amplitude * 0.34);
        if (x === 0) {
          context.moveTo(x, waveY);
        } else {
          context.lineTo(x, waveY);
        }
      }

      context.lineTo(width, height + 4);
      context.lineTo(0, height + 4);
      context.closePath();
      context.fill();
      context.restore();
    }
  }

  let projectCardWaveCleanup: (() => void) | null = null;

  function mountProjectCardWaves(): () => void {
    return mountWaveEngine({
      canvasSelector: "[data-project-card-wave]",
      createScene: ({ canvas, context, index }) => createProjectCardWaveScene(canvas, context, index),
      drawScene: drawProjectCardWaveScene,
      size: { minWidth: 120, minHeight: 72, maxDpr: 2 },
      intersectionThreshold: 0.05,
      staticTime: 0,
    });
  }

  function initProjectCardWaves(): () => void {
    projectCardWaveCleanup?.();
    projectCardWaveCleanup = mountProjectCardWaves();

    return () => {
      projectCardWaveCleanup?.();
      projectCardWaveCleanup = null;
    };
  }

  setupWaveLifecycle({
    scopeKey: "project-card-waves",
    init: initProjectCardWaves,
  });

  ensureScopedDocumentListener({
    scopeKey: "project-card-waves",
    event: "project-card:waves-sync",
    handler: () => {
      initProjectCardWaves();
    },
  });
</script>

<style lang="scss">
  @use "../styles/variables" as *;
  @use "../styles/mixins" as *;

  .project-card {
    background-color: $color-white;
    border-radius: $radius-2xl;
    overflow: hidden;
    box-shadow: 0 2px 8px $color-shadow;
    @include transition(all, 0.3s);
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;

    &:hover {
      transform: translateY(-4px);
      box-shadow: 0 8px 24px $color-shadow-hover;

      .project-card__image {
        transform: translateY(-5px);
      }

      .project-card__placeholder {
        transform: translateY(-5px);
      }
    }

    // Clickable card state (for internal pages)
    &--clickable {
      cursor: pointer;
      @include focus-visible;

      &:hover {
        .project-card__title {
          color: $color-orange;
        }

        .project-card__arrow-icon {
          transform: translateX(4px);
          opacity: 1;
        }

        .project-card__image-badge {
          transform: translateY(-2px);
        }
      }

      &:focus-visible {
        outline: 2px solid $color-orange;
        outline-offset: 2px;
      }
    }

    &--with-wave {
      position: relative;
      border: 1px solid rgba($color-blue-dark, 0.14);
      background-color: $color-white;
      box-shadow:
        0 2px 8px $color-shadow,
        0 10px 24px rgba($color-blue-dark, 0.08);
    }

    &--featured {
      display: grid;
      grid-template-columns: minmax(18rem, 0.95fr) minmax(0, 1.25fr);
      align-items: stretch;

      @include respond-to(md) {
        grid-template-columns: 1fr;
      }

      &:hover {
        .project-card__image {
          transform: scale(1.03);
        }

        .project-card__placeholder {
          transform: scale(1.03);
        }
      }
    }

    &__image-wrapper {
      position: relative;
      z-index: 1;
      padding: $space-md $space-md 0;
      background-color: $color-neutral-200;
      // Let the image bleed past the bottom edge
      overflow: visible;
      contain: layout style;

      // Pattern overlay (category-specific). Sits above the gradient, below the image tile.
      &::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background-image: var(--project-card-pattern, none);
        background-size: var(--project-card-pattern-size, 32px 32px);
        opacity: 0.9;
        mix-blend-mode: soft-light;
      }
    }

    &--featured &__image-wrapper {
      display: flex;
      align-items: center;
      padding: $space-lg;
      min-width: 0;

      @include respond-to(md) {
        padding: $space-md $space-md 0;
      }
    }

    &__image {
      position: relative;
      z-index: 1;
      display: block;
      width: 100%;
      height: auto;
      aspect-ratio: 16 / 10;
      object-fit: cover;
      border-radius: calc(#{$radius-2xl} - #{$space-sm});
      // Bleed into the content area below
      margin-bottom: -14px;
      transition: transform 0.36s cubic-bezier(0.22, 1, 0.36, 1);
      will-change: transform;
    }

    &--featured &__image {
      width: 100%;
      height: auto;
      aspect-ratio: 4 / 3;
      margin-bottom: 0;
      box-shadow: 0 18px 36px rgba($color-blue-dark, 0.16);

      @include respond-to(md) {
        aspect-ratio: 16 / 10;
        margin-bottom: -14px;
        box-shadow: none;
      }
    }

    &__placeholder {
      position: relative;
      z-index: 1;
      display: flex;
      align-items: center;
      justify-content: center;
      width: 100%;
      aspect-ratio: 16 / 10;
      border-radius: calc(#{$radius-2xl} - #{$space-xs});
      margin-bottom: -14px;
      background: linear-gradient(135deg, rgba($color-white, 0.22) 0%, rgba($color-black, 0.18) 100%);
      transition:
        transform 0.36s cubic-bezier(0.22, 1, 0.36, 1),
        background 0.3s ease;

      span {
        font-size: $font-size-4xl;
        font-weight: 700;
        color: $color-white;
        opacity: 0.95;
        text-shadow: 0 2px 10px rgba(0, 0, 0, 0.25);
      }
    }

    &--featured &__placeholder {
      aspect-ratio: 4 / 3;
      margin-bottom: 0;
      box-shadow: 0 18px 36px rgba($color-blue-dark, 0.16);

      @include respond-to(md) {
        aspect-ratio: 16 / 10;
        margin-bottom: -14px;
        box-shadow: none;
      }
    }

    // Category-driven backdrops behind the image tile.
    // Patterns double as a11y affordance for color-blind users.
    &[data-category~="web"] .project-card__image-wrapper {
      background: linear-gradient(135deg, $color-blue-light 0%, $color-blue 55%, $color-blue-dark 100%);
      // Grid / tic-tac-toe lines — technical, structured feel.
      --project-card-pattern: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='32' height='32'><path d='M0 16h32M16 0v32' stroke='white' stroke-width='1' opacity='0.35'/></svg>");
      --project-card-pattern-size: 32px 32px;
    }

    &[data-category~="games"] .project-card__image-wrapper {
      background: linear-gradient(135deg, $color-orange-light 0%, $color-orange 55%, $color-orange-dark 100%);
      // Alternating plus / circle pattern — arcade feel with more visual distinction.
      --project-card-pattern: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='44' height='44'><path d='M10 4v12M4 10h12' stroke='white' stroke-width='1.6' stroke-linecap='round' opacity='0.42'/><circle cx='34' cy='10' r='5.5' fill='none' stroke='white' stroke-width='1.4' opacity='0.38'/><circle cx='10' cy='34' r='5.5' fill='none' stroke='white' stroke-width='1.4' opacity='0.38'/><path d='M34 28v12M28 34h12' stroke='white' stroke-width='1.6' stroke-linecap='round' opacity='0.42'/></svg>");
      --project-card-pattern-size: 44px 44px;
    }

    &[data-category~="creative"] .project-card__image-wrapper {
      background: linear-gradient(135deg, #a78bfa 0%, $color-purple 100%);
      // Overlapping circles — bubbles / playful.
      --project-card-pattern: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' width='40' height='40'><circle cx='10' cy='10' r='7' fill='none' stroke='white' stroke-width='1' opacity='0.4'/><circle cx='30' cy='30' r='7' fill='none' stroke='white' stroke-width='1' opacity='0.4'/><circle cx='30' cy='10' r='7' fill='none' stroke='white' stroke-width='1' opacity='0.25'/><circle cx='10' cy='30' r='7' fill='none' stroke='white' stroke-width='1' opacity='0.25'/></svg>");
      --project-card-pattern-size: 40px 40px;
    }

    // Combined backdrops for multi-category projects.
    &[data-category~="web"][data-category~="games"] .project-card__image-wrapper {
      background: linear-gradient(135deg, $color-blue 0%, $color-blue-dark 45%, $color-orange 55%, $color-orange-dark 100%);
    }

    &[data-category~="web"][data-category~="creative"] .project-card__image-wrapper {
      background: linear-gradient(135deg, $color-blue 0%, $color-blue-dark 45%, $color-purple 100%);
    }

    &[data-category~="games"][data-category~="creative"] .project-card__image-wrapper {
      background: linear-gradient(135deg, $color-orange 0%, $color-orange-dark 45%, $color-purple 100%);
    }

    &__image-badge {
      position: absolute;
      left: calc(#{$space-md} + #{$space-sm});
      top: calc(#{$space-md} + #{$space-sm});
      z-index: 2;
      display: inline-flex;
      align-items: center;
      padding: 0.35rem 0.65rem;
      border-radius: 999px;
      background: rgba($color-blue-dark, 0.88);
      color: $color-white;
      font-size: $font-size-xs;
      font-weight: $font-weight-semibold;
      letter-spacing: 0.02em;
      box-shadow: 0 4px 12px rgba($color-black, 0.2);
      @include transition(transform, 0.2s);
    }

    &--featured &__image-badge {
      left: calc(#{$space-lg} + #{$space-sm});
      top: calc(#{$space-lg} + #{$space-sm});

      @include respond-to(md) {
        left: calc(#{$space-md} + #{$space-sm});
        top: calc(#{$space-md} + #{$space-sm});
      }
    }

    &__content {
      position: relative;
      z-index: 1;
      padding: $space-xl;
      display: flex;
      flex-direction: column;
      gap: $space-sm;
      flex-grow: 1;
    }

    &--featured &__content {
      justify-content: center;
      padding: $space-2xl $space-2xl calc(#{$space-2xl} + 4.5rem);
      gap: $space-md;

      @include respond-to(md) {
        padding: $space-xl $space-xl calc(#{$space-xl} + 4.5rem);
      }
    }

    &__title {
      font-size: $font-size-lg;
      font-weight: 600;
      color: $color-text-dark;
      display: flex;
      align-items: center;
      gap: $space-xs;
      @include transition(color, 0.2s);
    }

    &--featured &__title {
      font-size: clamp($font-size-xl, 1.5vw + 1rem, $font-size-2xl);
      line-height: 1.15;
    }

    // Arrow icon for internal pages (full card clickable)
    &__arrow-icon {
      opacity: 0.6;
      flex-shrink: 0;
      @include transition(all, 0.2s);
    }

    // External link styling (title-only clickable)
    &__external-link {
      color: inherit;
      text-decoration: none;
      display: inline-flex;
      align-items: center;
      gap: $space-xs;
      border-radius: 4px;
      @include focus-visible;

      &:hover {
        color: $color-orange;
      }
    }

    &__external-icon {
      opacity: 0.6;
      @include transition(transform, 0.2s);

      .project-card__external-link:hover & {
        transform: translate(2px, -2px);
        opacity: 1;
      }
    }

    &__description {
      font-size: $font-size-sm;
      color: $color-text-muted;
      line-height: 1.6;
      flex-grow: 1;

      .project-card--with-wave & {
        max-width: 62ch;
      }
    }

    &--featured &__description {
      font-size: $font-size-base;
      line-height: 1.75;
      max-width: 58ch;
    }

    &__tags {
      display: flex;
      flex-wrap: wrap;
      gap: $space-xs;
      margin-top: auto;
    }

    &__tag {
      font-size: $font-size-xs;
      color: $color-text-muted;
      background-color: $color-blue-pale;
      padding: $space-xs $space-sm;
      border-radius: 4px;
    }

    &__wave {
      position: absolute;
      inset: auto -10px -16px -10px;
      width: calc(100% + 20px);
      height: 112px;
      display: block;
      pointer-events: none;
      z-index: 0;
      opacity: 0.92;
    }

    &--featured &__wave {
      height: 96px;
    }
  }
</style>
